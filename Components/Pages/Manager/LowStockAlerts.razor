    .ls-filter-tag-close {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        font-size: 1rem;
        line-height: 1;
        color: color-mix(in srgb, var(--color-primary-text) 55%, transparent);
        transition: color 0.15s ease;
    }

    .ls-filter-tag-close:hover { color: var(--color-heading-text); }

    /* ── Table ──────────────────────────────────────────────────── */
    .ls-table { color: var(--color-primary-text); }

    .ls-table-head {
        background-color: color-mix(in srgb, var(--color-card-bg) 60%, var(--color-page-bg));
        border-bottom: 1px solid color-mix(in srgb, var(--color-border-accent) 20%, transparent);
    }

    .ls-table-head th {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: color-mix(in srgb, var(--color-primary-text) 60%, transparent);
        padding: 10px 12px;
        white-space: nowrap;
    }

    .ls-table tbody tr { border-bottom: 1px solid color-mix(in srgb, var(--color-border-accent) 15%, transparent); }
    .ls-table tbody tr:last-child { border-bottom: none; }

    /* ── Table row urgency highlighting ────────────────────────── */
    .ls-table-row { transition: background-color 0.12s ease; }

    .ls-table-row:hover {
        background-color: color-mix(in srgb, var(--color-border-accent) 6%, var(--color-card-bg));
    }

    .ls-row-out-of-stock {
        background-color: color-mix(in srgb, var(--color-accent) 6%, var(--color-card-bg));
    }

    .ls-row-out-of-stock:hover {
        background-color: color-mix(in srgb, var(--color-accent) 10%, var(--color-card-bg));
    }

    .ls-row-critical {
        background-color: color-mix(in srgb, var(--color-accent) 4%, var(--color-card-bg));
    }

    /* ── Table cell content ─────────────────────────────────────── */
    .ls-product-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--color-heading-text);
    }

    .ls-product-supplier {
        font-size: 0.75rem;
        color: color-mix(in srgb, var(--color-primary-text) 55%, transparent);
        margin-top: 2px;
    }

    .ls-sku-pill {
        display: inline-block;
        font-family: 'Courier New', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        background-color: color-mix(in srgb, var(--color-border-accent) 12%, var(--color-page-bg));
        color: var(--color-heading-text);
        padding: 2px 8px;
        border-radius: 5px;
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 25%, transparent);
    }

    .ls-product-id {
        font-size: 0.72rem;
        color: color-mix(in srgb, var(--color-primary-text) 45%, transparent);
        margin-top: 4px;
    }

    .ls-stock-value {
        font-size: 1.1rem;
        font-weight: 700;
    }

    .ls-stock-zero { color: var(--color-accent); }
    .ls-stock-low  { color: color-mix(in srgb, var(--color-accent) 85%, var(--color-heading-text)); }

    /* ── Urgency badges ─────────────────────────────────────────── */
    .ls-urgency-badge {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 2px 7px;
        border-radius: 4px;
        border: 1px solid;
    }

    .ls-badge-out-of-stock {
        background-color: color-mix(in srgb, var(--color-accent) 18%, var(--color-card-bg));
        border-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
        color: var(--color-accent);
    }

    .ls-badge-critical {
        background-color: color-mix(in srgb, var(--color-accent) 10%, var(--color-card-bg));
        border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
        color: color-mix(in srgb, var(--color-accent) 90%, var(--color-heading-text));
    }

    .ls-badge-warning {
        background-color: color-mix(in srgb, var(--color-border-accent) 12%, var(--color-card-bg));
        border-color: color-mix(in srgb, var(--color-border-accent) 35%, transparent);
        color: color-mix(in srgb, var(--color-heading-text) 80%, var(--color-accent));
    }

    /* ── Reorder level & deficit cells ─────────────────────────── */
    .ls-reorder-level {
        font-size: 0.875rem;
        font-weight: 600;
        color: color-mix(in srgb, var(--color-primary-text) 75%, transparent);
    }

    .ls-deficit {
        font-size: 0.875rem;
        font-weight: 700;
    }

    .ls-deficit-positive { color: var(--color-accent); }
    .ls-deficit-met      { color: color-mix(in srgb, var(--color-primary-text) 40%, transparent); }

    /* ── Date cells ─────────────────────────────────────────────── */
    .ls-date {
        font-size: 0.825rem;
        color: var(--color-primary-text);
    }

    .ls-time {
        font-size: 0.72rem;
        color: color-mix(in srgb, var(--color-primary-text) 45%, transparent);
        margin-top: 2px;
    }

    /* ── Quick Reorder button ───────────────────────────────────── */
    .ls-btn-reorder {
        display: inline-flex;
        align-items: center;
        background-color: var(--color-button-primary);
        border: 1px solid var(--color-button-primary);
        color: var(--color-page-bg);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 7px 14px;
        border-radius: 7px;
        transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.1s ease, box-shadow 0.15s ease;
        white-space: nowrap;
    }

    .ls-btn-reorder:hover {
        background-color: var(--color-button-hover);
        border-color: var(--color-button-hover);
        color: var(--color-page-bg);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px color-mix(in srgb, var(--color-button-primary) 30%, transparent);
    }

    .ls-btn-reorder:active {
        transform: translateY(0);
        box-shadow: none;
    }

    /* ── Primary & Outline buttons ──────────────────────────────── */
    .ls-btn-primary {
        background-color: var(--color-button-primary);
        border: 1px solid var(--color-button-primary);
        color: var(--color-page-bg);
        font-size: 0.8rem;
        font-weight: 500;
    }

    .ls-btn-primary:hover, .ls-btn-primary:focus {
        background-color: var(--color-button-hover);
        border-color: var(--color-button-hover);
        color: var(--color-page-bg);
    }

    .ls-btn-outline {
        background-color: transparent;
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 40%, transparent);
        color: var(--color-primary-text);
        font-size: 0.8rem;
        font-weight: 500;
    }

    .ls-btn-outline:hover, .ls-btn-outline:focus {
        background-color: color-mix(in srgb, var(--color-border-accent) 10%, transparent);
        border-color: var(--color-border-accent);
        color: var(--color-primary-text);
    }

    /* ── Pagination ─────────────────────────────────────────────── */
    .ls-page-info {
        font-size: 0.8rem;
        color: color-mix(in srgb, var(--color-primary-text) 60%, transparent);
    }

    .ls-page-btn { min-width: 34px; }

    /* ── Empty state ────────────────────────────────────────────── */
    .ls-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 20px 0;
        color: color-mix(in srgb, var(--color-primary-text) 45%, transparent);
    }

    .ls-empty-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-heading-text);
    }

    .ls-empty-subtitle {
        font-size: 0.85rem;
        color: color-mix(in srgb, var(--color-primary-text) 55%, transparent);
        max-width: 360px;
    }

    /* ── Skeleton loading ───────────────────────────────────────── */
    .ls-skeleton {
        background: linear-gradient(
            90deg,
            color-mix(in srgb, var(--color-border-accent) 15%, var(--color-card-bg)) 25%,
            color-mix(in srgb, var(--color-border-accent) 25%, var(--color-card-bg)) 50%,
            color-mix(in srgb, var(--color-border-accent) 15%, var(--color-card-bg)) 75%
        );
        background-size: 200% 100%;
        animation: ls-shimmer 1.4s ease-in-out infinite;
        border-radius: 4px;
    }

    .ls-skeleton-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ls-skeleton-text { display: block; }

    @@keyframes ls-shimmer {
        from { background-position: 200% 0; }
        to   { background-position: -200% 0; }
    }

    /* ── Navigation shortcut buttons ────────────────────────────── */
    .ls-nav-link-btn {
        display: inline-flex;
        align-items: center;
        background-color: transparent;
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 30%, transparent);
        color: color-mix(in srgb, var(--color-primary-text) 70%, transparent);
        font-size: 0.8rem;
        font-weight: 500;
        padding: 7px 14px;
        border-radius: 7px;
        transition: all 0.15s ease;
    }

    .ls-nav-link-btn:hover {
        background-color: color-mix(in srgb, var(--color-border-accent) 8%, var(--color-card-bg));
        border-color: var(--color-border-accent);
        color: var(--color-heading-text);
    }
