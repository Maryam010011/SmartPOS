@page "/manager/purchase-orders"
@using SmartPOS.Shared.DTOs.PurchaseOrders
@inject IPurchaseOrderService PurchaseOrderService
@inject ISupplierService SupplierService
@inject IProductService ProductService

<PageTitle>Purchase Orders</PageTitle>

<div class="sp-page p-4">
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="sp-heading h3 mb-1">Purchase Orders</h1>
            <p class="sp-text-muted mb-0">Create, track, and manage supplier purchase orders.</p>
        </div>
        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center gap-2 w-100 w-xl-auto">
            <div class="input-group">
                <span class="input-group-text sp-input-addon">Search</span>
                <InputText class="form-control sp-input" @bind-Value="SearchText" @bind-Value:event="oninput" placeholder="Search purchase orders..." />
            </div>
            <InputSelect class="form-select sp-input" @bind-Value="StatusFilter" @onblur="OnStatusFilterBlur">
                <option value="">All Statuses</option>
                @foreach (var status in StatusOptions)
                {
                    <option value="@status">@status</option>
                }
            </InputSelect>
            <button class="btn sp-btn-primary" type="button" @onclick="OpenCreateModal">Create Purchase Order</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert sp-alert mb-4" role="alert">
            <strong>Action failed.</strong> @ErrorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="alert sp-alert mb-4" role="alert">
            <strong>Success.</strong> @SuccessMessage
        </div>
    }

    <section class="sp-card">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 sp-border-bottom">
            <div>
                <h2 class="sp-heading h5 mb-1">Purchase Order Summary</h2>
                <p class="sp-text-muted small mb-0">Review recent purchase orders and status updates.</p>
            </div>
            <span class="badge sp-badge-accent">@FilteredOrders.Count order(s)</span>
        </div>

        <div class="table-responsive">
            <table class="table sp-table mb-0">
                <thead class="sp-table-head">
                    <tr>
                        <th scope="col">PO #</th>
                        <th scope="col">Supplier</th>
                        <th scope="col">Status</th>
                        <th scope="col">Total Cost</th>
                        <th scope="col">Order Date</th>
                        <th scope="col">Line Items</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="7" class="p-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="spinner-border sp-spinner" role="status"></div>
                                    <span class="sp-text-muted">Loading purchase orders...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (PagedOrders.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="p-4">
                                <p class="mb-0 sp-text-muted">No purchase orders match the current filters.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var order in PagedOrders)
                        {
                            <tr>
                                <td>@order.Id</td>
                                <td>@order.SupplierName</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(order.Status)">@GetStatusLabel(order.Status)</span>
                                </td>
                                <td>@order.TotalCost.ToString("N2")</td>
                                <td>@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td>@order.LineItems.Count</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        <button class="btn sp-btn-outline btn-sm" type="button" @onclick="() => OpenDetailsModal(order)">View Details</button>
                                        <button class="btn sp-btn-outline btn-sm" type="button" @onclick="() => MarkAsReceived(order)" disabled="@(!CanMarkAsReceived(order) || IsActionBusy)">
                                            Mark Received
                                        </button>
                                        <button class="btn sp-btn-outline btn-sm po-btn-danger" type="button" @onclick="() => OpenCancelModal(order)" disabled="@(!CanCancel(order) || IsActionBusy)">
                                            Cancel
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 sp-border-top">
            <p class="mb-0 sp-text-muted small">Showing @(PagedOrders.Count) of @(FilteredOrders.Count) entries</p>
            <div class="btn-group" role="group" aria-label="Purchase order pagination">
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="PreviousPage" disabled="@IsFirstPage">Previous</button>
                @foreach (var page in PageNumbers)
                {
                    <button class="btn @(page == CurrentPage ? "sp-btn-primary" : "sp-btn-outline") btn-sm" type="button" @onclick="() => GoToPage(page)">
                        @(page)
                    </button>
                }
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="NextPage" disabled="@IsLastPage">Next</button>
            </div>
        </div>
    </section>
</div>

@if (IsCreateModalOpen)
{
    <div class="po-modal-backdrop">
        <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header">
                    <div>
                        <h2 class="h5 sp-heading mb-1">Create Purchase Order</h2>
                        <p class="sp-text-muted small mb-0">Select a supplier and add the required products.</p>
                    </div>
                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="CloseCreateModal">Close</button>
                </div>
                <div class="modal-body p-4">
                    <EditForm EditContext="CreateEditContext" OnSubmit="HandleCreateSubmit">
                        <ValidationSummary class="sp-validation-summary" />
                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label sp-label">Supplier</label>
                                <InputSelect class="form-select sp-input" @bind-Value="CreateModel.SupplierId" @bind-Value:event="onblur">
                                    <option value="0">Select supplier</option>
                                    @foreach (var supplier in ActiveSuppliers)
                                    {
                                        <option value="@supplier.Id">@supplier.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => CreateModel.SupplierId)" class="sp-validation-message" />
                            </div>
                            <div class="col-12 col-lg-6">
                                <label class="form-label sp-label">Notes</label>
                                <InputTextArea class="form-control sp-input" @bind-Value="CreateModel.Notes" @bind-Value:event="onblur" rows="2" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 mb-2">
                            <h3 class="sp-heading h6 mb-0">Line Items</h3>
                            <button class="btn sp-btn-outline btn-sm" type="button" @onclick="AddLineItem">Add Line Item</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table sp-table mb-0">
                                <thead class="sp-table-head">
                                    <tr>
                                        <th scope="col">Product</th>
                                        <th scope="col">Quantity</th>
                                        <th scope="col">Unit Price</th>
                                        <th scope="col">Line Total</th>
                                        <th scope="col" class="text-end">Remove</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (CreateModel.LineItems.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5" class="p-4">
                                                <p class="mb-0 sp-text-muted">Add at least one line item to proceed.</p>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var line in CreateModel.LineItems)
                                        {
                                            <tr>
                                                <td class="align-top">
                                                    <InputSelect class="form-select sp-input" @bind-Value="line.ProductId" @bind-Value:event="onblur" @onchange="(args) => OnProductChanged(line, args)">
                                                        <option value="0">Select product</option>
                                                        @foreach (var product in ActiveProducts)
                                                        {
                                                            <option value="@product.Id">@product.Name</option>
                                                        }
                                                    </InputSelect>
                                                    <ValidationMessage For="@(() => line.ProductId)" class="sp-validation-message" />
                                                </td>
                                                <td class="align-top">
                                                    <InputNumber class="form-control sp-input" @bind-Value="line.OrderedQty" @bind-Value:event="onblur" />
                                                    <ValidationMessage For="@(() => line.OrderedQty)" class="sp-validation-message" />
                                                </td>
                                                <td class="align-top">
                                                    <InputNumber class="form-control sp-input" @bind-Value="line.UnitPrice" @bind-Value:event="onblur" />
                                                    <ValidationMessage For="@(() => line.UnitPrice)" class="sp-validation-message" />
                                                </td>
                                                <td class="align-top">
                                                    <div class="sp-text-muted">@line.LineTotal.ToString("N2")</div>
                                                </td>
                                                <td class="align-top text-end">
                                                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="() => RemoveLineItem(line)">Remove</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div class="sp-text-muted">Total Estimated Cost</div>
                            <div class="h5 sp-heading mb-0">@CreateTotalCost.ToString("N2")</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button class="btn sp-btn-outline" type="button" @onclick="CloseCreateModal">Cancel</button>
                            <button class="btn sp-btn-primary" type="submit" disabled="@IsSaving">
                                @(IsSaving ? "Creating..." : "Create Purchase Order")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (IsDetailsModalOpen && SelectedOrder is not null)
{
    <div class="po-modal-backdrop">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header">
                    <div>
                        <h2 class="h5 sp-heading mb-1">Purchase Order Details</h2>
                        <p class="sp-text-muted small mb-0">Review the order information and line items.</p>
                    </div>
                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="CloseDetailsModal">Close</button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <div class="sp-text-muted small">Supplier</div>
                            <div class="sp-heading">@SelectedOrder.SupplierName</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="sp-text-muted small">Status</div>
                            <span class="badge @GetStatusBadgeClass(SelectedOrder.Status)">@GetStatusLabel(SelectedOrder.Status)</span>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="sp-text-muted small">Order Date</div>
                            <div>@SelectedOrder.OrderDate.ToLocalTime().ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="sp-text-muted small">Received Date</div>
                            <div>@(SelectedOrder.ReceivedAt.HasValue ? SelectedOrder.ReceivedAt.Value.ToLocalTime().ToString("dd/MM/yyyy") : "Pending")</div>
                        </div>
                        <div class="col-12">
                            <div class="sp-text-muted small">Notes</div>
                            <div>@(string.IsNullOrWhiteSpace(SelectedOrder.Notes) ? "No notes provided." : SelectedOrder.Notes)</div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table sp-table mb-0">
                            <thead class="sp-table-head">
                                <tr>
                                    <th scope="col">Product</th>
                                    <th scope="col">Quantity</th>
                                    <th scope="col">Unit Price</th>
                                    <th scope="col">Line Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in SelectedOrder.LineItems)
                                {
                                    <tr>
                                        <td>@line.ProductName</td>
                                        <td>@line.OrderedQty</td>
                                        <td>@line.UnitPrice.ToString("N2")</td>
                                        <td>@line.LineTotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-end align-items-center mt-3">
                        <div class="sp-text-muted me-3">Total Cost</div>
                        <div class="h5 sp-heading mb-0">@SelectedOrder.TotalCost.ToString("N2")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (IsCancelModalOpen && PendingCancelOrder is not null)
{
    <div class="po-modal-backdrop">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header">
                    <div>
                        <h2 class="h5 sp-heading mb-1">Cancel Purchase Order</h2>
                        <p class="sp-text-muted small mb-0">This action cannot be undone.</p>
                    </div>
                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="CloseCancelModal">Close</button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-0">Confirm cancellation for purchase order #@PendingCancelOrder.Id from @PendingCancelOrder.SupplierName.</p>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button class="btn sp-btn-outline" type="button" @onclick="CloseCancelModal">Keep Order</button>
                        <button class="btn po-btn-danger" type="button" @onclick="ConfirmCancel" disabled="@IsActionBusy">
                            @(IsActionBusy ? "Cancelling..." : "Cancel Purchase Order")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .po-modal-backdrop {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background-color: color-mix(in srgb, var(--color-navbar-bg) 30%, transparent);
        backdrop-filter: blur(8px);
        z-index: 1050;
    }

    .po-btn-danger {
        background-color: var(--color-border-accent);
        border-color: var(--color-border-accent);
        color: var(--color-page-bg);
    }

    .po-btn-danger:hover {
        background-color: var(--color-button-hover);
        border-color: var(--color-button-hover);
        color: var(--color-page-bg);
    }

    .po-badge-draft {
        background-color: transparent;
        border: 1px solid var(--color-border-accent);
        color: var(--color-primary-text);
    }

    .po-badge-sent {
        background-color: var(--color-badge);
        color: var(--color-page-bg);
    }

    .po-badge-received {
        background-color: var(--color-accent);
        color: var(--color-page-bg);
    }

    .po-badge-cancelled {
        background-color: color-mix(in srgb, var(--color-border-accent) 60%, transparent);
        color: var(--color-primary-text);
    }

    .sp-validation-summary {
        margin-bottom: 16px;
        color: var(--color-primary-text);
    }

    .sp-validation-message {
        margin-top: 8px;
        color: var(--color-primary-text);
    }
</style>

@code {
    private const int PageSize = 8;
    private const int DefaultUserId = 1;

    private readonly List<string> StatusOptions = Enum.GetNames<POStatus>().ToList();

    private List<PurchaseOrderDto> AllPurchaseOrders { get; set; } = new();
    private List<SupplierDto> Suppliers { get; set; } = new();
    private List<ProductDto> Products { get; set; } = new();

    private bool IsLoading { get; set; }
    private bool IsSaving { get; set; }
    private bool IsActionBusy { get; set; }

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            CurrentPage = 1;
        }
    }
    private string _searchText = string.Empty;

    private string StatusFilter
    {
        get => _statusFilter;
        set
        {
            _statusFilter = value;
            CurrentPage = 1;
        }
    }
    private string _statusFilter = string.Empty;

    private int CurrentPage { get; set; } = 1;

    private string ErrorMessage { get; set; } = string.Empty;
    private string SuccessMessage { get; set; } = string.Empty;

    private bool IsCreateModalOpen { get; set; }
    private bool IsDetailsModalOpen { get; set; }
    private bool IsCancelModalOpen { get; set; }

    private PurchaseOrderDto? SelectedOrder { get; set; }
    private PurchaseOrderDto? PendingCancelOrder { get; set; }

    private PurchaseOrderFormModel CreateModel { get; set; } = new();
    private EditContext CreateEditContext { get; set; } = default!;
    private ValidationMessageStore CreateValidationMessageStore { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        InitializeCreateForm();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var ordersTask = PurchaseOrderService.GetAll();
            var suppliersTask = SupplierService.GetAll();
            var productsTask = ProductService.GetAll();

            await Task.WhenAll(ordersTask, suppliersTask, productsTask);

            var ordersResponse = await ordersTask;
            var suppliersResponse = await suppliersTask;
            var productsResponse = await productsTask;

            if (ordersResponse.Success && ordersResponse.Data is not null)
            {
                AllPurchaseOrders = ordersResponse.Data;
            }
            else
            {
                ErrorMessage = ordersResponse.Message;
            }

            if (suppliersResponse.Success && suppliersResponse.Data is not null)
            {
                Suppliers = suppliersResponse.Data;
            }

            if (productsResponse.Success && productsResponse.Data is not null)
            {
                Products = productsResponse.Data;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unable to load purchase orders. {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private IReadOnlyList<SupplierDto> ActiveSuppliers => Suppliers.Where(s => s.IsActive).ToList();
    private IReadOnlyList<ProductDto> ActiveProducts => Products.Where(p => p.IsActive).ToList();

    private IReadOnlyList<PurchaseOrderDto> FilteredOrders
    {
        get
        {
            IEnumerable<PurchaseOrderDto> query = AllPurchaseOrders;

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                query = query.Where(order =>
                    order.Id.ToString().Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                    order.SupplierName.Contains(SearchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(StatusFilter) && Enum.TryParse<POStatus>(StatusFilter, out var status))
            {
                query = query.Where(order => order.Status == status);
            }

            return query.OrderByDescending(order => order.OrderDate).ToList();
        }
    }

    private IReadOnlyList<PurchaseOrderDto> PagedOrders => FilteredOrders
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private IReadOnlyList<int> PageNumbers => Enumerable.Range(1, Math.Max(1, (int)Math.Ceiling(FilteredOrders.Count / (double)PageSize))).ToList();

    private bool IsFirstPage => CurrentPage <= 1;
    private bool IsLastPage => CurrentPage >= PageNumbers.Count;

    private void NextPage()
    {
        if (!IsLastPage)
            CurrentPage++;
    }

    private void PreviousPage()
    {
        if (!IsFirstPage)
            CurrentPage--;
    }

    private void GoToPage(int page)
    {
        CurrentPage = page;
    }

    private void OpenCreateModal()
    {
        InitializeCreateForm();
        IsCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        IsCreateModalOpen = false;
    }

    private void OpenDetailsModal(PurchaseOrderDto order)
    {
        SelectedOrder = order;
        IsDetailsModalOpen = true;
    }

    private void CloseDetailsModal()
    {
        IsDetailsModalOpen = false;
        SelectedOrder = null;
    }

    private void OpenCancelModal(PurchaseOrderDto order)
    {
        PendingCancelOrder = order;
        IsCancelModalOpen = true;
    }

    private void CloseCancelModal()
    {
        PendingCancelOrder = null;
        IsCancelModalOpen = false;
    }

    private async Task HandleCreateSubmit()
    {
        if (!ValidateCreateForm())
            return;

        IsSaving = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var dto = new CreatePODto
            {
                SupplierId = CreateModel.SupplierId,
                UserId = DefaultUserId,
                Notes = CreateModel.Notes.Trim(),
                LineItems = CreateModel.LineItems.Select(line => new POLineItemDto
                {
                    ProductId = line.ProductId,
                    ProductName = line.ProductName,
                    OrderedQty = line.OrderedQty,
                    UnitPrice = line.UnitPrice
                }).ToList()
            };

            var response = await PurchaseOrderService.Create(dto);

            if (response.Success)
            {
                SuccessMessage = response.Message;
                IsCreateModalOpen = false;
                await LoadDataAsync();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to create purchase order. {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task MarkAsReceived(PurchaseOrderDto order)
    {
        if (!CanMarkAsReceived(order))
            return;

        IsActionBusy = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var response = await PurchaseOrderService.MarkAsReceived(order.Id, DefaultUserId);

            if (response.Success)
            {
                SuccessMessage = response.Message;
                await LoadDataAsync();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unable to mark purchase order as received. {ex.Message}";
        }
        finally
        {
            IsActionBusy = false;
        }
    }

    private async Task ConfirmCancel()
    {
        if (PendingCancelOrder is null)
            return;

        IsActionBusy = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var response = await PurchaseOrderService.Cancel(PendingCancelOrder.Id);

            if (response.Success)
            {
                SuccessMessage = response.Message;
                await LoadDataAsync();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unable to cancel purchase order. {ex.Message}";
        }
        finally
        {
            IsActionBusy = false;
            CloseCancelModal();
        }
    }

    private void AddLineItem()
    {
        CreateModel.LineItems.Add(new POLineItemFormModel());
    }

    private void RemoveLineItem(POLineItemFormModel line)
    {
        CreateModel.LineItems.Remove(line);
        CreateEditContext.NotifyValidationStateChanged();
    }

    private void OnProductChanged(POLineItemFormModel line, ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var productId))
        {
            var product = ActiveProducts.FirstOrDefault(p => p.Id == productId);
            if (product is not null)
            {
                line.ProductId = product.Id;
                line.ProductName = product.Name;
                line.UnitPrice = product.CostPrice > 0 ? product.CostPrice : product.Price;
            }
        }
    }

    private decimal CreateTotalCost => CreateModel.LineItems.Sum(line => line.LineTotal);

    private void InitializeCreateForm()
    {
        CreateModel = new PurchaseOrderFormModel();
        CreateModel.LineItems.Add(new POLineItemFormModel());
        CreateEditContext = new EditContext(CreateModel);
        CreateValidationMessageStore = new ValidationMessageStore(CreateEditContext);
    }

    private bool ValidateCreateForm()
    {
        CreateValidationMessageStore.Clear();
        var isValid = true;

        if (CreateModel.SupplierId <= 0)
        {
            CreateValidationMessageStore.Add(new FieldIdentifier(CreateModel, nameof(CreateModel.SupplierId)), "Supplier selection is required.");
            isValid = false;
        }

        if (CreateModel.LineItems.Count == 0)
        {
            CreateValidationMessageStore.Add(new FieldIdentifier(CreateModel, nameof(CreateModel.LineItems)), "At least one line item is required.");
            isValid = false;
        }

        foreach (var line in CreateModel.LineItems)
        {
            if (line.ProductId <= 0)
            {
                CreateValidationMessageStore.Add(new FieldIdentifier(line, nameof(line.ProductId)), "Product selection is required.");
                isValid = false;
            }

            if (line.OrderedQty <= 0)
            {
                CreateValidationMessageStore.Add(new FieldIdentifier(line, nameof(line.OrderedQty)), "Quantity must be greater than zero.");
                isValid = false;
            }

            if (line.UnitPrice <= 0)
            {
                CreateValidationMessageStore.Add(new FieldIdentifier(line, nameof(line.UnitPrice)), "Unit price must be greater than zero.");
                isValid = false;
            }
        }

        CreateEditContext.NotifyValidationStateChanged();
        return isValid;
    }

    private void ValidateField(FieldIdentifier field)
    {
        CreateValidationMessageStore.Clear(field);

        if (field.Model is PurchaseOrderFormModel model && field.FieldName == nameof(PurchaseOrderFormModel.SupplierId))
        {
            if (model.SupplierId <= 0)
            {
                CreateValidationMessageStore.Add(field, "Supplier selection is required.");
            }
        }

        if (field.Model is POLineItemFormModel item)
        {
            if (field.FieldName == nameof(POLineItemFormModel.ProductId) && item.ProductId <= 0)
            {
                CreateValidationMessageStore.Add(field, "Product selection is required.");
            }

            if (field.FieldName == nameof(POLineItemFormModel.OrderedQty) && item.OrderedQty <= 0)
            {
                CreateValidationMessageStore.Add(field, "Quantity must be greater than zero.");
            }

            if (field.FieldName == nameof(POLineItemFormModel.UnitPrice) && item.UnitPrice <= 0)
            {
                CreateValidationMessageStore.Add(field, "Unit price must be greater than zero.");
            }
        }

        CreateEditContext.NotifyValidationStateChanged();
    }

    private void OnStatusFilterBlur()
    {
        CurrentPage = 1;
    }

    private static bool CanMarkAsReceived(PurchaseOrderDto order)
        => order.Status != POStatus.Received && order.Status != POStatus.Cancelled;

    private static bool CanCancel(PurchaseOrderDto order)
        => order.Status != POStatus.Cancelled && order.Status != POStatus.Received;

    private static string GetStatusBadgeClass(POStatus status) => status switch
    {
        POStatus.Draft => "po-badge-draft",
        POStatus.Sent => "po-badge-sent",
        POStatus.Received => "po-badge-received",
        POStatus.Cancelled => "po-badge-cancelled",
        _ => "po-badge-draft"
    };

    private static string GetStatusLabel(POStatus status) => status switch
    {
        POStatus.Draft => "Draft",
        POStatus.Sent => "Sent",
        POStatus.Received => "Received",
        POStatus.Cancelled => "Cancelled",
        _ => "Unknown"
    };

    private sealed class PurchaseOrderFormModel
    {
        public int SupplierId { get; set; }
        public string Notes { get; set; } = string.Empty;
        public List<POLineItemFormModel> LineItems { get; set; } = new();
    }

    private sealed class POLineItemFormModel
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int OrderedQty { get; set; } = 1;
        public decimal UnitPrice { get; set; }

        public decimal LineTotal => OrderedQty * UnitPrice;
    }
}