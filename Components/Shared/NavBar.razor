@using SmartPOS.Services.MaryamJ
@inject SmartPOS.Services.MaryamJ.AuthStateService AuthState
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<nav class="navbar-pos">
    <div class="navbar-left">
        <span class="navbar-brand">🎂 SmartPOS+</span>
    </div>
    <div class="navbar-right">
        @if (AuthState.IsAuthenticated)
        {
            <span class="navbar-user">@AuthState.UserName</span>
            <span class="navbar-role-badge">@AuthState.UserRole</span>
            <button @onclick="HandleLogout" class="navbar-logout-btn" style="background: none; border: none; cursor: pointer;">Logout</button>
        }
        else
        {
            <a href="/login" class="navbar-logout-btn">Sign In</a>
        }
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnChange += StateHasChanged;
    }

    private async Task HandleLogout()
    {
        if (AuthStateProvider is CustomAuthStateProvider customProvider)
        {
            await customProvider.NotifyLogoutAsync();
        }
        else
        {
            AuthState.Logout();
        }
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }
}
