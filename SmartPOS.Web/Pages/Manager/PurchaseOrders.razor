    /* ── Animations ──────────────────────────────────── */
    @@keyframes po-fade-in  { from { opacity: 0; }           to { opacity: 1; }          }
    @@keyframes po-slide-up { from { transform: translateY(16px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
</style>

@code {
    private const int PageSize = 8;
    private const int DefaultUserId = 1;

    private readonly List<string> StatusOptions = Enum.GetNames<POStatus>().ToList();

    private List<PurchaseOrderDto> AllPurchaseOrders { get; set; } = new();
    private List<SupplierDto> Suppliers { get; set; } = new();
    private List<ProductDto> Products { get; set; } = new();

    private bool IsLoading { get; set; }
    private bool IsSaving { get; set; }
    private bool IsActionBusy { get; set; }

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            CurrentPage = 1;
        }
    }
    private string _searchText = string.Empty;

    private string StatusFilter
    {
        get => _statusFilter;
        set
        {
            _statusFilter = value;
            CurrentPage = 1;
        }
    }
    private string _statusFilter = string.Empty;

    private int CurrentPage { get; set; } = 1;

    private string ErrorMessage { get; set; } = string.Empty;
    private string SuccessMessage { get; set; } = string.Empty;

    private bool IsCreateModalOpen { get; set; }
    private bool IsDetailsModalOpen { get; set; }
    private bool IsCancelModalOpen { get; set; }

    private PurchaseOrderDto? SelectedOrder { get; set; }
    private PurchaseOrderDto? PendingCancelOrder { get; set; }

    private PurchaseOrderFormModel CreateModel { get; set; } = new();
    private EditContext CreateEditContext { get; set; } = default!;
    private ValidationMessageStore CreateValidationMessageStore { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        InitializeCreateForm();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var ordersTask = PurchaseOrderService.GetAll();
            var suppliersTask = SupplierService.GetAll();
            var productsTask = ProductService.GetAll();

            await Task.WhenAll(ordersTask, suppliersTask, productsTask);

            var ordersResponse = await ordersTask;
            var suppliersResponse = await suppliersTask;
            var productsResponse = await productsTask;

            if (ordersResponse.Success && ordersResponse.Data is not null)
            {
                AllPurchaseOrders = ordersResponse.Data;
            }
            else
            {
                ErrorMessage = ordersResponse.Message;
            }

            if (suppliersResponse.Success && suppliersResponse.Data is not null)
            {
                Suppliers = suppliersResponse.Data;
            }

            if (productsResponse.Success && productsResponse.Data is not null)
            {
                Products = productsResponse.Data;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unable to load purchase orders. {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private IReadOnlyList<SupplierDto> ActiveSuppliers => Suppliers.Where(s => s.IsActive).ToList();
    private IReadOnlyList<ProductDto> ActiveProducts => Products.Where(p => p.IsActive).ToList();

    private IReadOnlyList<PurchaseOrderDto> FilteredOrders
    {
        get
        {
            IEnumerable<PurchaseOrderDto> query = AllPurchaseOrders;

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                query = query.Where(order =>
                    order.Id.ToString().Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                    order.SupplierName.Contains(SearchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(StatusFilter) && Enum.TryParse<POStatus>(StatusFilter, out var status))
            {
                query = query.Where(order => order.Status == status);
            }

            return query.OrderByDescending(order => order.OrderDate).ToList();
        }
    }

    private IReadOnlyList<PurchaseOrderDto> PagedOrders => FilteredOrders
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private IReadOnlyList<int> PageNumbers => Enumerable.Range(1, Math.Max(1, (int)Math.Ceiling(FilteredOrders.Count / (double)PageSize))).ToList();

    private bool IsFirstPage => CurrentPage <= 1;
    private bool IsLastPage => CurrentPage >= PageNumbers.Count;

    private void NextPage()
    {
        if (!IsLastPage)
            CurrentPage++;
    }

    private void PreviousPage()
    {
        if (!IsFirstPage)
            CurrentPage--;
    }

    private void GoToPage(int page)
    {
        CurrentPage = page;
    }

    private void OpenCreateModal()
    {
        InitializeCreateForm();
        IsCreateModalOpen = true;
    }

    private void CloseCreateModal()
    {
        IsCreateModalOpen = false;
    }

    private void OpenDetailsModal(PurchaseOrderDto order)
    {
        SelectedOrder = order;
        IsDetailsModalOpen = true;
    }

    private void CloseDetailsModal()
    {
        IsDetailsModalOpen = false;
        SelectedOrder = null;
    }

    private void OpenCancelModal(PurchaseOrderDto order)
    {
        PendingCancelOrder = order;
        IsCancelModalOpen = true;
    }

    private void CloseCancelModal()
    {
        PendingCancelOrder = null;
        IsCancelModalOpen = false;
    }

    private async Task HandleCreateSubmit()
    {
        if (!ValidateCreateForm())
            return;

        IsSaving = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var dto = new CreatePODto
            {
                SupplierId = CreateModel.SupplierId,
                UserId = DefaultUserId,
                Notes = CreateModel.Notes.Trim(),
                LineItems = CreateModel.LineItems.Select(line => new POLineItemDto
                {
                    ProductId = line.ProductId,
                    ProductName = line.ProductName,
                    OrderedQty = line.OrderedQty,
                    UnitPrice = line.UnitPrice
                }).ToList()
            };

            var response = await PurchaseOrderService.Create(dto);

            if (response.Success)
            {
                SuccessMessage = response.Message;
                IsCreateModalOpen = false;
                await LoadDataAsync();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to create purchase order. {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task MarkAsReceived(PurchaseOrderDto order)
    {
        if (!CanMarkAsReceived(order))
            return;

        IsActionBusy = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var response = await PurchaseOrderService.MarkAsReceived(order.Id, DefaultUserId);

            if (response.Success)
            {
                SuccessMessage = response.Message;
                await LoadDataAsync();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unable to mark purchase order as received. {ex.Message}";
        }
        finally
        {
            IsActionBusy = false;
        }
    }

    private async Task ConfirmCancel()
    {
        if (PendingCancelOrder is null)
            return;

        IsActionBusy = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            var response = await PurchaseOrderService.Cancel(PendingCancelOrder.Id);

            if (response.Success)
            {
                SuccessMessage = response.Message;
                await LoadDataAsync();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unable to cancel purchase order. {ex.Message}";
        }
        finally
        {
            IsActionBusy = false;
            CloseCancelModal();
        }
    }

    private void AddLineItem()
    {
        CreateModel.LineItems.Add(new POLineItemFormModel());
    }

    private void RemoveLineItem(POLineItemFormModel line)
    {
        CreateModel.LineItems.Remove(line);
        CreateEditContext.NotifyValidationStateChanged();
    }

    private void OnProductChanged(POLineItemFormModel line, ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var productId))
        {
            var product = ActiveProducts.FirstOrDefault(p => p.Id == productId);
            if (product is not null)
            {
                line.ProductId = product.Id;
                line.ProductName = product.Name;
                line.UnitPrice = product.CostPrice > 0 ? product.CostPrice : product.Price;
            }
        }
    }

    private decimal CreateTotalCost => CreateModel.LineItems.Sum(line => line.LineTotal);

    private void InitializeCreateForm()
    {
        CreateModel = new PurchaseOrderFormModel();
        CreateModel.LineItems.Add(new POLineItemFormModel());
        CreateEditContext = new EditContext(CreateModel);
        CreateValidationMessageStore = new ValidationMessageStore(CreateEditContext);
    }

    private bool ValidateCreateForm()
    {
        CreateValidationMessageStore.Clear();
        var isValid = true;

        if (CreateModel.SupplierId <= 0)
        {
            CreateValidationMessageStore.Add(new FieldIdentifier(CreateModel, nameof(CreateModel.SupplierId)), "Supplier selection is required.");
            isValid = false;
        }

        if (CreateModel.LineItems.Count == 0)
        {
            CreateValidationMessageStore.Add(new FieldIdentifier(CreateModel, nameof(CreateModel.LineItems)), "At least one line item is required.");
            isValid = false;
        }

        foreach (var line in CreateModel.LineItems)
        {
            if (line.ProductId <= 0)
            {
                CreateValidationMessageStore.Add(new FieldIdentifier(line, nameof(line.ProductId)), "Product selection is required.");
                isValid = false;
            }

            if (line.OrderedQty <= 0)
            {
                CreateValidationMessageStore.Add(new FieldIdentifier(line, nameof(line.OrderedQty)), "Quantity must be greater than zero.");
                isValid = false;
            }

            if (line.UnitPrice <= 0)
            {
                CreateValidationMessageStore.Add(new FieldIdentifier(line, nameof(line.UnitPrice)), "Unit price must be greater than zero.");
                isValid = false;
            }
        }

        CreateEditContext.NotifyValidationStateChanged();
        return isValid;
    }

    private void ValidateField(FieldIdentifier field)
    {
        CreateValidationMessageStore.Clear(field);

        if (field.Model is PurchaseOrderFormModel model && field.FieldName == nameof(PurchaseOrderFormModel.SupplierId))
        {
            if (model.SupplierId <= 0)
            {
                CreateValidationMessageStore.Add(field, "Supplier selection is required.");
            }
        }

        if (field.Model is POLineItemFormModel item)
        {
            if (field.FieldName == nameof(POLineItemFormModel.ProductId) && item.ProductId <= 0)
            {
                CreateValidationMessageStore.Add(field, "Product selection is required.");
            }

            if (field.FieldName == nameof(POLineItemFormModel.OrderedQty) && item.OrderedQty <= 0)
            {
                CreateValidationMessageStore.Add(field, "Quantity must be greater than zero.");
            }

            if (field.FieldName == nameof(POLineItemFormModel.UnitPrice) && item.UnitPrice <= 0)
            {
                CreateValidationMessageStore.Add(field, "Unit price must be greater than zero.");
            }
        }

        CreateEditContext.NotifyValidationStateChanged();
    }

    private void OnStatusFilterBlur()
    {
        CurrentPage = 1;
    }

    private static bool CanMarkAsReceived(PurchaseOrderDto order)
        => order.Status != POStatus.Received && order.Status != POStatus.Cancelled;

    private static bool CanCancel(PurchaseOrderDto order)
        => order.Status != POStatus.Cancelled && order.Status != POStatus.Received;

    private static string GetStatusBadgeClass(POStatus status) => status switch
    {
        POStatus.Draft => "po-badge-draft",
        POStatus.Sent => "po-badge-sent",
        POStatus.Received => "po-badge-received",
        POStatus.Cancelled => "po-badge-cancelled",
        _ => "po-badge-draft"
    };

    private static string GetStatusLabel(POStatus status) => status switch
    {
        POStatus.Draft => "Draft",
        POStatus.Sent => "Sent",
        POStatus.Received => "Received",
        POStatus.Cancelled => "Cancelled",
        _ => "Unknown"
    };

    private sealed class PurchaseOrderFormModel
    {
        public int SupplierId { get; set; }
        public string Notes { get; set; } = string.Empty;
        public List<POLineItemFormModel> LineItems { get; set; } = new();
    }

    private sealed class POLineItemFormModel
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int OrderedQty { get; set; } = 1;
        public decimal UnitPrice { get; set; }

        public decimal LineTotal => OrderedQty * UnitPrice;
    }
}