@page "/admin/analytics"
@rendermode @(Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer)
@layout AdminLayout
@using SmartPOS.Shared.DTOs.Weather

@inject ISaleService SaleService
@inject IWeatherService WeatherService

<PageTitle>Analytics  -  SmartPOS+</PageTitle>

<div class="analytics-page">

    <!-- ── Page Header ─────────────────────────────────────────────── -->
    <header class="page-header">
        <div class="page-title">
            <h1>Sales Analytics</h1>
            <p>Real-time revenue intelligence and store performance metrics.</p>
        </div>
        <div class="header-actions">
            @if (lastRefreshed.HasValue)
            {
                <span class="last-refreshed">Updated @lastRefreshed.Value.ToLocalTime().ToString("hh:mm tt")</span>
            }
            <button class="btn btn-outline" @onclick="RefreshAsync" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Refreshing...</span>
                }
                else
                {
                    <span class="icon-refresh"></span>
                    <span>Refresh</span>
                }
            </button>
        </div>
    </header>

    <!-- ── Status Alert ────────────────────────────────────────────── -->
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @(isStatusSuccess ? "alert-success" : "alert-error")">
            <span>@statusMessage</span>
            <button class="btn btn-text" @onclick="ClearStatus">✕</button>
        </div>
    }

    <!-- ── Filter Bar ──────────────────────────────────────────────── -->
    <section class="filter-bar">
        <div class="filter-group">
            <span class="filter-label">Period Preset</span>
            <div class="period-pills">
                <button class="pill @(activePeriodPreset == "today"  ? "pill-active" : "")" @onclick='() => ApplyPreset("today")'>Today</button>
                <button class="pill @(activePeriodPreset == "7d"     ? "pill-active" : "")" @onclick='() => ApplyPreset("7d")'>Last 7 Days</button>
                <button class="pill @(activePeriodPreset == "30d"    ? "pill-active" : "")" @onclick='() => ApplyPreset("30d")'>Last 30 Days</button>
                <button class="pill @(activePeriodPreset == "mtd"    ? "pill-active" : "")" @onclick='() => ApplyPreset("mtd")'>Month to Date</button>
                <button class="pill @(activePeriodPreset == "custom" ? "pill-active" : "")" @onclick='() => ApplyPreset("custom")'>Custom Range</button>
            </div>
        </div>

        @if (activePeriodPreset == "custom")
        {
            <div class="filter-group">
                <span class="filter-label">From</span>
                <input id="analytics-date-from" type="date" class="filter-input"
                       value="@filter.From?.ToString("yyyy-MM-dd")"
                       @onchange="e => OnDateChange(e, true)" />
            </div>
            <div class="filter-group">
                <span class="filter-label">To</span>
                <input id="analytics-date-to" type="date" class="filter-input"
                       value="@filter.To?.ToString("yyyy-MM-dd")"
                       @onchange="e => OnDateChange(e, false)" />
            </div>
        }

        <div class="filter-group">
            <span class="filter-label">Granularity</span>
            <select id="analytics-granularity" class="filter-select"
                    value="@filter.Period"
                    @onchange="OnPeriodGranularityChange">
                <option value="daily">Daily</option>
                <option value="weekly">Weekly</option>
                <option value="monthly">Monthly</option>
            </select>
        </div>

        <div class="filter-group">
            <span class="filter-label">Sale Type</span>
            <select id="analytics-sale-type" class="filter-select"
                    value="@selectedSaleType"
                    @onchange="OnSaleTypeChange">
                <option value="">All Types</option>
                <option value="Onsite">Onsite</option>
                <option value="Online">Online</option>
            </select>
        </div>

        <div class="filter-actions">
            <button id="analytics-apply-btn" class="btn btn-primary" @onclick="RefreshAsync" disabled="@isLoading">
                Apply Filters
            </button>
            <button id="analytics-reset-btn" class="btn btn-outline" @onclick="ResetFilters" disabled="@isLoading">
                Reset
            </button>
        </div>
    </section>

    <!-- ── KPI Cards + Weather ──────────────────────────────────────── -->
    <section class="kpi-grid">

        <!-- Total Revenue -->
        <div class="kpi-card kpi-revenue">
            <div class="kpi-icon-wrap"></div>
            <div class="kpi-content">
                <span class="kpi-label">Total Revenue</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value">@(analytics?.TotalRevenue.ToString("N0") ?? "0")</span>
                    <span class="kpi-unit">Pakistani Rupee</span>
                }
            </div>
        </div>

        <!-- Total Transactions -->
        <div class="kpi-card kpi-transactions">
            <div class="kpi-icon-wrap">#</div>
            <div class="kpi-content">
                <span class="kpi-label">Total Transactions</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value">@(analytics?.TotalTransactions.ToString("N0") ?? "0")</span>
                    <span class="kpi-unit">Completed Sales</span>
                }
            </div>
        </div>

        <!-- Average Order Value -->
        <div class="kpi-card kpi-aov">
            <div class="kpi-icon-wrap">⌀</div>
            <div class="kpi-content">
                <span class="kpi-label">Avg. Order Value</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value">@(analytics?.AverageOrderValue.ToString("N0") ?? "0")</span>
                    <span class="kpi-unit">PKR per Sale</span>
                }
            </div>
        </div>

        <!-- Chart Intervals -->
        <div class="kpi-card kpi-intervals">
            <div class="kpi-icon-wrap"></div>
            <div class="kpi-content">
                <span class="kpi-label">Chart Intervals</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value">@(analytics?.ChartData?.Count ?? 0)</span>
                    <span class="kpi-unit">@filter.Period periods</span>
                }
            </div>
        </div>

        <!-- Weather Widget -->
        <div class="kpi-card kpi-weather">
            @if (isLoadingWeather)
            {
                <div class="weather-loading">
                    <span class="spinner"></span>
                    <span>Fetching weather</span>
                </div>
            }
            else if (weather != null)
            {
                <div class="weather-city-row">
                    <span class="weather-icon"></span>
                    <span class="weather-city">@weather.City</span>
                </div>
                <div class="weather-temp">@weather.Temperature.ToString("F1") degC</div>
                <div class="weather-condition">@weather.Condition</div>
                <div class="weather-fetched">Updated @weather.FetchedAt.ToLocalTime().ToString("hh:mm tt")</div>
            }
            else
            {
                <div class="weather-city-row">
                    <span class="weather-icon"></span>
                    <span class="weather-city">Local Store</span>
                </div>
                <div class="weather-unavailable">Weather service unavailable</div>
            }
        </div>

    </section>

    <!-- ── Revenue Trend Chart ──────────────────────────────────────── -->
    <section class="card chart-card">
        <div class="card-header">
            <div>
                <h2>Revenue Trend</h2>
                <p class="card-subtitle">
                    @filter.Period revenue from
                    @filter.From?.ToString("dd MMM yyyy") to @filter.To?.ToString("dd MMM yyyy")
                </p>
            </div>
            <div class="chart-legend">
                <span class="legend-dot legend-revenue"></span>
                <span>Revenue (PKR)</span>
                <span class="legend-sep">Â·</span>
                <span class="legend-dot legend-txns"></span>
                <span>Transactions</span>
            </div>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="loading-state">
                    <span class="spinner"></span>
                    <span>Building chart data</span>
                </div>
            }
            else if (analytics == null || !analytics.ChartData.Any())
            {
                <div class="empty-state">No revenue data available for the selected period and filters.</div>
            }
            else
            {
                <div class="chart-container">
                    @{
                        var pts       = analytics.ChartData;
                        decimal maxRev  = pts.Max(p => p.Revenue);
                        int     maxTxn  = pts.Max(p => p.Transactions);
                        if (maxRev == 0) maxRev = 1;
                        if (maxTxn == 0) maxTxn = 1;

                        const int  CH        = 180;  // chart height px
                        const int  SVG_W     = 800;
                        int        barCount  = pts.Count;
                        double     slot      = barCount > 0 ? (double)SVG_W / barCount : SVG_W;
                        double     bw        = Math.Max(slot * 0.55, 3);
                        double     gap       = (slot - bw) / 2.0;
                    }

                    <svg id="analytics-revenue-chart"
                         viewBox="0 0 @SVG_W @(CH + 50)"
                         class="revenue-svg"
                         preserveAspectRatio="none">

                        <!-- Y grid lines -->
                        @for (int yi = 0; yi <= 4; yi++)
                        {
                            double yy = CH - yi * CH / 4.0;
                            decimal lv = maxRev * yi / 4;
                            <line x1="0" y1="@yy.ToString("F0")" x2="@SVG_W" y2="@yy.ToString("F0")"
                                  stroke="rgba(61,28,2,0.07)" stroke-width="1" stroke-dasharray="4 3" />
                            @((MarkupString)$@"<text x=""4"" y=""{(yy - 4):F0}"" font-size=""8"" fill=""rgba(61,28,2,0.38)"" font-family=""system-ui"">{lv:N0}</text>")
                        }

                        <!-- Revenue Bars -->
                        @for (int i = 0; i < pts.Count; i++)
                        {
                            var pt   = pts[i];
                            double bh  = (double)pt.Revenue / (double)maxRev * CH;
                            double bx  = i * slot + gap;
                            double by  = CH - bh;

                            <rect x="@bx.ToString("F1")"
                                  y="@by.ToString("F1")"
                                  width="@bw.ToString("F1")"
                                  height="@bh.ToString("F1")"
                                  rx="3" ry="3"
                                  fill="var(--color-button-primary)"
                                  opacity="0.82"
                                  class="chart-bar">
                                <title>@pt.Label  -  PKR @pt.Revenue.ToString("N2") Â· @pt.Transactions txns</title>
                            </rect>

                            <!-- Transactions dot overlay -->
                            <circle cx="@((bx + bw / 2.0).ToString("F1"))" 
                                    cy="@((CH - ((double)pt.Transactions / (double)maxTxn * CH)).ToString("F1"))"
                                    r="3.5" fill="var(--color-navbar-bg)" opacity="0.7"
                                    class="chart-dot">
                                <title>@pt.Label  -  @pt.Transactions transactions</title>
                            </circle>

                            <!-- X-axis Labels (only when few points) -->
                            @if (barCount <= 16)
                            {
                                @((MarkupString)$@"<text x=""{(bx + bw / 2):F1}"" y=""{CH + 16}"" text-anchor=""middle"" font-size=""7.5"" fill=""var(--color-text-muted)"" font-family=""system-ui"">{System.Net.WebUtility.HtmlEncode(pt.Label)}</text>")
                            }
                        }

                        <!-- Trend line through dots -->
                        @if (pts.Count > 1)
                        {
                            string polyline = string.Join(" ", pts.Select((pt, i) =>
                            {
                                double doty = CH - ((double)pt.Transactions / (double)maxTxn * CH);
                                double dotx = i * slot + gap + bw / 2.0;
                                return $"{dotx.ToString("F1")},{doty.ToString("F1")}";
                            }));
                            <polyline points="@polyline"
                                      fill="none"
                                      stroke="var(--color-navbar-bg)"
                                      stroke-width="1.5"
                                      opacity="0.45"
                                      stroke-linejoin="round"
                                      stroke-linecap="round" />
                        }

                        <!-- X-axis baseline -->
                        <line x1="0" y1="@CH" x2="@SVG_W" y2="@CH"
                              stroke="rgba(61,28,2,0.18)" stroke-width="1.5" />
                    </svg>
                </div>
            }
        </div>
    </section>

    <!-- ── Bottom Row: Top Products + Period Breakdown ──────────────── -->
    <div class="bottom-grid">

        <!-- Top Products -->
        <section class="card">
            <div class="card-header">
                <div>
                    <h2>Top Products</h2>
                    <p class="card-subtitle">Ranked by units sold  -  top 10</p>
                </div>
                @if (!isLoadingSales && topProducts.Any())
                {
                    <span class="badge">@topProducts.Count products</span>
                }
            </div>
            <div class="card-body">
                @if (isLoadingSales)
                {
                    <div class="loading-state">
                        <span class="spinner"></span>
                        <span>Aggregating product sales</span>
                    </div>
                }
                else if (!topProducts.Any())
                {
                    <div class="empty-state">No product sales data for this period.</div>
                }
                else
                {
                    var totalProdRev = topProducts.Sum(p => p.TotalRevenue);
                    <table class="table" id="analytics-top-products-table">
                        <thead>
                            <tr>
                                <th class="rank-col">#</th>
                                <th>Product</th>
                                <th class="num-col">Units</th>
                                <th class="num-col">Revenue (PKR)</th>
                                <th class="share-col">Share</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < topProducts.Count; i++)
                            {
                                var p     = topProducts[i];
                                double pct = totalProdRev > 0
                                    ? (double)p.TotalRevenue / (double)totalProdRev * 100
                                    : 0;
                                <tr class="@(i % 2 == 1 ? "row-alt" : "")">
                                    <td><span class="rank-badge @(i < 3 ? "rank-top" : "")">@(i + 1)</span></td>
                                    <td class="product-name-cell">@p.ProductName</td>
                                    <td class="num-col">@p.TotalQuantity.ToString("N0")</td>
                                    <td class="num-col revenue-cell">@p.TotalRevenue.ToString("N2")</td>
                                    <td class="share-col">
                                        <div class="share-bar-wrap">
                                            <div class="share-bar" style="width:@(Math.Min(pct, 100).ToString("F1"))%"></div>
                                            <span class="share-pct">@pct.ToString("F1")%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>

        <!-- Period Breakdown -->
        <section class="card">
            <div class="card-header">
                <div>
                    <h2>Period Breakdown</h2>
                    <p class="card-subtitle">Revenue and transactions per @filter.Period interval</p>
                </div>
                @if (!isLoading && analytics?.ChartData != null)
                {
                    <span class="badge">@analytics.ChartData.Count intervals</span>
                }
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <div class="loading-state">
                        <span class="spinner"></span>
                        <span>Loading breakdown</span>
                    </div>
                }
                else if (analytics == null || !analytics.ChartData.Any())
                {
                    <div class="empty-state">No breakdown data available for this period.</div>
                }
                else
                {
                    <div class="table-scroll">
                        <table class="table" id="analytics-breakdown-table">
                            <thead>
                                <tr>
                                    <th>Interval</th>
                                    <th class="num-col">Revenue (PKR)</th>
                                    <th class="num-col">Transactions</th>
                                    <th class="num-col">Avg / Sale</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < analytics.ChartData.Count; i++)
                                {
                                    var pt     = analytics.ChartData[i];
                                    decimal avg = pt.Transactions > 0 ? pt.Revenue / pt.Transactions : 0;
                                    <tr class="@(i % 2 == 1 ? "row-alt" : "")">
                                        <td><span class="period-chip">@pt.Label</span></td>
                                        <td class="num-col revenue-cell">@pt.Revenue.ToString("N2")</td>
                                        <td class="num-col">@pt.Transactions</td>
                                        <td class="num-col">@avg.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-footer-row">
                                    <td><strong>Total</strong></td>
                                    <td class="num-col"><strong>@analytics.TotalRevenue.ToString("N2")</strong></td>
                                    <td class="num-col"><strong>@analytics.TotalTransactions</strong></td>
                                    <td class="num-col"><strong>@analytics.AverageOrderValue.ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </section>

    </div>

</div>

@code {

    // ── State ──────────────────────────────────────────────────────────
    private SaleAnalyticsDto?   analytics;
    private WeatherDto?         weather;
    private List<TopProductRow> topProducts = new();

    private SaleFilterDto filter = new()
    {
        Period = "daily",
        From   = DateTime.Today.AddDays(-7),
        To     = DateTime.Today
    };

    private string activePeriodPreset = "7d";
    private string selectedSaleType   = "";

    private bool isLoading;
    private bool isLoadingWeather;
    private bool isLoadingSales;

    private DateTime? lastRefreshed;
    private string?   statusMessage;
    private bool      isStatusSuccess;

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Fire all three data loads concurrently  -  never block on each other
        await Task.WhenAll(
            LoadAnalyticsAsync(),
            LoadWeatherAsync(),
            LoadTopProductsAsync()
        );
        lastRefreshed = DateTime.UtcNow;
    }

    // ── Data Loaders ───────────────────────────────────────────────────

    private async Task LoadAnalyticsAsync()
    {
        isLoading = true;
        var result = await SaleService.GetAnalytics(filter);
        if (result.Success && result.Data != null)
        {
            analytics = result.Data;
        }
        else
        {
            analytics = null;
            SetStatus(result.Message ?? "Failed to load analytics data.", false);
        }
        isLoading = false;
    }

    private async Task LoadWeatherAsync()
    {
        isLoadingWeather = true;
        var result = await WeatherService.GetCurrentWeather("Lahore");
        weather = (result.Success && result.Data != null) ? result.Data : null;
        isLoadingWeather = false;
    }

    private async Task LoadTopProductsAsync()
    {
        isLoadingSales = true;
        var result = await SaleService.GetAll(filter);
        if (result.Success && result.Data != null)
        {
            topProducts = result.Data
                .Where(s => s.Items != null && s.Items.Any())
                .SelectMany(s => s.Items)
                .GroupBy(item => item.ProductName)
                .Select(g => new TopProductRow
                {
                    ProductName   = g.Key,
                    TotalQuantity = g.Sum(i => i.Quantity),
                    TotalRevenue  = g.Sum(i => i.LineTotal)
                })
                .OrderByDescending(p => p.TotalQuantity)
                .Take(10)
                .ToList();
        }
        else
        {
            topProducts = new();
        }
        isLoadingSales = false;
    }

    // ── User Actions ───────────────────────────────────────────────────

    private async Task RefreshAsync()
    {
        ClearStatus();
        StateHasChanged();
        await Task.WhenAll(
            LoadAnalyticsAsync(),
            LoadWeatherAsync(),
            LoadTopProductsAsync()
        );
        lastRefreshed = DateTime.UtcNow;
    }

    private async Task ApplyPreset(string preset)
    {
        activePeriodPreset = preset;
        var today = DateTime.Today;

        switch (preset)
        {
            case "today":
                filter.From   = today;
                filter.To     = today;
                filter.Period = "daily";
                break;
            case "7d":
                filter.From   = today.AddDays(-7);
                filter.To     = today;
                filter.Period = "daily";
                break;
            case "30d":
                filter.From   = today.AddDays(-30);
                filter.To     = today;
                filter.Period = "daily";
                break;
            case "mtd":
                filter.From   = new DateTime(today.Year, today.Month, 1);
                filter.To     = today;
                filter.Period = "daily";
                break;
            case "custom":
                // Reveal date pickers; keep the current date range
                break;
        }

        if (preset != "custom")
            await RefreshAsync();
    }

    private void OnDateChange(ChangeEventArgs e, bool isFrom)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            if (isFrom) filter.From = dt;
            else        filter.To   = dt;
        }
    }

    private async Task OnPeriodGranularityChange(ChangeEventArgs e)
    {
        filter.Period = e.Value?.ToString() ?? "daily";
        await RefreshAsync();
    }

    private async Task OnSaleTypeChange(ChangeEventArgs e)
    {
        selectedSaleType = e.Value?.ToString() ?? "";
        filter.SaleType  = selectedSaleType switch
        {
            "Onsite" => SmartPOS.Shared.Enums.SaleType.Onsite,
            "Online" => SmartPOS.Shared.Enums.SaleType.Online,
            _        => (SmartPOS.Shared.Enums.SaleType?)null
        };
        await RefreshAsync();
    }

    private async Task ResetFilters()
    {
        filter = new SaleFilterDto
        {
            Period = "daily",
            From   = DateTime.Today.AddDays(-7),
            To     = DateTime.Today
        };
        activePeriodPreset = "7d";
        selectedSaleType   = "";
        ClearStatus();
        await RefreshAsync();
    }

    private void SetStatus(string msg, bool success)
    {
        statusMessage   = msg;
        isStatusSuccess = success;
    }

    private void ClearStatus() => statusMessage = null;

    // ── Inner record ──────────────────────────────────────────────────
    private sealed class TopProductRow
    {
        public string  ProductName   { get; set; } = string.Empty;
        public int     TotalQuantity { get; set; }
        public decimal TotalRevenue  { get; set; }
    }
}

<style>

    /* â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*
       Analytics Page  -  SmartPOS+ Bakery Theme
       All colors reference tokens from wwwroot/css/colors.css
       â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â* */

    /* ── Page Shell ──────────────────────────────────────────── */
    .analytics-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 1.75rem;
        background-color: var(--color-page-bg);
        color: var(--color-primary-text);
        min-height: 100vh;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    /* ── Page Header ─────────────────────────────────────────── */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title h1 {
        margin: 0;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--color-heading-text);
        letter-spacing: -0.025em;
    }

    .page-title p {
        margin: 0.3rem 0 0;
        font-size: 0.9rem;
        color: var(--color-primary-text);
        opacity: 0.6;
    }

    .header-actions {
