@page "/manager/purchase-orders"
@layout ManagerLayout
@rendermode InteractiveServer
@using SmartPOS.Shared.DTOs.PurchaseOrders
@inject IPurchaseOrderService PurchaseOrderService
@inject ISupplierService SupplierService
@inject IProductService ProductService

<PageTitle>Purchase Orders</PageTitle>

<div class="sp-page p-4">

    @* Page header *@
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="sp-heading h3 mb-1">Purchase Orders</h1>
            <p class="sp-text-muted mb-0">Create, track, and manage supplier purchase orders.</p>
        </div>
        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center gap-2 w-100 w-xl-auto">
            <div class="input-group">
                <span class="input-group-text sp-input-addon po-search-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/></svg>
                </span>
                <InputText class="form-control sp-input" @bind-Value="SearchText" @bind-Value:event="oninput" placeholder="Search by PO # or supplier..." />
            </div>
            <select class="form-select sp-input" value="@StatusFilter"
                    @onchange="@(e => { StatusFilter = e.Value?.ToString() ?? string.Empty; OnStatusFilterBlur(); })">
                <option value="">All Statuses</option>
                @foreach (var status in StatusOptions)
                {
                    <option value="@status" selected="@(StatusFilter == status)">@status</option>
                }
            </select>
            <button class="btn sp-btn-primary po-create-btn" type="button" @onclick="OpenCreateModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/></svg>
                New Purchase Order
            </button>
        </div>
    </div>

    @* Stat summary cards *@
    @if (!IsLoading)
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="po-stat-card">
                    <div class="po-stat-label">Total Orders</div>
                    <div class="po-stat-value">@AllPurchaseOrders.Count</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="po-stat-card po-stat-draft">
                    <div class="po-stat-label">Draft</div>
                    <div class="po-stat-value">@AllPurchaseOrders.Count(o => o.Status == POStatus.Draft)</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="po-stat-card po-stat-received">
                    <div class="po-stat-label">Received</div>
                    <div class="po-stat-value">@AllPurchaseOrders.Count(o => o.Status == POStatus.Received)</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="po-stat-card po-stat-cancelled">
                    <div class="po-stat-label">Cancelled</div>
                    <div class="po-stat-value">@AllPurchaseOrders.Count(o => o.Status == POStatus.Cancelled)</div>
                </div>
            </div>
        </div>
    }

    @* Alerts *@
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="po-alert po-alert-error mb-4" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
            <div><strong>Action failed.</strong> @ErrorMessage</div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="po-alert po-alert-success mb-4" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
            <div><strong>Success.</strong> @SuccessMessage</div>
        </div>
    }

    @* Orders table card *@
    <section class="sp-card">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 sp-border-bottom">
            <div>
                <h2 class="sp-heading h5 mb-1">Purchase Order Summary</h2>
                <p class="sp-text-muted small mb-0">Review recent purchase orders and status updates.</p>
            </div>
            <span class="badge sp-badge-accent po-count-badge">@FilteredOrders.Count order(s)</span>
        </div>

        <div class="table-responsive">
            <table class="table sp-table mb-0">
                <thead class="sp-table-head">
                    <tr>
                        <th scope="col" class="po-col-id">PO #</th>
                        <th scope="col">Supplier</th>
                        <th scope="col">Status</th>
                        <th scope="col">Total Cost</th>
                        <th scope="col">Order Date</th>
                        <th scope="col" class="text-center">Items</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="7" class="p-5 text-center">
                                <div class="d-flex flex-column align-items-center gap-3">
                                    <div class="spinner-border sp-spinner" role="status" style="width:2rem;height:2rem;"></div>
                                    <span class="sp-text-muted">Loading purchase orders…</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (PagedOrders.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="p-5 text-center">
                                <p class="mb-0 sp-text-muted">No purchase orders match the current filters.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var order in PagedOrders)
                        {
                            <tr class="po-table-row">
                                <td><span class="po-id-pill">#@order.Id</span></td>
                                <td><span class="po-supplier-name">@order.SupplierName</span></td>
                                <td><span class="badge @GetStatusBadgeClass(order.Status)">@GetStatusLabel(order.Status)</span></td>
                                <td><span class="po-currency">@order.TotalCost.ToString("N2")</span></td>
                                <td><span class="po-date">@order.OrderDate.ToLocalTime().ToString("dd MMM yyyy")</span></td>
                                <td class="text-center"><span class="po-item-count">@order.LineItems.Count</span></td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-1">
                                        <button class="btn po-action-btn po-action-view" type="button" @onclick="() => OpenDetailsModal(order)">View</button>
                                        <button class="btn po-action-btn po-action-receive" type="button" @onclick="() => MarkAsReceived(order)" disabled="@(!CanMarkAsReceived(order) || IsActionBusy)">Received</button>
                                        <button class="btn po-action-btn po-action-cancel" type="button" @onclick="() => OpenCancelModal(order)" disabled="@(!CanCancel(order) || IsActionBusy)">Cancel</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Pagination *@
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 sp-border-top">
            <p class="mb-0 sp-text-muted small">Showing <strong>@PagedOrders.Count</strong> of <strong>@FilteredOrders.Count</strong> entries</p>
            <div class="btn-group" role="group" aria-label="Purchase order pagination">
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="PreviousPage" disabled="@IsFirstPage">&lsaquo;</button>
                @foreach (var page in PageNumbers)
                {
                    <button class="btn @(page == CurrentPage ? "sp-btn-primary" : "sp-btn-outline") btn-sm po-page-btn" type="button" @onclick="() => GoToPage(page)">@(page)</button>
                }
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="NextPage" disabled="@IsLastPage">&rsaquo;</button>
            </div>
        </div>
    </section>
</div>

@if (IsCreateModalOpen)
{
    <div class="po-modal-backdrop">
        <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header">
                    <div>
                        <h2 class="h5 sp-heading mb-1">Create Purchase Order</h2>
                        <p class="sp-text-muted small mb-0">Select a supplier and add the required products.</p>
                    </div>
                    <button class="po-close-btn" type="button" @onclick="CloseCreateModal" aria-label="Close">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/></svg>
                    </button>
                </div>
                <div class="modal-body p-4">
                    <EditForm EditContext="CreateEditContext" OnSubmit="HandleCreateSubmit" FormName="CreatePurchaseOrderForm">
                        <ValidationSummary class="sp-validation-summary" />
                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                <label class="form-label sp-label">Supplier <span class="po-required">*</span></label>
                                <InputSelect class="form-select sp-input" @bind-Value="CreateModel.SupplierId" @bind-Value:event="onblur">
                                    <option value="0">Select supplier…</option>
                                    @foreach (var supplier in ActiveSuppliers)
                                    {
                                        <option value="@supplier.Id">@supplier.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => CreateModel.SupplierId)" class="sp-validation-message" />
                            </div>
                            <div class="col-12 col-lg-6">
                                <label class="form-label sp-label">Notes</label>
                                <InputTextArea class="form-control sp-input" @bind-Value="CreateModel.Notes" @bind-Value:event="onblur" rows="2" placeholder="Optional order notes…" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 mb-2">
                            <h3 class="sp-heading h6 mb-0">Line Items</h3>
                            <button class="btn po-add-item-btn" type="button" @onclick="AddLineItem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/></svg>
                                Add Line Item
                            </button>
                        </div>

                        <div class="table-responsive">
                            <table class="table sp-table mb-0">
                                <thead class="sp-table-head">
                                    <tr>
                                        <th scope="col">Product <span class="po-required">*</span></th>
                                        <th scope="col" style="width:120px">Qty <span class="po-required">*</span></th>
                                        <th scope="col" style="width:140px">Unit Price <span class="po-required">*</span></th>
                                        <th scope="col" style="width:120px">Line Total</th>
                                        <th scope="col" style="width:60px" class="text-end">Del</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (CreateModel.LineItems.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5" class="p-4 text-center">
                                                <p class="mb-0 sp-text-muted small">No line items yet — click <strong>Add Line Item</strong> to begin.</p>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var line in CreateModel.LineItems)
                                        {
                                            <tr>
                                                <td class="align-top">
                                                    <InputSelect class="form-select sp-input sp-input-sm" @bind-Value="line.ProductId" @bind-Value:event="onblur" @onchange="(args) => OnProductChanged(line, args)">
                                                        <option value="0">Select product…</option>
                                                        @foreach (var product in ActiveProducts)
                                                        {
                                                            <option value="@product.Id">@product.Name</option>
                                                        }
                                                    </InputSelect>
                                                    <ValidationMessage For="@(() => line.ProductId)" class="sp-validation-message" />
                                                </td>
                                                <td class="align-top">
                                                    <InputNumber class="form-control sp-input sp-input-sm" @bind-Value="line.OrderedQty" @bind-Value:event="onblur" />
                                                    <ValidationMessage For="@(() => line.OrderedQty)" class="sp-validation-message" />
                                                </td>
                                                <td class="align-top">
                                                    <InputNumber class="form-control sp-input sp-input-sm" @bind-Value="line.UnitPrice" @bind-Value:event="onblur" />
                                                    <ValidationMessage For="@(() => line.UnitPrice)" class="sp-validation-message" />
                                                </td>
                                                <td class="align-top">
                                                    <div class="po-line-total">@line.LineTotal.ToString("N2")</div>
                                                </td>
                                                <td class="align-top text-end">
                                                    <button class="btn po-remove-btn" type="button" @onclick="() => RemoveLineItem(line)" title="Remove">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="po-total-row mt-3">
                            <div class="sp-text-muted small">Estimated Total</div>
                            <div class="po-total-value">@CreateTotalCost.ToString("N2")</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 po-modal-footer-border">
                            <button class="btn sp-btn-outline" type="button" @onclick="CloseCreateModal">Discard</button>
                            <button class="btn sp-btn-primary" type="submit" disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span><span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Purchase Order</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (IsDetailsModalOpen && SelectedOrder is not null)
{
    <div class="po-modal-backdrop">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header">
                    <div>
                        <h2 class="h5 sp-heading mb-1">Purchase Order #@SelectedOrder.Id</h2>
                        <p class="sp-text-muted small mb-0">Review the order information and line items.</p>
                    </div>
                    <button class="po-close-btn" type="button" @onclick="CloseDetailsModal" aria-label="Close">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/></svg>
                    </button>
                </div>
                <div class="po-details-stripe">
                    <div class="po-details-stripe-item">
                        <div class="po-detail-label">Supplier</div>
                        <div class="po-detail-value">@SelectedOrder.SupplierName</div>
                    </div>
                    <div class="po-details-stripe-item">
                        <div class="po-detail-label">Status</div>
                        <span class="badge @GetStatusBadgeClass(SelectedOrder.Status)">@GetStatusLabel(SelectedOrder.Status)</span>
                    </div>
                    <div class="po-details-stripe-item">
                        <div class="po-detail-label">Order Date</div>
                        <div class="po-detail-value">@SelectedOrder.OrderDate.ToLocalTime().ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="po-details-stripe-item">
                        <div class="po-detail-label">Received Date</div>
                        <div class="po-detail-value">@(SelectedOrder.ReceivedAt.HasValue ? SelectedOrder.ReceivedAt.Value.ToLocalTime().ToString("dd MMM yyyy") : "—")</div>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(SelectedOrder.Notes))
                {
                    <div class="po-notes-block">
                        <div class="po-detail-label mb-1">Notes</div>
                        <div class="po-notes-text">@SelectedOrder.Notes</div>
                    </div>
                }
                <div class="modal-body p-0">
                    <div class="table-responsive">
                        <table class="table sp-table mb-0">
                            <thead class="sp-table-head">
                                <tr>
                                    <th scope="col">Product</th>
                                    <th scope="col" class="text-center">Qty</th>
                                    <th scope="col" class="text-end">Unit Price</th>
                                    <th scope="col" class="text-end">Line Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in SelectedOrder.LineItems)
                                {
                                    <tr>
                                        <td>@line.ProductName</td>
                                        <td class="text-center">@line.OrderedQty</td>
                                        <td class="text-end">@line.UnitPrice.ToString("N2")</td>
                                        <td class="text-end"><strong>@line.LineTotal.ToString("N2")</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="po-total-row p-3 po-modal-footer-border">
                        <div class="sp-text-muted small">Order Total</div>
                        <div class="po-total-value">@SelectedOrder.TotalCost.ToString("N2")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (IsCancelModalOpen && PendingCancelOrder is not null)
{
    <div class="po-modal-backdrop">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header po-modal-header-danger">
                    <div>
                        <h2 class="h5 sp-heading mb-1">Cancel Purchase Order</h2>
                        <p class="sp-text-muted small mb-0">This action cannot be undone.</p>
                    </div>
                    <button class="po-close-btn" type="button" @onclick="CloseCancelModal" aria-label="Close">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/></svg>
                    </button>
                </div>
                <div class="modal-body p-4">
                    <div class="po-cancel-info">
                        <p class="mb-0">You are about to cancel <strong>Purchase Order #@PendingCancelOrder.Id</strong> from <strong>@PendingCancelOrder.SupplierName</strong>. Once cancelled, this order cannot be reversed.</p>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button class="btn sp-btn-outline" type="button" @onclick="CloseCancelModal">Keep Order</button>
                        <button class="btn po-btn-danger" type="button" @onclick="ConfirmCancel" disabled="@IsActionBusy">
                            @if (IsActionBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span><span>Cancelling…</span>
                            }
                            else
                            {
                                <span>Confirm Cancellation</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ── Modal backdrop ──────────────────────────────────── */
    .po-modal-backdrop {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background-color: color-mix(in srgb, var(--color-navbar-bg) 35%, transparent);
        backdrop-filter: blur(6px);
        z-index: 1050;
        animation: po-fade-in 0.15s ease;
    }

    .po-modal-backdrop .modal-dialog {
        animation: po-slide-up 0.2s ease;
        width: 100%;
    }

    .po-modal-backdrop .modal-content {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 60px color-mix(in srgb, var(--color-navbar-bg) 25%, transparent);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
    }

    .po-modal-backdrop .modal-body {
        overflow-y: auto;
    }

    /* ── Modal header ──────────────────────────────────── */
    .sp-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        padding: 20px 24px;
        border-bottom: 1px solid color-mix(in srgb, var(--color-border-accent) 20%, transparent);
        background-color: color-mix(in srgb, var(--color-card-bg) 50%, var(--color-page-bg));
        flex-shrink: 0;
    }

    .po-modal-header-danger {
        background-color: color-mix(in srgb, var(--color-border-accent) 8%, var(--color-card-bg));
        border-bottom-color: color-mix(in srgb, var(--color-border-accent) 30%, transparent);
    }

    /* ── Close button ──────────────────────────────────── */
    .po-close-btn {
        background: transparent;
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 30%, transparent);
        border-radius: 6px;
        padding: 5px 8px;
        color: var(--color-primary-text);
        cursor: pointer;
        flex-shrink: 0;
        transition: background-color 0.15s ease, border-color 0.15s ease;
        line-height: 1;
    }

    .po-close-btn:hover {
        background-color: color-mix(in srgb, var(--color-border-accent) 15%, transparent);
        border-color: var(--color-border-accent);
    }

    /* ── Details stripe ──────────────────────────────── */
    .po-details-stripe {
