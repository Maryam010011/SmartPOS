    /* ── Total row ───────────────────────────────────── */
    .po-total-row {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 16px;
    }

    .po-total-value {
        font-size: 1.2rem;
        font-weight: 700;
