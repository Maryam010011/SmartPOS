@namespace SmartPOS.Components.Layout
@inherits LayoutComponentBase

<div class="admin-layout-shell">

    <AdminNavbar OnAvatarClick="OpenDrawer" />

    <ProfileDrawer IsOpen="@_drawerOpen"
                   OnClose="CloseDrawer"
                   DisplayName="Admin User"
                   RoleName="Administrator"
                   RoleColor="var(--role-admin-accent, #C4848A)"
                    DashboardRoute="/admin/analytics"
                    SettingsRoute=""
                    NavItems="@(new List<ProfileDrawer.DrawerNavItem>
                    {
                        new() { Label = "Products",    Url = "/admin/products" },
                        new() { Label = "Categories",  Url = "/admin/categories" },
                        new() { Label = "Suppliers",   Url = "/admin/suppliers" },
                        new() { Label = "Users",       Url = "/admin/users" },
                        new() { Label = "Roles",       Url = "/admin/roles" },
                        new() { Label = "Customers",   Url = "/admin/customers" },
                        new() { Label = "Audit Logs",  Url = "/admin/audit-logs" },
                        new() { Label = "Sentiment",   Url = "/admin/sentiment" },
                    })" />

    <main class="admin-main" id="admin-content">
        <div class="admin-content-wrap">
            @Body
        </div>
    </main>

    <Footer />

</div>

@code {
    private bool _drawerOpen = false;

    private void OpenDrawer()  { _drawerOpen = true; StateHasChanged(); }
    private void CloseDrawer() => _drawerOpen = false;
}

<style>
    .admin-layout-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: var(--surface-0, #FFF8DC);
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
    }

    .admin-main {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .admin-content-wrap {
        flex: 1;
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0;
    }
</style>
