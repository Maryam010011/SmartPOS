@page "/cashier/sales-history"
@layout CashierLayout
@attribute [Authorize(Roles = "Admin,Manager,Cashier")]
@rendermode InteractiveServer
@using SmartPOS.Shared.DTOs.Sales
@using SmartPOS.Shared.Interfaces
@inject ISaleService SaleService

<div class="container py-4">
    <h2 class="mb-3">Sales History</h2>
    <p class="text-muted">View past sales transactions.</p>

    @if (IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (Sales == null || !Sales.Any())
    {
        <div class="alert alert-info">No sales transactions found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Sale ID</th>
                        <th>Receipt #</th>
                        <th>Date & Time</th>
                        <th>Items</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-end">Discount</th>
                        <th class="text-end">Total Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sale in Sales)
                    {
                        <tr>
                            <td><strong>#@sale.SaleId</strong></td>
                            <td><span class="text-muted small">@sale.ReceiptNumber</span></td>
                            <td>@sale.SaleDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                            <td>@sale.Items.Count</td>
                            <td class="text-end">Rs @sale.SubTotal.ToString("N2")</td>
                            <td class="text-end">Rs @sale.DiscountAmount.ToString("N2")</td>
                            <td class="text-end"><strong>Rs @sale.TotalAmount.ToString("N2")</strong></td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(sale.Status)">@sale.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="text-muted small">Page @CurrentPage</span>
            <nav>
                <ul class="pagination pagination-sm">
                    <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="PreviousPage">Previous</button>
                    </li>
                    <li class="page-item active">
                        <span class="page-link">@CurrentPage</span>
                    </li>
                    <li class="page-item @(Sales.Count < PageSize ? "disabled" : "")">
                        <button class="page-link" @onclick="NextPage">Next</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@code {
    private List<SaleResultDto>? Sales;
    private bool IsLoading = true;
    private int CurrentPage = 1;
    private const int PageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadSales();
    }

    private async Task LoadSales()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var filter = new SaleFilterDto
            {
                Page = CurrentPage,
                PageSize = PageSize
            };

            var response = await SaleService.GetAll(filter);
            if (response.Success && response.Data != null)
            {
                Sales = response.Data;
            }
            else
            {
                Sales = new List<SaleResultDto>();
            }
        }
        catch
        {
            Sales = new List<SaleResultDto>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            await LoadSales();
        }
    }

    private async Task NextPage()
    {
        if (Sales != null && Sales.Count == PageSize)
        {
            CurrentPage++;
            await LoadSales();
        }
    }

    private static string GetStatusBadgeClass(SmartPOS.Shared.Enums.SaleStatus status)
    {
        return status switch
        {
            SmartPOS.Shared.Enums.SaleStatus.Completed => "bg-success",
            SmartPOS.Shared.Enums.SaleStatus.Voided => "bg-warning",
            SmartPOS.Shared.Enums.SaleStatus.Refunded => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
