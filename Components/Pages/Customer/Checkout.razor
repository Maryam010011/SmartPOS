@* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   @CODE SECTION
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
@code {

    // â”€â”€ Contact fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private string _fullName   = string.Empty;
    private string _email      = string.Empty;
    private string _phone      = string.Empty;

    // â”€â”€ Shipping fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private string _address      = string.Empty;
    private string _city         = string.Empty;
    private string _province     = string.Empty;
    private string _postalCode   = string.Empty;
    private string _deliveryNotes = string.Empty;

    // â”€â”€ Promo fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private string  _promoCode     = string.Empty;
    private bool    _promoApplied  = false;
    private decimal _promoDiscount = 0m;
    private string? _promoError    = null;
    private bool    _isApplyingPromo = false;

    // â”€â”€ Payment â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private PaymentMethod? _paymentMethod = null;

    // â”€â”€ Stripe card fields (UI shell â€” wired but gateway is a TODO stub) â”€â”€
    private string _cardName   = string.Empty;
    private string _cardNumber = string.Empty;
    private string _cardExpiry = string.Empty;
    private string _cardCvc    = string.Empty;

    // â”€â”€ State â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private bool            _isPlacingOrder = false;
    private bool            _orderPlaced    = false;
    private SaleResultDto?  _saleResult     = null;
    private string?         _globalError    = null;

    // â”€â”€ Validation dictionary (field key â†’ message) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private readonly Dictionary<string, string> _fieldErrors = new();

    // â”€â”€ Computed properties â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    /// <summary>
    /// Tax preview at 17% on the discounted sub-total.
    /// The SaleService.ProcessSale applies the same rate server-side.
    /// </summary>
    private decimal EstimatedTax =>
        Math.Round((CartState.SubTotal - _promoDiscount) * 0.17m, 0);

    /// <summary>Grand total displayed in the order summary and CTA button.</summary>
    private decimal GrandTotal =>
        CartState.SubTotal - _promoDiscount + EstimatedTax;

    // â”€â”€ Lifecycle â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    protected override void OnInitialized()
    {
        CartState.OnCartChanged += OnCartChanged;
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CartState.OnCartChanged -= OnCartChanged;
    }

    // â”€â”€ Navigation helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private void GoToCart() => Navigation.NavigateTo("/customer/cart");
    private void GoToShop() => Navigation.NavigateTo("/customer/shop");

    // â”€â”€ Validation helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private bool   HasError(string key) => _fieldErrors.ContainsKey(key);
    private string GetError(string key) => _fieldErrors.TryGetValue(key, out var msg) ? msg : string.Empty;
    private void   ClearFieldError(string key) => _fieldErrors.Remove(key);

    private bool ValidateForm()
    {
        _fieldErrors.Clear();

        if (string.IsNullOrWhiteSpace(_fullName))
            _fieldErrors["FullName"] = "Full name is required.";

        if (string.IsNullOrWhiteSpace(_email) ||
            !System.Text.RegularExpressions.Regex.IsMatch(_email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            _fieldErrors["Email"] = "A valid email address is required.";

        if (string.IsNullOrWhiteSpace(_phone))
            _fieldErrors["Phone"] = "Phone number is required.";

        if (string.IsNullOrWhiteSpace(_address))
            _fieldErrors["Address"] = "Street address is required.";

        if (string.IsNullOrWhiteSpace(_city))
            _fieldErrors["City"] = "City is required.";

        if (string.IsNullOrWhiteSpace(_postalCode))
            _fieldErrors["PostalCode"] = "Postal code is required.";

        if (!_paymentMethod.HasValue)
            _fieldErrors["Payment"] = "Please select a payment method.";

        return _fieldErrors.Count == 0;
    }

    // â”€â”€ Promo code â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private async Task ApplyPromo()
    {
        _promoError = null;
        if (string.IsNullOrWhiteSpace(_promoCode)) return;

        _isApplyingPromo = true;
        StateHasChanged();

        // TODO: Replace with real IPromotionService.ValidateAndApply call
        // once MaryamJ's promo module is merged.
        await Task.Delay(600); // simulated network call
        _promoError = "Promo code feature is coming soon. Please check back later.";
        _isApplyingPromo = false;
    }

    private void RemovePromo()
    {
        _promoApplied  = false;
        _promoDiscount = 0m;
        _promoCode     = string.Empty;
        _promoError    = null;
    }

    // â”€â”€ Stripe gateway stub â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    /// <summary>
    /// Stripe payment gateway placeholder.
    /// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    /// TODO (MaryamJ): Wire the actual Stripe gateway call here once your
    /// payment-intent / tokenisation feature branch is merged into main.
    /// Expected flow:
    ///   1. Call Stripe.js via JSInterop to tokenise card fields.
    ///   2. Send the payment-intent ID to the backend endpoint.
    ///   3. Await confirmation before calling SaleService.ProcessSale.
    /// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    /// </summary>
    private async Task<bool> PlaceOrderWithStripe()
    {
        // Placeholder â€” always returns true in the stub.
        // Replace this body with the real Stripe JS interop flow.
        await Task.CompletedTask;
        return true;
    }

    // â”€â”€ Main order submission â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    /// <summary>
    /// Validates the form, optionally processes Stripe payment (stub),
    /// then calls SaleService.ProcessSale with SaleType explicitly set to Online.
    /// </summary>
    private async Task PlaceOrder()
    {
        _globalError = null;

        // â”€â”€ 1. Client-side validation â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        if (!ValidateForm())
        {
            StateHasChanged();
            return;
        }

        // â”€â”€ 2. Guard against empty cart â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        if (CartState.Count == 0)
        {
            _globalError = "Your cart is empty. Please add items before placing an order.";
            return;
        }

        _isPlacingOrder = true;
        StateHasChanged();

        try
        {
            // â”€â”€ 3. Stripe gateway (stub â€” see PlaceOrderWithStripe summary) â”€â”€
            if (_paymentMethod == PaymentMethod.Card)
            {
                var stripeSuccess = await PlaceOrderWithStripe();
                if (!stripeSuccess)
                {
                    _globalError = "Card payment could not be processed. Please try again or use another method.";
                    return;
                }
            }

            // â”€â”€ 4. Build CreateSaleDto â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            //       SaleType is explicitly set to Online â€” this is a customer
            //       web checkout, never an Onsite / cashier transaction.
            var dto = new CreateSaleDto
            {
                CustomerId    = null,          // Guest checkout; set after auth module integration
                UserId        = 0,             // System user ID placeholder for online orders
                PromoCode     = _promoApplied && !string.IsNullOrWhiteSpace(_promoCode)
                                    ? _promoCode.Trim()
                                    : null,
                SaleType      = SaleType.Online,    // â† Explicitly Online for every web checkout
                PaymentMethod = _paymentMethod!.Value,
                Items         = CartState.Items.Select(i => new SaleItemDto
                {
                    ProductId   = i.Product.Id,
                    ProductName = i.Product.Name,
                    Quantity    = i.Quantity,
                    UnitPrice   = i.Product.Price,
                    LineTotal   = i.Product.Price * i.Quantity
                }).ToList()
            };

            // â”€â”€ 5. Call SaleService.ProcessSale â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            var response = await SaleService.ProcessSale(dto);

            if (!response.Success || response.Data is null)
            {
                _globalError = response.Message.Length > 0
                    ? response.Message
                    : "Order could not be placed. Please try again.";
                return;
            }

            // â”€â”€ 6. Success: store result, clear cart, show receipt â”€â”€â”€â”€â”€â”€â”€â”€
            _saleResult  = response.Data;
            _orderPlaced = true;
            CartState.Clear();
        }
        catch (Exception ex)
        {
            _globalError = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isPlacingOrder = false;
            StateHasChanged();
        }
    }

    // â”€â”€ UI helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private static string PaymentIcon(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash   => "ðŸ’µ",
        PaymentMethod.Card   => "ðŸ’³",
        PaymentMethod.Online => "ðŸ“±",
        _                    => "ðŸ’³"
    };

    private static string PaymentLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash   => "Cash on Delivery",
        PaymentMethod.Card   => "Credit / Debit Card",
        PaymentMethod.Online => "Mobile Wallet",
        _                    => "Card"
    };
}


