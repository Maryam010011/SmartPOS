@page "/admin/audit-logs"
@layout AdminLayout
@using SmartPOS.Shared.DTOs.AuditLogs
@using SmartPOS.Shared.Interfaces
@using System.Text.Json
@inject IAuditLogService AuditLogService
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Audit Logs</h2>
            <p class="text-muted m-0">Read-only trail of all system activities and data changes.</p>
        </div>
        <button class="btn btn-outline-secondary d-flex align-items-center gap-2" @onclick="ExportCsv">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download" viewBox="0 0 16 16">
                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
            </svg>
            <span>Export CSV</span>
        </button>
    </div>

    <div class="card card-pos mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-secondary small fw-semibold">Date From</label>
                    <input type="date" class="form-control" @bind="DateFrom" @bind:after="OnDateFilterChanged" />
                </div>
                <div class="col-md-3">
                    <label class="form-label text-secondary small fw-semibold">Date To</label>
                    <input type="date" class="form-control" @bind="DateTo" @bind:after="OnDateFilterChanged" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Module</label>
                    <select class="form-select" @bind="SelectedModule" @bind:after="ReloadLogs">
                        <option value="">All Modules</option>
                        <option value="UserManagement">UserManagement</option>
                        <option value="RoleManagement">RoleManagement</option>
                        <option value="Inventory">Inventory</option>
                        <option value="POS">POS</option>
                        <option value="Reports">Reports</option>
                        <option value="Promotions">Promotions</option>
                        <option value="Customers">Customers</option>
                        <option value="PurchaseOrders">PurchaseOrders</option>
                        <option value="AuditLogs">AuditLogs</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Action</label>
                    <select class="form-select" @bind="SelectedAction" @bind:after="ReloadLogs">
                        <option value="">All Actions</option>
                        <option value="Created">Created</option>
                        <option value="Updated">Updated</option>
                        <option value="Deleted">Deleted</option>
                        <option value="Login">Login</option>
                        <option value="Logout">Logout</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search text-muted" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 ps-0" placeholder="Search user..." 
                               @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                    </div>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12 d-flex justify-content-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ResetFilters">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--color-button-primary);" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2">Loading audit logs...</p>
        </div>
    }
    else if (Logs == null || !Logs.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3" style="font-size: 3rem;">ðŸ“‹</div>
            <h5 class="text-muted">No audit logs found</h5>
            <p class="text-muted small">Try adjusting your filters or check back later.</p>
        </div>
    }
    else
    {
        <div class="card card-pos">
            <div class="table-responsive">
                <table class="table table-pos align-middle m-0">
                    <thead class="table-light">
                        <tr>
                            <th style="padding-left: 20px; width: 160px;">Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Module</th>
                            <th>Entity ID</th>
                            <th style="padding-right: 20px;">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Logs)
                        {
                            <tr>
                                <td style="padding-left: 20px;">
                                    <span class="small text-muted">@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center bg-secondary-subtle" 
                                             style="width: 28px; height: 28px; font-size: 0.7rem; font-weight: 600; color: #6c757d;">
                                            @log.UserName[..1].ToUpper()
                                        </div>
                                        <div>
                                            <span class="fw-semibold text-dark small">@log.UserName</span>
                                            <div class="text-muted" style="font-size: 0.7rem;">@log.UserEmail</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge @(GetActionBadgeClass(log.Action)) px-2 py-1 rounded-pill">@log.Action</span>
                                </td>
                                <td>
                                    <span class="badge @(GetModuleBadgeClass(log.Module)) px-2 py-1 rounded-pill">@log.Module</span>
                                </td>
                                <td>
                                    @if (log.EntityId.HasValue)
                                    {
                                        <span class="text-muted small">#@log.EntityId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">â€”</span>
                                    }
                                </td>
                                <td style="padding-right: 20px;">
                                    @if (!string.IsNullOrEmpty(log.OldValues) || !string.IsNullOrEmpty(log.NewValues))
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleDetail(log.Id)">
                                            @(ExpandedLogId == log.Id ? "Hide" : "View") Diff
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">â€”</span>
                                    }
                                </td>
                            </tr>
                            @if (ExpandedLogId == log.Id)
                            {
                                <tr class="table-light">
                                    <td colspan="6" style="padding: 12px 20px;">
                                        <div class="row g-2">
                                            <div class="col-md-6">
                                                <div class="fw-semibold small text-danger mb-1">Old Values</div>
                                                <pre style="max-height: 200px; overflow: auto; font-size: 0.75rem; background: #fff5f5; border: 1px solid #ffcccc; border-radius: 4px; padding: 8px; margin: 0; white-space: pre-wrap; word-break: break-all;">@FormatJson(log.OldValues)</pre>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="fw-semibold small text-success mb-1">New Values</div>
                                                <pre style="max-height: 200px; overflow: auto; font-size: 0.75rem; background: #f5fff5; border: 1px solid #ccffcc; border-radius: 4px; padding: 8px; margin: 0; white-space: pre-wrap; word-break: break-all;">@FormatJson(log.NewValues)</pre>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(log.IPAddress))
                                        {
                                            <div class="mt-2 text-muted small">
                                                <span class="fw-semibold">IP:</span> @log.IPAddress
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted small">
                Showing page @CurrentPage
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(CurrentPage <= 1)" @onclick="() => GoToPage(CurrentPage - 1)">
                    Previous
                </button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasMoreData)" @onclick="() => GoToPage(CurrentPage + 1)">
                    Next
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool IsLoading = true;
    private bool HasMoreData;
    private int CurrentPage = 1;
    private const int PageSize = 20;

    private DateTime? DateFrom;
    private DateTime? DateTo;
    private string SelectedModule = "";
    private string SelectedAction = "";
    private string SearchTerm = "";
    private int? ExpandedLogId;

    private List<AuditLogDto>? Logs;

    protected override async Task OnInitializedAsync()
    {
        await ReloadLogs();
    }

    private async Task ReloadLogs()
    {
        IsLoading = true;
        StateHasChanged();

        var filter = new AuditLogFilterDto
        {
            Page = CurrentPage,
            PageSize = PageSize,
            Module = string.IsNullOrWhiteSpace(SelectedModule) ? null : SelectedModule,
            Action = string.IsNullOrWhiteSpace(SelectedAction) ? null : SelectedAction,
            SearchTerm = string.IsNullOrWhiteSpace(SearchTerm) ? null : SearchTerm,
            DateFrom = DateFrom,
            DateTo = DateTo.HasValue ? DateTo.Value.Date.AddDays(1).AddSeconds(-1) : null
        };

        var result = await AuditLogService.GetAuditLogs(filter);
        if (result.Success)
        {
            Logs = result.Data;
            HasMoreData = result.Data != null && result.Data.Count == PageSize;
        }
        else
        {
            Logs = new();
            HasMoreData = false;
        }

        ExpandedLogId = null;
        IsLoading = false;
        StateHasChanged();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            CurrentPage = 1;
            await ReloadLogs();
        }
    }

    private async Task ResetFilters()
    {
        DateFrom = null;
        DateTo = null;
        SelectedModule = "";
        SelectedAction = "";
        SearchTerm = "";
        CurrentPage = 1;
        ExpandedLogId = null;
        await ReloadLogs();
    }

    private void OnDateFilterChanged()
    {
        CurrentPage = 1;
        _ = ReloadLogs();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1) return;
        CurrentPage = page;
        await ReloadLogs();
    }

    private void ToggleDetail(int logId)
    {
        ExpandedLogId = ExpandedLogId == logId ? null : logId;
    }

    private void ExportCsv()
    {
    }

    private static string GetActionBadgeClass(string action)
    {
        return action switch
        {
            "Created" => "bg-success-subtle text-success border border-success-subtle",
            "Updated" => "bg-info-subtle text-info-emphasis border border-info-subtle",
            "Deleted" => "bg-danger-subtle text-danger border border-danger-subtle",
            "Login" => "bg-primary-subtle text-primary border border-primary-subtle",
            "Logout" => "bg-secondary-subtle text-secondary border border-secondary-subtle",
            _ => "bg-light text-dark border border-light-subtle"
        };
    }

    private static string GetModuleBadgeClass(string module)
    {
        return module switch
        {
            "UserManagement" => "badge-module-user",
            "RoleManagement" => "badge-module-role",
            "Inventory" => "badge-module-inventory",
            "POS" => "badge-module-pos",
            "Reports" => "badge-module-reports",
            "Promotions" => "badge-module-promo",
            "Customers" => "badge-module-customer",
            "PurchaseOrders" => "badge-module-po",
            "AuditLogs" => "badge-module-audit",
            _ => "badge-module-default"
        };
    }

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrEmpty(json)) return "(empty)";
        try
        {
            var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
}
