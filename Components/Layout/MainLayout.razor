@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="app-layout @(IsAdminPage ? "admin-layout" : "")">
    @if (IsAdminPage)
    {
        <aside class="admin-sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand">
                    <span class="brand-icon">SP+</span>
                </div>
                <span class="brand-text">SmartPOS+</span>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">Administration</div>

                <NavLink class="nav-item" href="/admin/users" Match="NavLinkMatch.Prefix">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="nav-icon" viewBox="0 0 16 16">
                        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.274-.1-3.41-4.793-3.41C.851 9.586 0 11.2 0 12.996C0 13.996 1 14 1 14zM11 3.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0M4.5 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/>
                    </svg>
                    <span>User Management</span>
                </NavLink>

                <NavLink class="nav-item" href="/admin/customers" Match="NavLinkMatch.Prefix">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="nav-icon" viewBox="0 0 16 16">
                        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/>
                    </svg>
                    <span>Customer Management</span>
                </NavLink>

                <NavLink class="nav-item" href="/admin/roles" Match="NavLinkMatch.Prefix">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="nav-icon" viewBox="0 0 16 16">
                        <path d="M4.5 11.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-3a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-3a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5"/>
                        <path d="M3 0a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V1a1 1 0 0 0-1-1zm0 1h10v14H3z"/>
                    </svg>
                    <span>Role Management</span>
                </NavLink>

                <div class="nav-section-label mt-3">Promotions</div>

                <NavLink class="nav-item" href="/manager/promotions" Match="NavLinkMatch.Prefix">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="nav-icon" viewBox="0 0 16 16">
                        <path d="M3.604 7.197c.412-.81.628-1.721.628-2.693C9.232.75 6.61.5 4.5.5 2.39.5 0 2.39 0 4.5c0 3.303 2.206 5.732 4.854 7.854.26.21.535.404.814.593.278-.189.554-.383.814-.593C9.794 10.232 12 7.803 12 4.5c0-.972.216-1.883.628-2.693C11.39.75 8.768.5 6.646.5c-2.122 0-4.744.25-6.86 2.604.412-.81 1.122-1.522 2.122-2.004a9.265 9.265 0 0 0-2.302 1.848C1.025 4.025 1 4.262 1 4.5c0 2.687 1.813 4.747 4.268 6.518a10.56 10.56 0 0 0-1.995-1.426c.846.31 1.75.508 2.727.508.977 0 1.88-.198 2.727-.508a10.56 10.56 0 0 0-1.995 1.426C13.187 9.247 15 7.187 15 4.5c0-.238-.025-.475-.073-.704a9.265 9.265 0 0 0-2.302-1.848c1 .482 1.71 1.194 2.122 2.004-2.116-2.354-4.738-2.604-6.86-2.604z"/>
                        <path d="M4.5 2.5a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
                    </svg>
                    <span>Promotion Management</span>
                </NavLink>

                <NavLink class="nav-item" href="/customer/promotions" Match="NavLinkMatch.Prefix">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="nav-icon" viewBox="0 0 16 16">
                        <path d="M1.5 1a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h2a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-2zm10 0a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h2a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-2zM1 6.5A1.5 1.5 0 0 1 2.5 5h11A1.5 1.5 0 0 1 15 6.5v4a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 10.5v-4zM3.854 6.646a.5.5 0 0 1 .708 0l2.5 2.5a.5.5 0 0 1-.708.708L4.5 7.707l-1.854 1.854a.5.5 0 0 1-.708-.708l2.5-2.5zm6.292 0l2.5 2.5a.5.5 0 0 1-.708.708L10 7.707l-1.854 1.854a.5.5 0 0 1-.708-.708l2.5-2.5a.5.5 0 0 1 .708 0z"/>
                    </svg>
                    <span>Active Promotions</span>
                </NavLink>
            </nav>

            <div class="sidebar-footer">
                <NavLink class="nav-item" href="/">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="nav-icon" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M9.5 1.5a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-4a.5.5 0 0 1 .5-.5zm-2 6v4a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-4a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5m6-6v4a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-4a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5m0 6v4a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-4a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5"/>
                    </svg>
                    <span>Back to Home</span>
                </NavLink>
            </div>
        </aside>
    }

    <main class="main-content @(IsAdminPage ? "with-sidebar" : "")">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool IsAdminPage => Navigation.Uri.Contains("/admin/", StringComparison.OrdinalIgnoreCase)
                                || Navigation.Uri.Contains("/manager/", StringComparison.OrdinalIgnoreCase);
}
