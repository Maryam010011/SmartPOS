@code {
    // в”Ђв”Ђ Services are injected at the top of the file в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    // в”Ђв”Ђ Clock в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private string currentTime = string.Empty;
    private System.Threading.Timer? _clockTimer;

    // в”Ђв”Ђ Data в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private List<ProductDto>  allProducts      = new();
    private List<CategoryDto> categories       = new();
    private bool              isLoadingProducts;
    private string            productError     = string.Empty;

    // в”Ђв”Ђ Filtering в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private string searchKeyword      = string.Empty;
    private int    selectedCategoryId = 0;

    private List<ProductDto> filteredProducts =>
        allProducts
            .Where(p => p.IsActive)
            .Where(p => selectedCategoryId == 0 || p.CategoryId == selectedCategoryId)
            .Where(p => string.IsNullOrWhiteSpace(searchKeyword)
                        || p.Name.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase)
                        || p.SKU.Contains(searchKeyword,  StringComparison.OrdinalIgnoreCase))
            .ToList();

    // в”Ђв”Ђ Cart в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private List<CartLineItem> cartItems = new();

    // в”Ђв”Ђ Promo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private string promoCode      = string.Empty;
    private string promoMessage   = string.Empty;
    private bool   promoApplied;
    private decimal discountAmount;

    // в”Ђв”Ђ Totals в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private const decimal TaxRate = 0.17m;
    private decimal SubTotal    => cartItems.Sum(i => i.UnitPrice * i.Quantity);
    private decimal Taxable     => SubTotal - discountAmount;
    private decimal TaxAmount   => Math.Round(Taxable * TaxRate, 2);
    private decimal TotalAmount => Taxable + TaxAmount;

    // в”Ђв”Ђ Checkout Modal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private bool          showCheckoutModal;
    private PaymentMethod selectedPayment    = PaymentMethod.Cash;
    private SaleType      selectedSaleType   = SaleType.Onsite;
    private int?          checkoutCustomerId;
    private string        checkoutError      = string.Empty;
    private bool          isProcessingSale;

    // в”Ђв”Ђ Receipt Modal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private bool           showReceiptModal;
    private SaleResultDto? lastSaleResult;

    // в”Ђв”Ђ Lifecycle в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    protected override async Task OnInitializedAsync()
    {
        UpdateClock();
        _clockTimer = new System.Threading.Timer(
            _ => { UpdateClock(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

        await LoadDataAsync();
    }

    private void UpdateClock()
    {
        currentTime = DateTime.Now.ToString("ddd, dd MMM yyyy  -  hh:mm:ss tt");
    }

    private async Task LoadDataAsync()
    {
        isLoadingProducts = true;
        productError      = string.Empty;

        try
        {
            var catTask  = CategoryService.GetAll();
            var prodTask = ProductService.GetAll();
            await Task.WhenAll(catTask, prodTask);

            var catResp  = catTask.Result;
            var prodResp = prodTask.Result;

            if (catResp.Success && catResp.Data != null)
                categories = catResp.Data;
            else
                productError = catResp.Message;

            if (prodResp.Success && prodResp.Data != null)
                allProducts = prodResp.Data;
            else
                productError = string.IsNullOrWhiteSpace(productError)
                              ? prodResp.Message
                              : productError;
        }
        catch (Exception ex)
        {
            productError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            isLoadingProducts = false;
        }
    }

    // в”Ђв”Ђ Filtering & Search в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    private void SelectCategory(int catId)
    {
        selectedCategoryId = catId;
        searchKeyword = string.Empty;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchKeyword = e.Value?.ToString() ?? string.Empty;
        selectedCategoryId = 0; // reset filter when searching
    }

    // в”Ђв”Ђ Cart Operations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    private void AddToCart(ProductDto product)
    {
        var existing = cartItems.FirstOrDefault(i => i.ProductId == product.Id);
        if (existing is not null)
        {
            existing.Quantity++;
        }
        else
        {
            cartItems.Add(new CartLineItem
            {
                ProductId   = product.Id,
                ProductName = product.Name,
                UnitPrice   = product.Price,
                Quantity    = 1
            });
        }
    }

    private void ChangeQty(CartLineItem item, int delta)
    {
        item.Quantity += delta;
        if (item.Quantity <= 0)
            cartItems.Remove(item);
    }

    private void RemoveFromCart(CartLineItem item)
    {
        cartItems.Remove(item);
    }

    private void ClearCart()
    {
        cartItems.Clear();
        ResetPromo();
    }

    // в”Ђв”Ђ Promo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    private void ApplyPromo()
    {
        // Promo service integration is pending (IPromotionService belongs to Maryam Jahangir).
        // For now we accept the code and note it will be sent in CreateSaleDto.PromoCode
        // so SaleService can handle it when the Promotion module is wired up.
        if (string.IsNullOrWhiteSpace(promoCode))
        {
            promoMessage = "Please enter a promo code.";
            promoApplied = false;
            return;
        }

        // Optimistic: accept code and let SaleService validate server-side
        promoApplied  = true;
        promoMessage  = $"Code \"{promoCode.Trim().ToUpper()}\" will be applied at checkout.";
        discountAmount = 0m; // actual discount calculated server-side
    }

    private void ResetPromo()
    {
        promoCode      = string.Empty;
        promoMessage   = string.Empty;
        promoApplied   = false;
        discountAmount = 0m;
    }

    // в”Ђв”Ђ Checkout Modal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    private void OpenCheckoutModal()
    {
        checkoutError = string.Empty;
        showCheckoutModal = true;
    }

    private void CloseCheckoutModal()
    {
        showCheckoutModal = false;
        checkoutError     = string.Empty;
    }

    private async Task ConfirmSaleAsync()
    {
        if (cartItems.Count == 0) return;

        isProcessingSale = true;
        checkoutError    = string.Empty;

        try
        {
            var dto = new CreateSaleDto
            {
                // UserId = 1 placeholder; replace with real auth context when auth module lands
                UserId        = 1,
                CustomerId    = checkoutCustomerId > 0 ? checkoutCustomerId : null,
                PromoCode     = promoApplied ? promoCode.Trim() : null,
                SaleType      = selectedSaleType,
                PaymentMethod = selectedPayment,
                Items         = cartItems.Select(ci => new SaleItemDto
                {
                    ProductId   = ci.ProductId,
                    ProductName = ci.ProductName,
                    Quantity    = ci.Quantity,
                    UnitPrice   = ci.UnitPrice,
                    LineTotal   = ci.UnitPrice * ci.Quantity
                }).ToList()
            };

            var response = await SaleService.ProcessSale(dto);

            if (response.Success && response.Data != null)
            {
                lastSaleResult    = response.Data;
                showCheckoutModal = false;
                showReceiptModal  = true;
                // Cart and promo cleared after receipt is dismissed
            }
            else
            {
                checkoutError = response.Message;
            }
        }
        catch (Exception ex)
        {
            checkoutError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isProcessingSale = false;
        }
    }

    // в”Ђв”Ђ Receipt / Reset в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    private void CloseReceiptAndReset()
    {
        showReceiptModal  = false;
        lastSaleResult    = null;
        cartItems.Clear();
        ResetPromo();
        checkoutCustomerId = null;
        selectedPayment    = PaymentMethod.Cash;
        selectedSaleType   = SaleType.Onsite;
    }

