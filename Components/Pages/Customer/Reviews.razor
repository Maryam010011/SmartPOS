@page "/customer/reviews"
@rendermode InteractiveServer
@layout CustomerLayout

@inject IProductService  ProductService
@inject IReviewService   ReviewService

<PageTitle>Reviews â€” SmartPOS+ Bakery</PageTitle>

<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     PAGE HERO HEADER
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
<section class="rv-hero">
    <div class="rv-hero-inner">
        <div class="rv-hero-text">
            <span class="rv-hero-eyebrow">â­ Customer Voices</span>
            <h1 class="rv-hero-title">Reviews &amp; Feedback</h1>
            <p class="rv-hero-sub">
                Share your experience and read what others are saying about our fresh-baked goods.
            </p>
        </div>
        <div class="rv-hero-stat-row">
            <div class="rv-stat-chip">
                <span class="rv-stat-icon">ðŸ“</span>
                <div class="rv-stat-body">
                    <span class="rv-stat-val">@_allReviews.Count</span>
                    <span class="rv-stat-lbl">Total Reviews</span>
                </div>
            </div>
            <div class="rv-stat-chip">
                <span class="rv-stat-icon">ðŸ˜Š</span>
                <div class="rv-stat-body">
                    <span class="rv-stat-val">@_positiveCount</span>
                    <span class="rv-stat-lbl">Positive</span>
                </div>
            </div>
            <div class="rv-stat-chip">
                <span class="rv-stat-icon">â­</span>
                <div class="rv-stat-body">
                    <span class="rv-stat-val">@(_allReviews.Count > 0 ? (_allReviews.Average(r => r.Rating)).ToString("F1") : "â€”")</span>
                    <span class="rv-stat-lbl">Avg Rating</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     MAIN SPLIT LAYOUT
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
<section class="rv-main-layout">

    <!-- â”€â”€ LEFT PANEL: Write a Review â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <div class="rv-form-panel">
        <div class="rv-panel-header">
            <span class="rv-panel-icon">âœï¸</span>
            <div>
                <h2 class="rv-panel-title">Write a Review</h2>
                <p class="rv-panel-subtitle">Tell us about your experience</p>
            </div>
        </div>

        @if (_submitSuccess)
        {
            <div class="rv-success-toast" role="alert">
                <span class="rv-success-icon">âœ…</span>
                <div>
                    <strong>Review submitted!</strong>
                    <p>Thank you for your feedback. Your review has been added to the feed.</p>
                </div>
                <button class="rv-toast-dismiss" @onclick="DismissSuccess" aria-label="Dismiss">Ã—</button>
            </div>
        }

        @if (!string.IsNullOrEmpty(_submitError))
        {
            <div class="rv-error-toast" role="alert">
                <span>âš ï¸</span>
                <div>
                    <strong>Submission failed</strong>
                    <p>@_submitError</p>
                </div>
                <button class="rv-toast-dismiss" @onclick="DismissError" aria-label="Dismiss">Ã—</button>
            </div>
        }

        <div class="rv-form-body">
            <!-- Product Select -->
            <div class="rv-field">
                <label class="rv-label" for="rv-product-select">
                    Select Product <span class="rv-required">*</span>
                </label>
                @if (_loadingProducts)
                {
                    <div class="rv-select-skeleton skeleton"></div>
                }
                else
                {
                    <div class="rv-select-wrap">
                        <select id="rv-product-select"
                                class="rv-select"
                                @bind="_selectedProductId"
                                @bind:after="OnProductChanged">
                            <option value="0">â€” Choose a product â€”</option>
                            @foreach (var product in _products)
                            {
                                <option value="@product.Id">@product.Name</option>
                            }
                        </select>
                        <span class="rv-select-arrow">â–¾</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_productError))
                {
                    <span class="rv-field-error">@_productError</span>
                }
            </div>

            <!-- Star Rating -->
            <div class="rv-field">
                <label class="rv-label">
                    Your Rating <span class="rv-required">*</span>
                </label>
                <div class="rv-stars-row" role="group" aria-label="Star rating selector">
                    @for (int i = 1; i <= 5; i++)
                    {
                        int star = i;
                        <button id="rv-star-@star"
                                type="button"
                                class="rv-star @(star <= (_hoverRating > 0 ? _hoverRating : _newReview.Rating) ? "rv-star--filled" : "")"
                                @onclick="@(() => SetRating(star))"
                                @onmouseenter="@(() => _hoverRating = star)"
                                @onmouseleave="@(() => _hoverRating = 0)"
                                aria-label="@star star@(star == 1 ? "" : "s")">
                            â˜…
                        </button>
                    }
                    <span class="rv-star-label">
                        @if (_newReview.Rating > 0)
                        {
                            @RatingLabel(_newReview.Rating)
                        }
                        else
                        {
                            <span class="rv-star-placeholder">Tap a star to rate</span>
                        }
                    </span>
                </div>
                @if (_formSubmitted && _newReview.Rating == 0)
                {
                    <span class="rv-field-error">Please select a rating.</span>
                }
            </div>

            <!-- Comment Textarea -->
            <div class="rv-field">
                <label class="rv-label" for="rv-comment">
                    Your Comment
                    <span class="rv-label-hint">(optional â€” our AI will analyze the sentiment)</span>
                </label>
                <textarea id="rv-comment"
                          class="rv-textarea"
                          placeholder="Describe your experience with this productâ€¦"
                          rows="5"
                          maxlength="1000"
                          @bind="_newReview.Comment"
                          @bind:event="oninput"></textarea>
                <div class="rv-char-count">
                    @(_newReview.Comment?.Length ?? 0) / 1000
                </div>
            </div>

            <!-- Auth Placeholder Notice -->
            <div class="rv-auth-notice">
                <span class="rv-auth-icon">ðŸ”</span>
                <p>
                    <!-- AUTH PLACEHOLDER: CustomerId is hardcoded to 1 below as a development stub.
                         TODO: Replace with the real authenticated customer ID once MaryamJ's
                         authentication branch (auth-system) is merged into main. Wire this to:
                         AuthStateService.CurrentUser.Id or equivalent auth state provider. -->
                    Submitting as <strong>Guest Customer</strong> (Auth integration pending â€” see code comment).
                </p>
            </div>

            <!-- Submit Button -->
            <button id="rv-submit-btn"
                    class="rv-submit-btn @(_isSubmitting ? "rv-submit-btn--loading" : "")"
                    type="button"
                    disabled="@(_isSubmitting || _selectedProductId == 0 || _newReview.Rating == 0)"
                    @onclick="SubmitReviewAsync">
                @if (_isSubmitting)
                {
                    <span class="rv-spinner"></span>
                    <span>Submittingâ€¦</span>
                }
                else
                {
                    <span>Submit Review</span>
                    <span class="rv-submit-arrow">â†’</span>
                }
            </button>
        </div>
    </div>

    <!-- â”€â”€ RIGHT PANEL: Review Feed â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <div class="rv-feed-panel">
        <div class="rv-panel-header">
            <span class="rv-panel-icon">ðŸ’¬</span>
            <div>
                <h2 class="rv-panel-title">
                    @if (_selectedProductId > 0)
                    {
                        @($"Reviews for {_selectedProductName}")
                    }
                    else
                    {
                        @("All Reviews")
                    }
                </h2>
                <p class="rv-panel-subtitle">
                    @if (_selectedProductId > 0)
                    {
                        @($"{_reviews.Count} review{(_reviews.Count == 1 ? "" : "s")} found")
                    }
                    else
                    {
                        <span>Select a product to filter</span>
                    }
                </p>
            </div>

            <!-- Feed Filter Pills -->
            <div class="rv-filter-pills">
                @foreach (var filter in new[] { "All", "Positive", "Neutral", "Negative" })
                {
                    <button id="rv-filter-@filter.ToLower()"
                            type="button"
                            class="rv-pill @(_activeSentimentFilter == filter ? "rv-pill--active" : "")"
                            @onclick="@(() => SetSentimentFilter(filter))">
                        @filter
                    </button>
                }
            </div>
        </div>

        <div class="rv-feed-scroll">
            @if (_loadingReviews)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="rv-review-card rv-review-card--skeleton">
                        <div class="rv-sk rv-sk--header"></div>
                        <div class="rv-sk rv-sk--body"></div>
                        <div class="rv-sk rv-sk--body rv-sk--short"></div>
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(_feedError))
            {
                <div class="rv-feed-empty">
                    <span class="rv-empty-icon">âš ï¸</span>
                    <p class="rv-empty-msg">@_feedError</p>
                </div>
            }
            else if (FilteredReviews.Count == 0)
            {
                <div class="rv-feed-empty">
                    <span class="rv-empty-icon">ðŸŒŸ</span>
                    <p class="rv-empty-title">No reviews yet</p>
                    <p class="rv-empty-msg">
                        @if (_selectedProductId > 0)
                        {
                            @("Be the first to share your thoughts on this product!")
                        }
                        else
                        {
                            @("Select a product on the left and be the first to review it.")
                        }
                    </p>
                </div>
            }
            else
            {
                @foreach (var review in FilteredReviews)
                {
                    <article id="rv-card-@review.Id" class="rv-review-card">

                        <!-- Card Top Row: Avatar + Meta + Sentiment Badge -->
                        <div class="rv-card-top">
                            <div class="rv-avatar" aria-hidden="true">
                                @GetAvatarInitial(review.CustomerName)
                            </div>
                            <div class="rv-card-meta">
                                <span class="rv-card-customer">
                                    @(string.IsNullOrEmpty(review.CustomerName) ? "Anonymous" : review.CustomerName)
                                </span>
                                <span class="rv-card-product">on <em>@review.ProductName</em></span>
                                <time class="rv-card-date" datetime="@review.CreatedAt.ToString("o")">
                                    @FormatDate(review.CreatedAt)
                                </time>
                            </div>
                            <span class="rv-sentiment-badge rv-sentiment-badge--@review.Sentiment.ToLower()" aria-label="Sentiment: @review.Sentiment">
                                @SentimentIcon(review.Sentiment) @review.Sentiment
                            </span>
                        </div>

                        <!-- Star Display -->
                        <div class="rv-card-stars" aria-label="Rating: @review.Rating out of 5">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <span class="rv-card-star @(s <= review.Rating ? "rv-card-star--filled" : "")">â˜…</span>
                            }
                            <span class="rv-card-rating-num">@review.Rating.ToString("F0")/5</span>
                        </div>

                        <!-- Comment -->
                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                        {
                            <p class="rv-card-comment">"@review.Comment"</p>
                        }
                        else
                        {
                            <p class="rv-card-comment rv-card-comment--empty">No written comment provided.</p>
                        }

                        <!-- Sentiment Score Bar -->
                        @if (!string.IsNullOrEmpty(review.Sentiment))
                        {
                            <div class="rv-score-bar-wrap" aria-label="Sentiment score">
                                <span class="rv-score-bar-label">Sentiment Confidence</span>
                                <div class="rv-score-bar-track">
                                    <div class="rv-score-bar-fill rv-score-bar-fill--@review.Sentiment.ToLower()"
                                         style="width: @((review.SentimentScore * 100).ToString("F0"))%">
                                    </div>
                                </div>
                                <span class="rv-score-bar-pct">@((review.SentimentScore * 100).ToString("F0"))%</span>
                            </div>
                        }
                    </article>
                }
            }
        </div>
    </div>

</section>

@code {
    // â”€â”€ State: Products â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private List<ProductDto>  _products       = new();
    private bool              _loadingProducts = true;
    private string?           _productError;

    // â”€â”€ State: Review Form â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private int               _selectedProductId   = 0;
    private string            _selectedProductName = string.Empty;
    private int               _hoverRating         = 0;
    private bool              _formSubmitted       = false;
    private bool              _isSubmitting        = false;
    private bool              _submitSuccess        = false;
    private string?           _submitError;

    /// <summary>
    /// The CreateReviewDto being built by the form.
    /// CustomerId is a hardcoded placeholder (1).
    ///
    /// TODO: Replace CustomerId with the real authenticated user's ID once
    /// MaryamJ's authentication branch (auth-system) is merged into main.
    /// Wire to: AuthStateService.CurrentUser.Id or the equivalent cascading
    /// AuthenticationState that her system exposes.
    /// </summary>
    private CreateReviewDto _newReview = new()
    {
        CustomerId = 1  // â† PLACEHOLDER â€” see TODO above
    };

    // â”€â”€ State: Review Feed â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private List<ReviewDto>  _reviews        = new();
    private List<ReviewDto>  _allReviews     = new();
    private bool             _loadingReviews = false;
    private string?          _feedError;
    private string           _activeSentimentFilter = "All";

    // â”€â”€ Computed â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private int _positiveCount => _allReviews.Count(r => r.Sentiment == "Positive");

    private List<ReviewDto> FilteredReviews =>
        _activeSentimentFilter == "All"
            ? _reviews
            : _reviews.Where(r => r.Sentiment == _activeSentimentFilter).ToList();

    // â”€â”€ Lifecycle â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadProductsAsync(), LoadAllReviewsAsync());
    }

    // â”€â”€ Data Loaders â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private async Task LoadProductsAsync()
    {
        _loadingProducts = true;
        try
        {
            var result = await ProductService.GetAll();
            if (result.Success && result.Data is not null)
                _products = result.Data.Where(p => p.IsActive).OrderBy(p => p.Name).ToList();
            else
                _productError = result.Message;
        }
        catch (Exception ex)
        {
            _productError = $"Could not load products: {ex.Message}";
        }
        finally
        {
            _loadingProducts = false;
        }
    }

    private async Task LoadAllReviewsAsync()
    {
        try
        {
            var result = await ReviewService.GetAll();
            if (result.Success && result.Data is not null)
            {
                _allReviews = result.Data;
                _reviews    = result.Data;
            }
        }
        catch { /* Non-critical â€” stat chips will show 0 */ }
    }

    private async Task LoadReviewsForProductAsync(int productId)
    {
        _loadingReviews = true;
        _feedError      = null;
        _reviews        = new();
        try
        {
            var result = await ReviewService.GetByProduct(productId);
            if (result.Success && result.Data is not null)
                _reviews = result.Data;
            else
                _feedError = result.Message;
        }
        catch (Exception ex)
        {
            _feedError = $"Could not load reviews: {ex.Message}";
        }
        finally
        {
            _loadingReviews = false;
        }
    }

    // â”€â”€ Event Handlers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private async Task OnProductChanged()
    {
        _activeSentimentFilter = "All";
        _newReview.ProductId   = _selectedProductId;

        var product = _products.FirstOrDefault(p => p.Id == _selectedProductId);
        _selectedProductName = product?.Name ?? string.Empty;

        if (_selectedProductId > 0)
            await LoadReviewsForProductAsync(_selectedProductId);
        else
            _reviews = _allReviews;
    }

    private void SetRating(int rating)
    {
        _newReview.Rating = rating;
    }

    private void SetSentimentFilter(string filter)
    {
        _activeSentimentFilter = filter;
    }

    private async Task SubmitReviewAsync()
    {
        _formSubmitted = true;
        _submitError   = null;

        if (_selectedProductId == 0 || _newReview.Rating == 0)
            return;

        _isSubmitting = true;
        try
        {
            _newReview.ProductId = _selectedProductId;

            var result = await ReviewService.Create(_newReview);
            if (result.Success && result.Data is not null)
            {
                _submitSuccess = true;

                // Prepend new review to the local feeds for instant UI refresh
                _reviews.Insert(0, result.Data);
                _allReviews.Insert(0, result.Data);

                // Reset form fields (keep product and CustomerId placeholder)
                _newReview = new CreateReviewDto
                {
                    CustomerId = 1,  // â† PLACEHOLDER â€” see TODO above
                    ProductId  = _selectedProductId
                };
                _formSubmitted = false;
                _hoverRating   = 0;
            }
            else
            {
                _submitError = result.Message;
            }
        }
        catch (Exception ex)
        {
            _submitError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void DismissSuccess() => _submitSuccess = false;
    private void DismissError()   => _submitError   = null;

    // â”€â”€ Helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private static string RatingLabel(int rating) => rating switch
    {
        1 => "ðŸ˜ž Poor",
        2 => "ðŸ˜• Fair",
        3 => "ðŸ˜ Average",
        4 => "ðŸ˜Š Good",
        5 => "ðŸ¤© Excellent",
        _ => string.Empty
    };

    private static string SentimentIcon(string sentiment) => sentiment switch
    {
        "Positive" => "ðŸ˜Š",
        "Negative" => "ðŸ˜ž",
        "Neutral"  => "ðŸ˜",
        _          => "â“"
    };

    private static string GetAvatarInitial(string name)
        => string.IsNullOrEmpty(name) ? "?" : name[0].ToString().ToUpper();

    private static string FormatDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if      (diff.TotalMinutes < 2)  return "just now";
        else if (diff.TotalHours   < 1)  return $"{(int)diff.TotalMinutes}m ago";
        else if (diff.TotalDays    < 1)  return $"{(int)diff.TotalHours}h ago";
        else if (diff.TotalDays    < 7)  return $"{(int)diff.TotalDays}d ago";
        else return dt.ToString("MMM d, yyyy");
    }
}


<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     SCOPED STYLES â€” ALL COLORS FROM colors.css VARIABLES
