        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .rv-submit-arrow {
        font-size: 1.1rem;
        transition: transform .18s;
    }

    .rv-submit-btn:hover:not(:disabled) .rv-submit-arrow {
        transform: translateX(4px);
