    .po-badge-cancelled {
        background-color: color-mix(in srgb, var(--color-navbar-bg) 15%, var(--color-page-bg));
        border: 1px solid color-mix(in srgb, var(--color-navbar-bg) 25%, transparent);
        color: color-mix(in srgb, var(--color-primary-text) 70%, transparent);
