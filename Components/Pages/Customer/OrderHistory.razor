    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    protected override async Task OnInitializedAsync()
    {
        // Seed the filter with the placeholder customer ID.
        // TODO: Replace with authenticated user ID once MaryamJ's
        //       auth service is available and merged.
        _filter = new SaleFilterDto
        {
            UserId = _placeholderCustomerId
        };

        await LoadOrders();
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  Data Loading
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private async Task LoadOrders()
    {
        _isLoading    = true;
        _errorMessage = null;
        StateHasChanged();

        var result = await SaleService.GetAll(_filter);

        if (result.Success && result.Data is not null)
        {
            _orders = result.Data;
        }
        else
        {
            _orders       = new();
            _errorMessage = result.Message;
        }

        _currentPage = 1;
        UpdatePage();
        _isLoading = false;
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  Filter Handlers
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void OnFromDateChange(string? value)
    {
        _filter.From = DateTime.TryParse(value, out var dt) ? dt : null;
    }

    private void OnToDateChange(string? value)
    {
        _filter.To = DateTime.TryParse(value, out var dt) ? dt : null;
    }

    private void OnStatusChange(string? value)
    {
        _filter.Status = Enum.TryParse<SaleStatus>(value, out var s) ? s : null;
    }

    private void OnSaleTypeChange(string? value)
    {
        _filter.SaleType = Enum.TryParse<SaleType>(value, out var t) ? t : null;
    }

    private async Task ApplyFilters() => await LoadOrders();

    private async Task ResetFilters()
    {
        _filter = new SaleFilterDto
        {
            // TODO: Replace with real authenticated user ID when MaryamJ's
            //       auth branch is merged.
            UserId = _placeholderCustomerId
        };
        await LoadOrders();
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  Pagination
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void UpdatePage()
    {
        _totalPages  = (int)Math.Ceiling(_orders.Count / (double)_pageSize);
        if (_totalPages < 1) _totalPages = 1;
        _pagedOrders = _orders
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _currentPage = page;
        UpdatePage();
    }

