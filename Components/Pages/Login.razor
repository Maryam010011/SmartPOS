@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using SmartPOS.Services.MaryamJ
@inject AuthService AuthService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">🎂</div>
            <h2>SmartPOS+</h2>
            <p class="text-muted">Sign in to your sweet management account</p>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger py-2 small">@Error</div>
        }

        @if (SelectedRole == null)
        {
            <div class="role-selection">
                <p class="text-center text-muted small mb-3">Select your role to continue</p>
                <div class="role-grid">
                    <button class="role-btn role-admin" @onclick="SelectAdmin">
                      
                        <span class="role-label">Admin</span>
                    </button>
                    <button class="role-btn role-manager" @onclick="SelectManager">
                        
                        <span class="role-label">Manager</span>
                    </button>
                    <button class="role-btn role-cashier" @onclick="SelectCashier">
                       
                        <span class="role-label">Cashier</span>
                    </button>
                    <button class="role-btn role-customer" @onclick="SelectCustomer">
        
                        <span class="role-label">Customer</span>
                    </button>
                </div>
                <div class="divider-line mt-3">
                    <span>NEW HERE?</span>
                </div>
                <a href="/register" class="btn btn-outline-secondary w-100 py-2 fw-semibold mt-2">Create Account</a>
            </div>
        }
        else
        {
            <div class="role-form">
                <div class="d-flex align-items-center mb-3">
                    <button class="btn btn-sm btn-outline-secondary me-2" @onclick="BackToRoleSelection">←</button>
                    <span class="fw-bold">@SelectedRole Login</span>
                </div>

                <EditForm Model="@Model" OnValidSubmit="HandleLogin" FormName="loginForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Email Address</label>
                        <InputText @bind-Value="Model.Email" class="form-control" placeholder="you@smartpos.pk" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Password</label>
                        <div class="input-group">
                            <InputText @bind-Value="Model.Password" type="@(ShowPassword ? "text" : "password")" class="form-control" placeholder="••••••••" required />
                            <button class="btn btn-outline-secondary" type="button" @onclick="TogglePasswordVisibility">
                                @(ShowPassword ? "🙈" : "👁")
                            </button>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <a href="/forgot-password" class="text-burnt-orange small fw-semibold text-decoration-none">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn btn-burnt-orange w-100 py-2 fw-semibold" disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Sign In as @SelectedRole
                    </button>
                </EditForm>
            </div>
        }
    </div>
</div>

<style>
    .login-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%); padding: 1rem; font-family: 'Inter', sans-serif; }
    .login-card { background: white; border-radius: 20px; box-shadow: 0 10px 45px rgba(0,0,0,0.08); padding: 2.5rem; width: 100%; max-width: 420px; border: 1px solid rgba(204, 85, 0, 0.1); }
    .login-header { text-align: center; margin-bottom: 2rem; }
    .login-logo { display: inline-flex; align-items: center; justify-content: center; width: 72px; height: 72px; border-radius: 50%; background: #FFE8D6; font-size: 2.5rem; margin-bottom: 1rem; box-shadow: 0 4px 15px rgba(204, 85, 0, 0.15); }
    .login-header h2 { font-weight: 800; color: #4A2C2A; margin: 0; font-size: 1.8rem; }
    .login-header p { font-size: 0.9rem; margin-top: 0.5rem; }
    .form-control:focus { border-color: #CC5500; box-shadow: 0 0 0 0.25rem rgba(204, 85, 0, 0.25); }
    .btn-burnt-orange { background-color: #CC5500; color: white; border: none; transition: background-color 0.2s; }
    .btn-burnt-orange:hover { background-color: #A34400; color: white; }
    .text-burnt-orange { color: #CC5500; }
    .text-burnt-orange:hover { color: #A34400; }

    .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .role-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px 8px; border-radius: 12px; border: none; cursor: pointer; font-family: inherit; transition: all 0.2s; width: 100%; }
    .role-btn .role-icon { font-size: 1.6rem; line-height: 1; }
    .role-btn .role-label { font-weight: 700; font-size: 0.9rem; margin-top: 6px; }
    .role-admin { background: #3D1C02; color: white; }
    .role-admin:hover { background: #2a1301; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(61,28,2,0.3); }
    .role-manager { background: #CC5500; color: white; }
    .role-manager:hover { background: #a34400; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(204,85,0,0.3); }
    .role-cashier { background: transparent; color: #CC5500; border: 2px solid #CC5500; }
    .role-cashier:hover { background: #FFF5ED; transform: translateY(-1px); }
    .role-customer { background: transparent; color: #3D1C02; border: 2px solid #3D1C02; }
    .role-customer:hover { background: #F5F0EB; transform: translateY(-1px); }
    .role-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none !important; }

    .divider-line { display: flex; align-items: center; margin: 1.5rem 0; gap: 1rem; }
    .divider-line::before, .divider-line::after { content: ""; flex: 1; height: 1px; background: #e0d6c8; }
    .divider-line span { font-size: 0.7rem; font-weight: 700; color: #b8a898; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap; }
</style>

@code {
    private string? SelectedRole;
    private LoginModel Model = new();
    private bool IsLoading;
    private bool ShowPassword;
    private string? Error;

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private void SelectAdmin() => SelectRole("Admin");
    private void SelectManager() => SelectRole("Manager");
    private void SelectCashier() => SelectRole("Cashier");
    private void SelectCustomer() => SelectRole("Customer");

    private void SelectRole(string role)
    {
        SelectedRole = role;
        Error = null;
    }

    private void BackToRoleSelection()
    {
        SelectedRole = null;
        Error = null;
        Model = new();
    }

    private void TogglePasswordVisibility() => ShowPassword = !ShowPassword;

    private async Task HandleLogin()
    {
        IsLoading = true;
        Error = null;

        string? redirect = null;

        try
        {
            var result = await AuthService.LoginAsync(Model.Email, Model.Password);
            if (result == null)
            {
                Error = "Invalid email or password.";
                return;
            }

            var actualRole = result.User.Role.Name;
            if (!string.Equals(actualRole, SelectedRole, StringComparison.OrdinalIgnoreCase))
            {
                Error = $"Access Denied. These credentials are for a {actualRole}, not a {SelectedRole}.";
                return;
            }

            await LocalStorage.SetItemAsync("authToken", result.Token);

            if (AuthStateProvider is CustomAuthStateProvider provider)
            {
                provider.MarkUserAsAuthenticated(result.Token);
            }

            redirect = actualRole.ToLower() switch
            {
                "admin" => "/admin/dashboard",
                "manager" => "/manager/dashboard",
                "cashier" => "/cashier/dashboard",
                "customer" => "/customer/dashboard",
                _ => "/"
            };
        }
        catch (Exception ex)
        {
            Error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }

        if (redirect != null)
        {
            NavigationManager.NavigateTo(redirect);
        }
    }
}
