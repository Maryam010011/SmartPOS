@page "/admin/sentiment"
@rendermode @(Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer)
@layout AdminLayout

<PageTitle>Sentiment & Reviews  -  SmartPOS+</PageTitle>

<div class="sentiment-page">

    <!-- ── Page Header ─────────────────────────────────────────────── -->
    <header class="page-header">
        <div class="page-title">
            <h1>Customer Sentiment &amp; Reviews</h1>
            <p>AI-powered sentiment intelligence from BERT analysis across all products.</p>
        </div>
        <div class="header-actions">
            @if (lastRefreshed.HasValue)
            {
                <span class="last-refreshed">Updated @lastRefreshed.Value.ToLocalTime().ToString("hh:mm tt")</span>
            }
            <button id="sentiment-refresh-btn" class="btn btn-outline" @onclick="RefreshAllAsync" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Refreshing</span>
                }
                else
                {
                    <span class="icon-refresh"></span>
                    <span>Refresh</span>
                }
            </button>
        </div>
    </header>

    <!-- ── Status Alert ────────────────────────────────────────────── -->
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @(isStatusSuccess ? "alert-success" : "alert-error")">
            <span>@statusMessage</span>
            <button class="btn btn-text" @onclick="ClearStatus">✕</button>
        </div>
    }

    <!-- ── KPI Summary Row ─────────────────────────────────────────── -->
    <section class="kpi-grid">

        <!-- Positive Sentiment Rate -->
        <div class="kpi-card kpi-positive">
            <div class="kpi-icon-wrap kpi-icon-pos">😊</div>
            <div class="kpi-content">
                <span class="kpi-label">Positive Sentiment</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value" style="color:var(--color-positive)">@OverallPositivePct.ToString("F1")%</span>
                    <span class="kpi-unit">of all reviews</span>
                }
            </div>
        </div>

        <!-- Total Reviews -->
        <div class="kpi-card kpi-total">
            <div class="kpi-icon-wrap kpi-icon-total"></div>
            <div class="kpi-content">
                <span class="kpi-label">Total Reviews</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value">@TotalReviewCount.ToString("N0")</span>
                    <span class="kpi-unit">reviews processed</span>
                }
            </div>
        </div>

        <!-- Average Rating -->
        <div class="kpi-card kpi-rating">
            <div class="kpi-icon-wrap kpi-icon-rating"></div>
            <div class="kpi-content">
                <span class="kpi-label">Avg. Customer Rating</span>
                @if (isLoading)
                {
                    <span class="kpi-value kpi-skeleton"> -  - </span>
                }
                else
                {
                    <span class="kpi-value">@OverallAvgRating.ToString("F2")<span class="kpi-denom"> / 5.0</span></span>
                    <div class="star-row" aria-label="Rating @OverallAvgRating out of 5">
                        @for (int s = 1; s <= 5; s++)
                        {
                            int si = s;
                            <span class="star @(OverallAvgRating >= si ? "star-full" : OverallAvgRating >= si - 0.5 ? "star-half" : "star-empty")">★</span>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Compound Sentiment Bar -->
        <div class="kpi-card kpi-breakdown">
            <div class="kpi-content" style="width:100%">
                <span class="kpi-label">Overall Sentiment Breakdown</span>
                @if (isLoading)
                {
                    <div class="compound-bar-skel"></div>
                }
                else if (TotalReviewCount == 0)
                {
                    <div class="compound-bar-empty">No data</div>
                }
                else
                {
                    <div class="compound-bar" role="img" aria-label="Sentiment breakdown">
                        <div class="compound-seg seg-pos" style="width:@OverallPositivePct.ToString("F1")%">
                            @if (OverallPositivePct > 8) { <span>@OverallPositivePct.ToString("F0")%</span> }
                        </div>
                        <div class="compound-seg seg-neu" style="width:@OverallNeutralPct.ToString("F1")%">
                            @if (OverallNeutralPct > 8) { <span>@OverallNeutralPct.ToString("F0")%</span> }
                        </div>
                        <div class="compound-seg seg-neg" style="width:@OverallNegativePct.ToString("F1")%">
                            @if (OverallNegativePct > 8) { <span>@OverallNegativePct.ToString("F0")%</span> }
                        </div>
                    </div>
                    <div class="compound-legend">
                        <span class="legend-item"><span class="legend-dot dot-pos"></span>Positive (@TotalPositive)</span>
                        <span class="legend-item"><span class="legend-dot dot-neu"></span>Neutral (@TotalNeutral)</span>
                        <span class="legend-item"><span class="legend-dot dot-neg"></span>Negative (@TotalNegative)</span>
                    </div>
                }
            </div>
        </div>

    </section>

    <!-- ── Filter Toolbar ─────────────────────────────────────────── -->
    <section class="filter-bar">
        <!-- Product Selector -->
        <div class="filter-group">
            <span class="filter-label">Filter by Product</span>
            <select id="sentiment-product-select" class="filter-select"
                    value="@selectedProductName"
                    @onchange="OnProductChange">
                <option value="">All Products</option>
                @foreach (var stat in sentimentStats)
                {
                    <option value="@stat.ProductName">@stat.ProductName</option>
                }
            </select>
        </div>

        <!-- Sentiment Pills -->
        <div class="filter-group">
            <span class="filter-label">Sentiment Filter</span>
            <div class="pill-group">
                <button id="sentiment-pill-all"      class="pill @(sentimentFilter == "All"      ? "pill-active" : "")" @onclick='() => SetSentimentFilter("All")'>All</button>
                <button id="sentiment-pill-positive" class="pill pill-pos @(sentimentFilter == "Positive" ? "pill-active pill-active-pos" : "")" @onclick='() => SetSentimentFilter("Positive")'>😊 Positive</button>
                <button id="sentiment-pill-neutral"  class="pill pill-neu @(sentimentFilter == "Neutral"  ? "pill-active pill-active-neu" : "")" @onclick='() => SetSentimentFilter("Neutral")'> Neutral</button>
                <button id="sentiment-pill-negative" class="pill pill-neg @(sentimentFilter == "Negative" ? "pill-active pill-active-neg" : "")" @onclick='() => SetSentimentFilter("Negative")'>😟 Negative</button>
            </div>
        </div>

        <!-- Search Bar -->
        <div class="filter-group filter-search">
            <span class="filter-label">Search Comments</span>
            <div class="search-wrap">
                <span class="search-icon"></span>
                <input id="sentiment-search-input"
                       type="text"
                       class="filter-input search-input"
                       placeholder="Search review text"
                       value="@searchQuery"
                       @oninput="OnSearchInput" />
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <button class="search-clear" @onclick="ClearSearch">✕</button>
                }
            </div>
        </div>

        <!-- Reset -->
        <div class="filter-actions">
            <button id="sentiment-reset-btn" class="btn btn-outline" @onclick="ResetFilters">Reset</button>
        </div>
    </section>

    <!-- ── Product Sentiment Leaderboard ──────────────────────────── -->
    <section class="card">
        <div class="card-header">
            <div>
                <h2>Product Sentiment Leaderboard</h2>
                <p class="card-subtitle">Per-product AI sentiment breakdown and average ratings</p>
            </div>
            @if (!isLoading && sentimentStats.Any())
            {
                <span class="badge">@sentimentStats.Count products</span>
            }
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="loading-state">
                    <span class="spinner"></span>
                    <span>Aggregating BERT sentiment data</span>
                </div>
            }
            else if (!sentimentStats.Any())
            {
                <div class="empty-state">No sentiment data available. Reviews will appear here once customers submit feedback.</div>
            }
            else
            {
                var displayStats = string.IsNullOrEmpty(selectedProductName)
                    ? sentimentStats
                    : sentimentStats.Where(s => s.ProductName == selectedProductName).ToList();

                if (!displayStats.Any())
                {
                    <div class="empty-state">No data for the selected product.</div>
                }
                else
                {
                    <div class="table-scroll">
                        <table class="table" id="sentiment-leaderboard-table">
                            <thead>
                                <tr>
                                    <th class="rank-col">#</th>
                                    <th>Product</th>
                                    <th class="num-col">Reviews</th>
                                    <th class="num-col">Avg. Rating</th>
                                    <th class="sentiment-col">Sentiment Distribution</th>
                                    <th class="num-col">Positive %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < displayStats.Count; i++)
                                {
                                    var stat = displayStats[i];
                                    double posPct = stat.TotalReviews > 0 ? (double)stat.Positive / stat.TotalReviews * 100 : 0;
                                    double neuPct = stat.TotalReviews > 0 ? (double)stat.Neutral  / stat.TotalReviews * 100 : 0;
                                    double negPct = stat.TotalReviews > 0 ? (double)stat.Negative / stat.TotalReviews * 100 : 0;

                                    <tr class="@(i % 2 == 1 ? "row-alt" : "")">
                                        <td><span class="rank-badge @(i < 3 ? "rank-top" : "")">@(i + 1)</span></td>
                                        <td class="product-name-cell">@stat.ProductName</td>
                                        <td class="num-col">@stat.TotalReviews</td>
                                        <td class="num-col rating-cell">
                                            <span>@stat.AverageRating.ToString("F1")</span>
                                            <span class="rating-star">★</span>
                                        </td>
                                        <td class="sentiment-col">
                                            <div class="mini-compound-bar">
                                                <div class="compound-seg seg-pos" style="width:@posPct.ToString("F1")%" title="Positive: @stat.Positive"></div>
                                                <div class="compound-seg seg-neu" style="width:@neuPct.ToString("F1")%" title="Neutral: @stat.Neutral"></div>
                                                <div class="compound-seg seg-neg" style="width:@negPct.ToString("F1")%" title="Negative: @stat.Negative"></div>
                                            </div>
                                            <div class="mini-counts">
                                                <span class="count-pos">+@stat.Positive</span>
                                                <span class="count-neu">~@stat.Neutral</span>
                                                <span class="count-neg">-@stat.Negative</span>
                                            </div>
                                        </td>
                                        <td class="num-col">
                                            <span class="pos-pct-badge @(posPct >= 70 ? "badge-high" : posPct >= 40 ? "badge-mid" : "badge-low")">
                                                @posPct.ToString("F0")%
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </section>

    <!-- ── Customer Reviews Feed ──────────────────────────────────── -->
    <section class="card">
        <div class="card-header">
            <div>
                <h2>Customer Reviews Feed</h2>
                <p class="card-subtitle">
                    @if (!string.IsNullOrEmpty(searchQuery) || sentimentFilter != "All" || !string.IsNullOrEmpty(selectedProductName))
                    {
                        <span>Showing @FilteredReviews.Count of @allReviews.Count reviews</span>
                    }
                    else
                    {
                        <span>Most recent @Math.Min(allReviews.Count, pageSize * currentPage) of @allReviews.Count reviews</span>
                    }
                </p>
            </div>
            @if (FilteredReviews.Any())
            {
                <span class="badge">@FilteredReviews.Count reviews</span>
            }
        </div>
        <div class="card-body">
            @if (isLoadingReviews)
            {
                <div class="loading-state">
                    <span class="spinner"></span>
                    <span>Loading customer reviews</span>
                </div>
            }
            else if (!FilteredReviews.Any())
            {
                <div class="empty-state">
                    @if (!string.IsNullOrEmpty(searchQuery) || sentimentFilter != "All")
                    {
                        <span>No reviews match the current filters. <button class="btn-link" @onclick="ResetFilters">Clear filters</button></span>
                    }
                    else
                    {
                        <span>No customer reviews have been submitted yet.</span>
                    }
                </div>
            }
            else
            {
                var pagedReviews = FilteredReviews
                    .OrderByDescending(r => r.CreatedAt)
                    .Take(pageSize * currentPage)
                    .ToList();

                <div class="reviews-feed" id="sentiment-reviews-feed">
                    @foreach (var review in pagedReviews)
                    {
                        <div class="review-card @GetSentimentClass(review.Sentiment)">
                            <!-- Avatar + Meta Row -->
                            <div class="review-meta-row">
                                <div class="review-avatar" aria-label="Customer @review.CustomerId">
                                    @GetAvatarInitials(review)
                                </div>
                                <div class="review-meta">
                                    <span class="review-customer">Customer #@review.CustomerId</span>
                                    <span class="review-product">@review.ProductName</span>
                                    <span class="review-date">@review.CreatedAt.ToLocalTime().ToString("dd MMM yyyy Â· hh:mm tt")</span>
                                </div>
                                <div class="review-right">
                                    <!-- Star Rating -->
                                    <div class="review-stars" aria-label="@review.Rating out of 5">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <span class="star-sm @(s <= review.Rating ? "star-full" : "star-empty")">★</span>
                                        }
                                    </div>
                                    <!-- Sentiment Badge -->
                                    <span class="sentiment-badge badge-@review.Sentiment.ToLower()">
                                        @GetSentimentEmoji(review.Sentiment) @review.Sentiment
                                    </span>
                                    @if (review.SentimentScore > 0)
                                    {
                                        <span class="confidence-tag">@((review.SentimentScore * 100).ToString("F1"))% conf.</span>
                                    }
                                </div>
                            </div>
                            <!-- Comment -->
                            @if (!string.IsNullOrWhiteSpace(review.Comment))
                            {
                                <p class="review-comment">"@review.Comment"</p>
                            }
                            else
                            {
                                <p class="review-comment review-no-comment">No written comment provided.</p>
                            }
                        </div>
                    }
                </div>

                <!-- Load More -->
                @if (FilteredReviews.Count > pageSize * currentPage)
                {
                    <div class="load-more-row">
                        <button id="sentiment-load-more-btn" class="btn btn-outline" @onclick="LoadMore">
                            Load More Reviews (@(FilteredReviews.Count - pageSize * currentPage) remaining)
                        </button>
                    </div>
                }
            }
        </div>
    </section>

</div>

@code {

    // ── Services ───────────────────────────────────────────────────────
    [Inject] private IReviewService ReviewService { get; set; } = default!;
    [Inject] private IBERTService   BertService   { get; set; } = default!;

    // ── Raw Data ───────────────────────────────────────────────────────
    private List<SentimentStatDto> sentimentStats = new();
    private List<ReviewDto>        allReviews     = new();

    // ── Filters ────────────────────────────────────────────────────────
    private string selectedProductName = string.Empty;
    private string sentimentFilter     = "All";
    private string searchQuery         = string.Empty;

    // ── Pagination ─────────────────────────────────────────────────────
    private int pageSize    = 10;
    private int currentPage = 1;

    // ── Loading / Status ───────────────────────────────────────────────
    private bool      isLoading;
    private bool      isLoadingReviews;
    private DateTime? lastRefreshed;
    private string?   statusMessage;
    private bool      isStatusSuccess;

    // ── Computed: Filtered Reviews ────────────────────────────────────
    private List<ReviewDto> FilteredReviews
    {
        get
        {
            var q = allReviews.AsEnumerable();

            if (!string.IsNullOrEmpty(selectedProductName))
                q = q.Where(r => r.ProductName == selectedProductName);

            if (sentimentFilter != "All")
                q = q.Where(r => string.Equals(r.Sentiment, sentimentFilter, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(searchQuery))
                q = q.Where(r => r.Comment.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

            return q.OrderByDescending(r => r.CreatedAt).ToList();
        }
    }

    // ── Computed: Overall KPIs ─────────────────────────────────────────
    private int TotalReviewCount   => sentimentStats.Sum(s => s.TotalReviews);
    private int TotalPositive      => sentimentStats.Sum(s => s.Positive);
    private int TotalNeutral       => sentimentStats.Sum(s => s.Neutral);
    private int TotalNegative      => sentimentStats.Sum(s => s.Negative);

    private double OverallPositivePct => TotalReviewCount > 0 ? (double)TotalPositive / TotalReviewCount * 100 : 0;
    private double OverallNeutralPct  => TotalReviewCount > 0 ? (double)TotalNeutral  / TotalReviewCount * 100 : 0;
    private double OverallNegativePct => TotalReviewCount > 0 ? (double)TotalNegative / TotalReviewCount * 100 : 0;
    private double OverallAvgRating   => sentimentStats.Any()
        ? sentimentStats.Sum(s => s.AverageRating * s.TotalReviews) / Math.Max(TotalReviewCount, 1)
        : 0;

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSentimentStatsAsync(), LoadReviewsAsync());
        lastRefreshed = DateTime.UtcNow;
    }

    // ── Data Loaders ──────────────────────────────────────────────────

    private async Task LoadSentimentStatsAsync()
    {
        isLoading = true;
        var result = await BertService.GetSentimentStats();
        if (result.Success && result.Data != null)
        {
            sentimentStats = result.Data;
        }
        else
        {
            sentimentStats = new();
            SetStatus(result.Message ?? "Failed to load sentiment statistics.", false);
        }
        isLoading = false;
    }

    private async Task LoadReviewsAsync()
    {
        isLoadingReviews = true;
        var result = await ReviewService.GetAll();
        if (result.Success && result.Data != null)
        {
            allReviews = result.Data;
        }
        else
        {
            allReviews = new();
            SetStatus(result.Message ?? "Failed to load reviews.", false);
        }
        isLoadingReviews = false;
    }

    // ── User Actions ──────────────────────────────────────────────────

    private async Task RefreshAllAsync()
    {
        ClearStatus();
        currentPage = 1;
        StateHasChanged();
        await Task.WhenAll(LoadSentimentStatsAsync(), LoadReviewsAsync());
        lastRefreshed = DateTime.UtcNow;
    }

    private void OnProductChange(ChangeEventArgs e)
    {
        selectedProductName = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
    }

    private void SetSentimentFilter(string filter)
    {
        sentimentFilter = filter;
        currentPage = 1;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
    }

    private void ClearSearch()
    {
        searchQuery = string.Empty;
        currentPage = 1;
    }

    private void LoadMore() => currentPage++;

    private void ResetFilters()
    {
        selectedProductName = string.Empty;
        sentimentFilter     = "All";
        searchQuery         = string.Empty;
        currentPage         = 1;
        ClearStatus();
    }

    private void SetStatus(string msg, bool success)
    {
        statusMessage   = msg;
        isStatusSuccess = success;
    }

    private void ClearStatus() => statusMessage = null;

    // ── Helpers ───────────────────────────────────────────────────────

    private static string GetSentimentClass(string sentiment) => sentiment?.ToLower() switch
    {
        "positive" => "review-positive",
        "negative" => "review-negative",
        "neutral"  => "review-neutral",
        _          => "review-neutral"
    };

    private static string GetSentimentEmoji(string sentiment) => sentiment?.ToLower() switch
    {
        "positive" => "😊",
        "negative" => "😟",
        "neutral"  => "",
        _          => ""
    };

    private static string GetAvatarInitials(ReviewDto review)
    {
        // Since CustomerName is not populated, derive a short code from CustomerId
        return $"C{review.CustomerId % 100:D2}";
    }
}

<style>

    /* â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*
       Sentiment Charts Page  -  SmartPOS+ Bakery Theme
       All colors reference tokens from wwwroot/css/colors.css
       â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â*â* */

    /* ── Semantic Color Variables (Sentiment-specific) ─────────────── */
    :root {
        --color-positive:    #5a7a52;   /* Sage green  -  harmonious with bakery palette */
        --color-positive-bg: #edf4eb;
        --color-neutral:     #8a7040;   /* Warm honey  -  accent warmth                  */
        --color-neutral-bg:  #fef6e4;
        --color-negative:    #8b4040;   /* Soft terracotta  -  warming red               */
        --color-negative-bg: #faeaea;
    }

    /* ── Page Shell ─────────────────────────────────────────────────── */
    .sentiment-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 1.75rem;
        background-color: var(--color-page-bg);
        color: var(--color-primary-text);
        min-height: 100vh;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    /* ── Page Header ───────────────────────────────────────────────── */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title h1 {
        margin: 0;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--color-heading-text);
        letter-spacing: -0.025em;
    }

    .page-title p {
        margin: 0.3rem 0 0;
        font-size: 0.9rem;
        color: var(--color-primary-text);
        opacity: 0.6;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .last-refreshed {
        font-size: 0.8rem;
        opacity: 0.5;
        color: var(--color-primary-text);
    }

    .icon-refresh {
        display: inline-block;
        transition: transform 0.45s ease;
        font-size: 1.1rem;
    }
    .btn-outline:hover:enabled .icon-refresh {
        transform: rotate(180deg);
    }

    /* ── Alerts ─────────────────────────────────────────────────────── */
    .alert {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.85rem 1.1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--color-border-accent);
        background-color: var(--color-card-bg);
        font-size: 0.9rem;
    }
    .alert-success { border-color: var(--color-accent); }
    .alert-error   { border-color: var(--color-navbar-bg); }

    /* ── Buttons ─────────────────────────────────────────────────────── */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 1.1rem;
        border-radius: 0.55rem;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1.5px solid transparent;
        line-height: 1.4;
        white-space: nowrap;
    }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-primary {
        background-color: var(--color-button-primary);
        color: var(--color-card-bg);
        border-color: var(--color-button-primary);
    }
    .btn-primary:hover:enabled {
