@code {
    /* ── Services ── */
    private List<ProductDto>  _filteredProducts = new();
    private List<CategoryDto> _categories       = new();

    /* ── UI State ── */
    private bool    _isLoading      = true;
    private string? _errorMessage;
    private string  _searchTerm     = string.Empty;
    private int     _selectedCategoryId = 0;   // 0 = All

    /* ── Cart State (in-component) ── */
    private List<CartItem> _cartItems = new();
    private bool           _showCart  = false;

    /* ── Modal State ── */
    private ProductDto? _selectedProduct;
    private bool        _showModal = false;
    private int         _modalQty  = 1;

    /* ══════════════════════════════════════════════
       LIFECYCLE
       ══════════════════════════════════════════════ */
    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadProducts();
    }

    /* ══════════════════════════════════════════════
       DATA LOADING
       ══════════════════════════════════════════════ */
    private async Task LoadCategories()
    {
        var result = await CategoryService.GetAll();
        if (result.Success && result.Data is not null)
            _categories = result.Data;
    }

    private async Task LoadProducts()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        ApiResponse<List<ProductDto>> result;

        if (!string.IsNullOrWhiteSpace(_searchTerm))
            result = await ProductService.Search(_searchTerm);
        else if (_selectedCategoryId > 0)
            result = await ProductService.GetByCategory(_selectedCategoryId);
        else
            result = await ProductService.GetAll();

        if (result.Success && result.Data is not null)
            _filteredProducts = result.Data.Where(p => p.IsActive).ToList();
        else
            _errorMessage = result.Message;

        _isLoading = false;
    }

    /* ══════════════════════════════════════════════
       SEARCH & FILTER
       ══════════════════════════════════════════════ */
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm         = e.Value?.ToString() ?? string.Empty;
        _selectedCategoryId = 0;   // reset category when searching
        await LoadProducts();
    }

    private async Task ClearSearch()
    {
        _searchTerm = string.Empty;
        await LoadProducts();
    }

    private async Task SelectCategory(int categoryId)
    {
        _selectedCategoryId = categoryId;
        _searchTerm         = string.Empty;
        await LoadProducts();
    }

    private async Task ResetFilters()
    {
        _selectedCategoryId = 0;
        _searchTerm         = string.Empty;
        await LoadProducts();
    }

    /* ══════════════════════════════════════════════
       MODAL
       ══════════════════════════════════════════════ */
    private void OpenModal(ProductDto product)
    {
        _selectedProduct = product;
        _modalQty        = 1;
        _showModal       = true;
    }

    private void CloseModal()
    {
        _showModal       = false;
        _selectedProduct = null;
        _modalQty        = 1;
    }

    private void AddFromModal()
    {
        if (_selectedProduct is null) return;
        AddToCart(_selectedProduct, _modalQty);
        CloseModal();
    }

    /* ══════════════════════════════════════════════
       CART
       ══════════════════════════════════════════════ */
    private void AddToCart(ProductDto product, int qty = 1)
    {
        var existing = _cartItems.FirstOrDefault(c => c.Product.Id == product.Id);
        if (existing is not null)
            existing.Quantity += qty;
        else
            _cartItems.Add(new CartItem { Product = product, Quantity = qty });

        _showCart = true;   // open cart drawer on add
    }

    private void RemoveFromCart(int productId)
        => _cartItems.RemoveAll(c => c.Product.Id == productId);

    private void UpdateQuantity(int productId, int delta)
    {
        var item = _cartItems.FirstOrDefault(c => c.Product.Id == productId);
        if (item is null) return;

        item.Quantity += delta;
        if (item.Quantity <= 0)
            _cartItems.Remove(item);
    }

    private void ClearCart()  => _cartItems.Clear();
    private void ToggleCart() => _showCart = !_showCart;

    private decimal CartTotal => _cartItems.Sum(c => c.Product.Price * c.Quantity);
    private int     CartCount => _cartItems.Sum(c => c.Quantity);

    /* ══════════════════════════════════════════════
       HELPERS
       ══════════════════════════════════════════════ */
    private static string StockLabel(int stock) => stock switch
    {
        0      => "Out of Stock",
        <= 5   => "Low Stock",
        _      => "In Stock"
    };

    private static string StockClass(int stock) => stock switch
    {
        0      => "stock-out",
        <= 5   => "stock-low",
        _      => "stock-in"
    };

    private static string TruncateDesc(string text, int max)
        => text.Length <= max ? text : text[..max].TrimEnd() + "…";

    /* ── Local cart item record ── */
    private sealed class CartItem
    {
        public ProductDto Product  { get; set; } = new();
        public int        Quantity { get; set; } = 1;
    }
}
