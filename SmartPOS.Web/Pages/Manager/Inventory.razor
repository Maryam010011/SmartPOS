@page "/manager/inventory"

@inject IInventoryService InventoryService
@inject IProductService ProductService

<PageTitle>Inventory Control</PageTitle>

<div class="sp-page p-4">
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="sp-heading h3 mb-1">Inventory Control</h1>
            <p class="sp-text-muted mb-0">Manage stock levels, restocking, and adjustments.</p>
        </div>
        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center gap-2 w-100 w-xl-auto">
            <div class="input-group">
                <span class="input-group-text sp-input-addon">Search</span>
                <InputText class="form-control sp-input" @bind-Value="SearchText" @bind-Value:event="oninput" placeholder="Search inventory..." />
            </div>
            <button class="btn sp-btn-outline" type="button" @onclick="ToggleLowStockFilter">
                @(ShowLowStockOnly ? "Show All Items" : "Filter Low Stock")
            </button>
            <button class="btn sp-btn-primary" type="button" @onclick="OpenCreateModal">Create New Entry</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert sp-alert mb-4" role="alert">
            <strong>Action failed.</strong> @ErrorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="alert sp-alert mb-4" role="alert">
            <strong>Success.</strong> @SuccessMessage
        </div>
    }

    <section class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="sp-heading h5 mb-0">Low Stock Alerts</h2>
            <span class="badge sp-badge-accent">@LowStockSummary</span>
        </div>

        @if (IsLoading)
        {
            <div class="sp-card p-4">
                <div class="d-flex align-items-center gap-2">
                    <div class="spinner-border sp-spinner" role="status"></div>
                    <span class="sp-text-muted">Loading inventory data...</span>
                </div>
            </div>
        }
        else if (LowStockItems.Count == 0)
        {
            <div class="sp-card p-4">
                <p class="mb-0 sp-text-muted">No low stock items were found.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in LowStockItems)
                {
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="sp-card p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="badge sp-badge-accent">Low Stock</span>
                                <span class="sp-text-muted small">@GetSku(item.ProductId)</span>
                            </div>
                            <h3 class="h6 sp-heading mt-2 mb-1">@item.ProductName</h3>
                            <p class="sp-text-muted small mb-0">@GetSupplier(item.ProductId)</p>
                            <div class="d-flex justify-content-between align-items-end mt-3">
                                <div>
                                    <div class="sp-text-muted small">Current Quantity</div>
                                    <div class="h5 mb-0 sp-accent-text">@item.Quantity</div>
                                </div>
                                <button class="btn sp-btn-primary btn-sm" type="button" @onclick="() => OpenRestockModal(item)">
                                    Restock Now
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="sp-card">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 sp-border-bottom">
            <h2 class="sp-heading h5 mb-0">Master Inventory Control</h2>
            <div class="d-flex gap-2">
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="ToggleLowStockFilter">
                    @(ShowLowStockOnly ? "Show All Items" : "Filter Low Stock")
                </button>
                <button class="btn sp-btn-primary btn-sm" type="button" @onclick="OpenCreateModal">Create New Entry</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table sp-table mb-0">
                <thead class="sp-table-head">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Product ID</th>
                        <th scope="col">Item Name</th>
                        <th scope="col">Current Stock</th>
                        <th scope="col">Reorder Level</th>
                        <th scope="col">Last Updated</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="7" class="p-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="spinner-border sp-spinner" role="status"></div>
                                    <span class="sp-text-muted">Loading inventory list...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (PagedItems.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="p-4">
                                <p class="mb-0 sp-text-muted">No inventory entries match the current filters.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        var index = 0;
                        foreach (var item in PagedItems)
                        {
                            <tr class="@GetRowClass(item, index++)">
                                <td>@item.Id</td>
                                <td>@item.ProductId</td>
                                <td>
                                    <div class="fw-semibold">@item.ProductName</div>
                                    <div class="sp-text-muted small">@GetSupplier(item.ProductId)</div>
                                </td>
                                <td>
                                    <span class="sp-stock">@item.Quantity</span>
                                    <span class="sp-text-muted small"> units</span>
                                    @if (item.IsLowStock)
                                    {
                                        <span class="badge sp-badge-accent ms-2">Low</span>
                                    }
                                </td>
                                <td>@item.ReorderLevel</td>
                                <td>@item.LastUpdated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        <button class="btn sp-btn-outline btn-sm" type="button" @onclick="() => OpenAdjustModal(item, 1)">Add</button>
                                        <button class="btn sp-btn-outline btn-sm" type="button" @onclick="() => OpenAdjustModal(item, -1)">Deduct</button>
                                        <button class="btn sp-btn-outline btn-sm" type="button" @onclick="() => OpenAdjustModal(item, 0)">Adjust</button>
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input sp-switch" type="checkbox" checked="@IsTracked(item.Id)" @onchange="(args) => ToggleTracked(item.Id, args)" />
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 sp-border-top">
            <p class="mb-0 sp-text-muted small">Showing @(PagedItems.Count) of @(FilteredItems.Count) entries</p>
            <div class="btn-group" role="group" aria-label="Inventory pagination">
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="PreviousPage" disabled="@IsFirstPage">Previous</button>
                @foreach (var page in PageNumbers)
                {
                    <button class="btn @(page == CurrentPage ? "sp-btn-primary" : "sp-btn-outline") btn-sm" type="button" @onclick="() => GoToPage(page)">
                        @(page)
                    </button>
                }
                <button class="btn sp-btn-outline btn-sm" type="button" @onclick="NextPage" disabled="@IsLastPage">Next</button>
            </div>
        </div>
    </section>
</div>

@if (IsAdjustModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content sp-card">
                <div class="modal-header sp-modal-header">
                    <div>
                        <h2 class="h5 sp-heading mb-0">@ModalTitle</h2>
                        <p class="sp-text-muted small mb-0">Record and confirm stock changes.</p>
                    </div>
                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="CloseAdjustModal">Close</button>
                </div>

                <EditForm Model="AdjustmentModel" OnValidSubmit="SubmitAdjustmentAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (IsCreateMode)
                        {
                            <div class="mb-3">
                                <label class="form-label sp-text-muted">Product</label>
                                <InputSelect class="form-select sp-input" @bind-Value="SelectedProductId">
                                    <option value="">Select a product...</option>
                                    @foreach (var product in Products)
                                    {
                                        <option value="@product.Id">@product.Name (@product.SKU)</option>
                                    }
                                </InputSelect>
                                @if (IsCreateMode && SelectedProductId is null)
                                {
                                    <div class="sp-validation small">Please select a product.</div>
                                }
                            </div>
                        }
                        else if (SelectedItem is not null)
                        {
                            <div class="sp-card p-3 mb-3">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                                    <div>
                                        <div class="fw-semibold">@SelectedItem.ProductName</div>
                                        <div class="sp-text-muted small">Product ID: @SelectedItem.ProductId</div>
                                        <div class="sp-text-muted small">@GetSupplier(SelectedItem.ProductId)</div>
                                    </div>
                                    <div class="text-md-end">
                                        <div class="sp-text-muted small">Current Quantity</div>
                                        <div class="h5 mb-0 sp-accent-text">@SelectedItem.Quantity</div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label sp-text-muted">@QuantityLabel</label>
                                <InputNumber class="form-control sp-input" @bind-Value="AdjustmentModel.QuantityChange" />
                                <ValidationMessage For="@(() => AdjustmentModel.QuantityChange)" class="sp-validation" />
                                <div class="sp-text-muted small mt-1">@QuantityHelpText</div>
                                @if (SelectedItem is not null && !IsCreateMode)
                                {
                                    <div class="sp-text-muted small mt-1">New quantity: <strong>@ComputedNewQuantity</strong></div>
                                }
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label sp-text-muted">Reason</label>
                                <InputSelect class="form-select sp-input" @bind-Value="AdjustmentModel.Reason">
                                    <option value="">Select reason...</option>
                                    @foreach (var reason in AdjustmentReasons)
                                    {
                                        <option value="@reason">@reason</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => AdjustmentModel.Reason)" class="sp-validation" />
                            </div>
                        </div>

                        @if (SelectedItem is not null && !IsCreateMode)
                        {
                            <div class="sp-card p-3 mt-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">Quick Deduct</div>
                                        <div class="sp-text-muted small">Maximum available: @SelectedItem.Quantity</div>
                                    </div>
                                    <div class="sp-text-muted small">Selected: @QuickDeductValue</div>
                                </div>
                                <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="DecreaseQuickDeduct" disabled="@IsQuickDeductMin">-</button>
                                    <button class="btn sp-btn-outline btn-sm" type="button" @onclick="IncreaseQuickDeduct" disabled="@IsQuickDeductMax">+</button>
                                    <button class="btn sp-btn-primary btn-sm" type="button" @onclick="ExecuteQuickDeductAsync" disabled="@IsQuickDeductDisabled">
                                        Execute Quick Deduct
                                    </button>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(QuickDeductMessage))
                                {
                                    <div class="sp-validation mt-2">@QuickDeductMessage</div>
                                }
                            </div>
                        }

                        <div class="mt-3">
                            <label class="form-label sp-text-muted">Adjustment Notes</label>
                            <InputTextArea class="form-control sp-input" @bind-Value="AdjustmentModel.Notes" rows="3" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(ModalErrorMessage))
                        {
                            <div class="sp-validation mt-3">@ModalErrorMessage</div>
                        }
                    </div>

                    <div class="modal-footer sp-modal-footer">
                        <button class="btn sp-btn-outline" type="button" @onclick="CloseAdjustModal" disabled="@IsSubmitting">Cancel</button>
                        <button class="btn sp-btn-primary" type="submit" disabled="@IsSubmitting">
                            @(IsSubmitting ? "Saving..." : "Confirm Adjustment")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="sp-modal-backdrop"></div>
}

<style>
    .sp-page {
        background-color: var(--color-page-bg);
        color: var(--color-primary-text);
        min-height: 100%;
    }

    .sp-heading {
        color: var(--color-heading-text);
    }

    .sp-text-muted {
        color: var(--color-primary-text);
        opacity: 0.7;
    }

    .sp-card {
        background-color: var(--color-card-bg);
        border: 1px solid var(--color-border-accent);
        border-radius: 0.5rem;
    }

    .sp-border-bottom {
        border-bottom: 1px solid var(--color-border-accent);
    }

    .sp-border-top {
        border-top: 1px solid var(--color-border-accent);
    }

    .sp-btn-primary {
        background-color: var(--color-button-primary);
        border-color: var(--color-button-primary);
        color: var(--color-page-bg);
    }

    .sp-btn-primary:hover,
    .sp-btn-primary:focus {
        background-color: var(--color-button-hover);
        border-color: var(--color-button-hover);
        color: var(--color-page-bg);
    }

    .sp-btn-outline {
        background-color: transparent;
        border-color: var(--color-border-accent);
        color: var(--color-primary-text);
    }

    .sp-btn-outline:hover,
    .sp-btn-outline:focus {
        background-color: var(--color-table-row-alt);
        border-color: var(--color-border-accent);
        color: var(--color-primary-text);
    }

    .sp-badge-accent {
        background-color: var(--color-badge);
        color: var(--color-page-bg);
    }

    .sp-accent-text {
        color: var(--color-accent);
    }

    .sp-input,
    .sp-input:focus,
    .sp-input-addon {
        background-color: var(--color-card-bg);
        border-color: var(--color-border-accent);
        color: var(--color-primary-text);
    }

    .sp-input::placeholder {
        color: var(--color-primary-text);
        opacity: 0.6;
    }

    .sp-input-addon {
        border-right: 0;
    }

    .sp-alert {
        background-color: var(--color-card-bg);
        border: 1px solid var(--color-border-accent);
        color: var(--color-primary-text);
    }

    .sp-table {
        color: var(--color-primary-text);
    }

    .sp-table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }

    .sp-table-head {
        background-color: var(--color-card-bg);
        border-bottom: 1px solid var(--color-border-accent);
    }

    .sp-table tbody tr {
        border-bottom: 1px solid var(--color-border-accent);
    }

    .sp-table-row-alt {
        background-color: var(--color-table-row-alt);
    }

    .sp-table-row {
        transition: background-color 0.2s ease;
    }

    .sp-table-row:hover {
        background-color: var(--color-table-row-alt);
    }

    .sp-row-muted {
        opacity: 0.6;
    }

    .sp-stock {
        font-weight: 600;
    }

    .sp-modal-header {
        background-color: var(--color-card-bg);
        border-bottom: 1px solid var(--color-border-accent);
    }

    .sp-modal-footer {
        background-color: var(--color-card-bg);
        border-top: 1px solid var(--color-border-accent);
    }

    .sp-modal-backdrop {
        position: fixed;
        inset: 0;
        background-color: color-mix(in srgb, var(--color-primary-text) 15%, transparent);
        z-index: 1040;
    }

    .sp-spinner {
        color: var(--color-accent);
    }

    .sp-validation {
        color: var(--color-accent);
        font-size: 0.85rem;
    }

    .sp-switch {
        border-color: var(--color-border-accent);
        background-color: var(--color-card-bg);
    }

    .sp-switch:checked {
        background-color: var(--color-accent);
        border-color: var(--color-accent);
    }
</style>

@code {
    private readonly List<string> AdjustmentReasons = new()
    {
        "Wastage / Spoiled",
        "Theft / Loss",
        "Count Discrepancy",
        "Customer Return",
        "Production Adjustment"
    };

    private List<InventoryDto> InventoryItems { get; set; } = new();
    private List<InventoryDto> LowStockItems { get; set; } = new();
    private List<ProductDto> Products { get; set; } = new();
    private Dictionary<int, ProductDto> ProductLookup { get; set; } = new();
    private Dictionary<int, bool> TrackedItems { get; } = new();

    private bool IsLoading { get; set; }
    private bool IsSubmitting { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }

    private string SearchText
    {
        get => _searchText;
        set
        {
            if (_searchText == value)
                return;

            _searchText = value;
            CurrentPage = 1;
        }
    }

    private string _searchText = string.Empty;
    private bool ShowLowStockOnly { get; set; }

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; } = 10;

    private bool IsAdjustModalOpen { get; set; }
    private bool IsCreateMode { get; set; }
    private InventoryDto? SelectedItem { get; set; }
    private int? SelectedProductId { get; set; }
    private AdjustmentFormModel AdjustmentModel { get; set; } = new();
    private string? ModalErrorMessage { get; set; }

    private int QuickDeductValue { get; set; } = 1;
    private string? QuickDeductMessage { get; set; }

    private IReadOnlyList<InventoryDto> FilteredItems
        => InventoryItems
            .Where(item => MatchesSearch(item))
            .Where(item => !ShowLowStockOnly || item.IsLowStock)
            .OrderBy(item => item.ProductName)
            .ToList();

    private IReadOnlyList<InventoryDto> PagedItems
        => FilteredItems
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredItems.Count / (double)PageSize));
    private bool IsFirstPage => CurrentPage <= 1;
    private bool IsLastPage => CurrentPage >= TotalPages;

    private IEnumerable<int> PageNumbers => Enumerable.Range(1, TotalPages);

    private string LowStockSummary => $"{LowStockItems.Count} Items";

    private string ModalTitle => IsCreateMode ? "Create Inventory Entry" : "Adjust Stock";
    private string QuantityLabel => IsCreateMode ? "Set Quantity" : "Change Quantity";
    private string QuantityHelpText => IsCreateMode ? "Set the starting stock level." : "Use positive or negative values to adjust stock.";
    private int ComputedNewQuantity => SelectedItem is null ? 0 : SelectedItem.Quantity + AdjustmentModel.QuantityChange;

    private bool IsQuickDeductMax => SelectedItem is null || QuickDeductValue >= SelectedItem.Quantity;
    private bool IsQuickDeductMin => QuickDeductValue <= 1;
    private bool IsQuickDeductDisabled => SelectedItem is null || QuickDeductValue <= 0 || IsSubmitting;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var inventoryTask = InventoryService.GetAll();
            var lowStockTask = InventoryService.GetLowStock();
            var productTask = ProductService.GetAll();

            await Task.WhenAll(inventoryTask, lowStockTask, productTask);

            var inventoryResponse = await inventoryTask;
            var lowStockResponse = await lowStockTask;
            var productResponse = await productTask;

            if (!inventoryResponse.Success)
            {
                ErrorMessage = inventoryResponse.Message;
                InventoryItems = new();
            }
            else
            {
                InventoryItems = inventoryResponse.Data ?? new();
            }

            if (!lowStockResponse.Success)
            {
                ErrorMessage = lowStockResponse.Message;
                LowStockItems = new();
            }
            else
            {
                LowStockItems = lowStockResponse.Data ?? new();
            }

            if (!productResponse.Success)
            {
                ErrorMessage = productResponse.Message;
                Products = new();
            }
            else
            {
                Products = productResponse.Data ?? new();
                ProductLookup = Products.ToDictionary(product => product.Id);
            }

            foreach (var item in InventoryItems)
            {
                if (!TrackedItems.ContainsKey(item.Id))
                {
                    TrackedItems[item.Id] = true;
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error loading inventory: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private bool MatchesSearch(InventoryDto item)
    {
        if (string.IsNullOrWhiteSpace(SearchText))
            return true;

        var term = SearchText.Trim();
        return item.ProductName.Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.ProductId.ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.Id.ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
            || GetSku(item.ProductId).Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private void ToggleLowStockFilter()
    {
        ShowLowStockOnly = !ShowLowStockOnly;
        CurrentPage = 1;
    }

    private string GetSku(int productId)
        => ProductLookup.TryGetValue(productId, out var product) ? product.SKU : "SKU Not Available";

    private string GetSupplier(int productId)
        => ProductLookup.TryGetValue(productId, out var product) ? product.SupplierName : "Supplier Not Available";

    private void OpenCreateModal()
    {
        IsCreateMode = true;
        SelectedItem = null;
        SelectedProductId = null;
        AdjustmentModel = new AdjustmentFormModel();
        ModalErrorMessage = null;
        QuickDeductValue = 1;
        QuickDeductMessage = null;
        IsAdjustModalOpen = true;
    }

    private void OpenAdjustModal(InventoryDto item, int initialDelta)
    {
        IsCreateMode = false;
        SelectedItem = item;
        SelectedProductId = item.ProductId;
        AdjustmentModel = new AdjustmentFormModel
        {
            QuantityChange = initialDelta
        };
        ModalErrorMessage = null;
        QuickDeductValue = Math.Min(1, item.Quantity);
        QuickDeductMessage = null;
        IsAdjustModalOpen = true;
    }

    private void OpenRestockModal(InventoryDto item)
    {
        var restockAmount = Math.Max(item.ReorderLevel - item.Quantity, 1);
        OpenAdjustModal(item, restockAmount);
    }

    private void CloseAdjustModal()
    {
        IsAdjustModalOpen = false;
        ModalErrorMessage = null;
        QuickDeductMessage = null;
    }

    private async Task SubmitAdjustmentAsync()
    {
        if (IsSubmitting)
            return;

        ModalErrorMessage = null;
        ErrorMessage = null;
        SuccessMessage = null;

        var productId = IsCreateMode ? SelectedProductId : SelectedItem?.ProductId;
        if (productId is null or 0)
        {
            ModalErrorMessage = "Please select a product.";
            return;
        }

        var targetQuantity = IsCreateMode
            ? AdjustmentModel.QuantityChange
            : (SelectedItem?.Quantity ?? 0) + AdjustmentModel.QuantityChange;

        if (AdjustmentModel.QuantityChange == 0)
        {
            ModalErrorMessage = "Please enter a quantity change.";
            return;
        }

        if (targetQuantity < 0)
        {
            ModalErrorMessage = "Stock level cannot be negative.";
            return;
        }

        var reasonText = AdjustmentModel.Reason;
        if (!string.IsNullOrWhiteSpace(AdjustmentModel.Notes))
        {
            reasonText = $"{reasonText}: {AdjustmentModel.Notes}";
        }

        IsSubmitting = true;

        try
        {
            var response = await InventoryService.AdjustStock(new AdjustStockDto
            {
                ProductId = productId.Value,
                Quantity = targetQuantity,
                Reason = reasonText
            });

            if (!response.Success)
            {
                ModalErrorMessage = response.Message;
                return;
            }

            SuccessMessage = response.Message;
            CloseAdjustModal();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ModalErrorMessage = $"Failed to adjust stock: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void IncreaseQuickDeduct()
    {
        if (SelectedItem is null)
            return;

        if (QuickDeductValue < SelectedItem.Quantity)
        {
            QuickDeductValue++;
        }
    }

    private void DecreaseQuickDeduct()
    {
        if (QuickDeductValue > 1)
        {
            QuickDeductValue--;
        }
    }

    private async Task ExecuteQuickDeductAsync()
    {
        if (SelectedItem is null)
            return;

        QuickDeductMessage = null;

        if (QuickDeductValue <= 0 || QuickDeductValue > SelectedItem.Quantity)
        {
            QuickDeductMessage = "Quick deduct value is out of range.";
            return;
        }

        if (string.IsNullOrWhiteSpace(AdjustmentModel.Reason))
        {
            QuickDeductMessage = "Please select a reason before executing.";
            return;
        }

        AdjustmentModel.QuantityChange = -QuickDeductValue;
        await SubmitAdjustmentAsync();
    }

    private string GetRowClass(InventoryDto item, int index)
    {
        var classes = new List<string> { "sp-table-row" };

        if (index % 2 == 1)
        {
            classes.Add("sp-table-row-alt");
        }

        if (!IsTracked(item.Id))
        {
            classes.Add("sp-row-muted");
        }

        return string.Join(" ", classes);
    }

    private bool IsTracked(int inventoryId)
        => TrackedItems.TryGetValue(inventoryId, out var tracked) && tracked;

    private void ToggleTracked(int inventoryId, ChangeEventArgs args)
    {
        if (args.Value is bool isTracked)
        {
            TrackedItems[inventoryId] = isTracked;
        }
    }

    private void PreviousPage()
    {
        if (!IsFirstPage)
        {
            CurrentPage--;
        }
    }

    private void NextPage()
    {
        if (!IsLastPage)
        {
            CurrentPage++;
        }
    }

    private void GoToPage(int page)
    {
        CurrentPage = Math.Clamp(page, 1, TotalPages);
    }

    private sealed class AdjustmentFormModel
    {
        [Range(-100000, 100000, ErrorMessage = "Enter a valid quantity adjustment.")]
        public int QuantityChange { get; set; }

        [Required(ErrorMessage = "Reason is required.")]
        public string Reason { get; set; } = string.Empty;

        public string Notes { get; set; } = string.Empty;
    }
}
