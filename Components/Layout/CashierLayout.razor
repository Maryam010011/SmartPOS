@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager


<NavBar />

@if (IsAuthorized)
{
    <div class="layout-wrapper">
        <aside class="sidebar">
            <nav class="sidebar-nav">
                <NavLink class="nav-item" href="/cashier/pos" Match="NavLinkMatch.Prefix">
                    🖥 <span>POS Terminal</span>
                </NavLink>
                <NavLink class="nav-item" href="/cashier/sales-history" Match="NavLinkMatch.Prefix">
                    📜 <span>Sales History</span>
                </NavLink>
                <NavLink class="nav-item" href="/cashier/customer-lookup" Match="NavLinkMatch.Prefix">
                    👤 <span>Customer Lookup</span>
                </NavLink>
            </nav>
        </aside>
        <main class="main-content">
            @Body
        </main>
    </div>
    <Footer />
}
else
{
    <div class="container py-5 text-center">
        <h2 class="text-danger">Access Denied</h2>
        <p>You need Cashier or higher privileges to view this page.</p>
        <a href="/login" class="btn btn-burnt-orange">Sign In</a>
    </div>
}

@code {
    private bool IsAuthorized;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !IsAuthorized)
        {
            await CheckAuthAsync();
            StateHasChanged();
        }
    }

    private async Task CheckAuthAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (!user.Identity?.IsAuthenticated ?? true)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        if (!user.IsInRole("Cashier") && !user.IsInRole("Manager") && !user.IsInRole("Admin"))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        IsAuthorized = true;
    }
}
