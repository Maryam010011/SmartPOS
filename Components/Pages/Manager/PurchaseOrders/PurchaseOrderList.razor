@page "/manager/purchase-orders"
@using SmartPOS.Shared.DTOs.PurchaseOrders
@using SmartPOS.Shared.DTOs.Suppliers
@using SmartPOS.Shared.DTOs.Users
@using SmartPOS.Shared.Enums
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.Common
@inject IPurchaseOrderService PurchaseOrderService
@inject ISupplierService SupplierService
@inject IUserService UserService
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <!-- Toast -->
    @if (!string.IsNullOrEmpty(ToastMessage))
    {
        <div class="toast-container-pos">
            <div class="toast-pos toast-@ToastType">
                <span class="toast-icon">
                    @(ToastType == "success" ? "âœ…" : ToastType == "error" ? "âŒ" : "â„¹ï¸")
                </span>
                <span class="toast-body">@ToastMessage</span>
                <button class="toast-close" @onclick="DismissToast">&times;</button>
            </div>
        </div>
    }

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Purchase Orders</h2>
            <p class="text-muted m-0">Manage purchase orders, track deliveries, and receive stock.</p>
        </div>
        <button type="button" class="btn btn-burnt-orange d-flex align-items-center gap-2" @onclick="OpenCreateWizard">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
            </svg>
            <span>Create Purchase Order</span>
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--color-button-primary);" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2">Loading purchase orders...</p>
        </div>
    }
    else
    {
        <!-- Filters -->
        <div class="card card-pos mb-4">
            <div class="card-body p-3">
                <div class="row g-3 align-items-start">
                    <div class="col-md-2">
                        <label class="form-label text-secondary small fw-semibold">Status</label>
                        <select class="form-select" @bind="StatusFilter">
                            <option value="">All Status</option>
                            <option value="Draft">Draft</option>
                            <option value="Sent">Sent</option>
                            <option value="Received">Received</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-secondary small fw-semibold">Supplier</label>
                        <select class="form-select" @bind="SupplierFilter">
                            <option value="">All Suppliers</option>
                            @if (AllSuppliers != null)
                            {
                                @foreach (var s in AllSuppliers.OrderBy(x => x.Name))
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-secondary small fw-semibold">From Date</label>
                        <input type="date" class="form-control" @bind="DateFrom" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-secondary small fw-semibold">To Date</label>
                        <input type="date" class="form-control" @bind="DateTo" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button class="btn btn-outline-secondary btn-sm fw-semibold" @onclick="ApplyFilters">
                            Apply Filters
                        </button>
                        <button class="btn btn-link btn-sm fw-semibold text-muted" @onclick="ClearFilters">
                            Clear
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Purchase Orders Table -->
        <div class="card card-pos">
            <div class="card-body p-0">
                @if (FilteredOrders == null || !FilteredOrders.Any())
                {
                    <div class="text-center py-5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="text-muted mb-3" viewBox="0 0 16 16">
                            <path d="M3 4.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5zM5 6v1h6V6zm0 2v1h4V8zm0 2v1h6v-1z"/>
                            <path d="M2 2a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1zm0 1h12v10H2z"/>
                        </svg>
                        <p class="text-muted fw-semibold mb-1">No purchase orders found</p>
                        <p class="text-muted small m-0">Try adjusting your filter criteria or create a new purchase order.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-pos align-middle m-0 table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th style="padding-left: 20px;">PO #</th>
                                    <th>Supplier</th>
                                    <th>Created By</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th class="text-center">Items</th>
                                    <th class="text-end">Total Cost</th>
                                    <th class="text-end" style="padding-right: 20px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var po in FilteredOrders)
                                {
                                    var user = GetUser(po.UserId);
                                    <tr>
                                        <td style="padding-left: 20px;">
                                            <span class="fw-bold text-dark">#@po.Id</span>
                                        </td>
                                        <td>
                                            <span class="text-dark">@po.SupplierName</span>
                                        </td>
                                        <td>
                                            <span class="text-muted small">@(user?.Name ?? $"User #{po.UserId}")</span>
                                        </td>
                                        <td>
                                            <span class="text-muted small">@po.OrderDate.ToString("dd MMM yyyy")</span>
                                        </td>
                                        <td>
                                            @GetStatusBadge(po.Status)
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-semibold">@po.LineItems.Count</span>
                                        </td>
                                        <td class="text-end fw-semibold">
                                            Rs @po.TotalCost.ToString("N2")
                                        </td>
                                        <td class="text-end" style="padding-right: 20px;">
                                            <div class="dropdown">
                                                <button class="btn btn-light btn-sm border dropdown-toggle fw-semibold" type="button" data-bs-toggle="dropdown">
                                                    Manage
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                                    <li>
                                                        <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => OpenDetail(po)">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/></svg>
                                                            <span>View Details</span>
                                                        </button>
                                                    </li>
                                                    @if (po.Status == POStatus.Draft)
                                                    {
                                                        <li>
                                                            <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => MarkAsSent(po)">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/></svg>
                                                                <span>Mark as Sent</span>
                                                            </button>
                                                        </li>
                                                    }
                                                    @if (po.Status == POStatus.Draft || po.Status == POStatus.Sent)
                                                    {
                                                        <li>
                                                            <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => MarkAsReceived(po)">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0"/><path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2zm10-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1"/></svg>
                                                                <span>Mark as Received</span>
                                                            </button>
                                                        </li>
                                                    }
                                                    @if (po.Status == POStatus.Draft || po.Status == POStatus.Sent)
                                                    {
                                                        <li><hr class="dropdown-divider"></li>
                                                        <li>
                                                            <button class="dropdown-item text-danger d-flex align-items-center gap-2" @onclick="() => PromptCancel(po)">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/></svg>
                                                                <span>Cancel PO</span>
                                                            </button>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Cancel Confirmation Modal -->
    @if (CancelTarget != null)
    {
        <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content card-pos border border-danger-subtle">
                    <div class="modal-header border-bottom-0 pb-0">
                        <h5 class="modal-title fw-bold text-danger">Cancel Purchase Order</h5>
                        <button type="button" class="btn-close" @onclick="CancelCancel"></button>
                    </div>
                    <div class="modal-body py-3">
                        <p class="m-0 text-dark">
                            Are you sure you want to cancel PO <strong>#@CancelTarget.Id</strong> from <strong>@CancelTarget.SupplierName</strong>?
                        </p>
                        <p class="text-muted small mt-2 m-0 border-start border-3 ps-2 border-danger-subtle">
                            This action cannot be undone.
                        </p>
                    </div>
                    <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                        <button class="btn btn-outline-secondary" @onclick="CancelCancel">Keep</button>
                        <button class="btn btn-danger px-4 fw-bold text-white" @onclick="ConfirmCancel" disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                                <span>Cancelling...</span>
                            }
                            else
                            {
                                <span>Yes, Cancel PO</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show modal-backdrop-pos"></div>
    }

    <!-- Create PO Wizard -->
    <CreatePOWizard @ref="WizardRef" OnSave="ReloadOrders" />

    <!-- PO Detail Modal -->
    <PODetailModal @ref="DetailModalRef" OnStatusChanged="ReloadOrders" />
</div>

@code {
    private List<PurchaseOrderDto>? AllOrders;
    private List<PurchaseOrderDto>? FilteredOrders;
    private List<SupplierDto>? AllSuppliers;
    private Dictionary<int, UserDto>? UserLookup;
    private bool IsLoading = true;
    private bool IsSaving;

    private string StatusFilter = string.Empty;
    private string SupplierFilter = string.Empty;
    private DateTime? DateFrom;
    private DateTime? DateTo;

    private string ToastMessage = string.Empty;
    private string ToastType = "success";

    private CreatePOWizard? WizardRef;
    private PODetailModal? DetailModalRef;
    private PurchaseOrderDto? CancelTarget;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var poTask = PurchaseOrderService.GetAll();
            var supTask = SupplierService.GetAll();
            var userTask = UserService.GetAllUsers(new UserFilterDto { PageSize = 100 });

            await Task.WhenAll(poTask, supTask, userTask);

            var poResult = await poTask;
            if (poResult.Success && poResult.Data != null)
                AllOrders = poResult.Data;
            else
                AllOrders = new List<PurchaseOrderDto>();

            var supResult = await supTask;
            if (supResult.Success && supResult.Data != null)
                AllSuppliers = supResult.Data;
            else
                AllSuppliers = new List<SupplierDto>();

            var userResult = await userTask;
            if (userResult.Success && userResult.Data != null)
                UserLookup = userResult.Data.ToDictionary(u => u.Id, u => u);
            else
                UserLookup = new Dictionary<int, UserDto>();

            ApplyFiltersToList();
        }
        catch
        {
            AllOrders = new List<PurchaseOrderDto>();
            AllSuppliers = new List<SupplierDto>();
            UserLookup = new Dictionary<int, UserDto>();
            FilteredOrders = new List<PurchaseOrderDto>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private UserDto? GetUser(int userId)
    {
        if (UserLookup != null && UserLookup.TryGetValue(userId, out var user))
            return user;
        return null;
    }

    private void ApplyFiltersToList()
    {
        if (AllOrders == null)
        {
            FilteredOrders = new List<PurchaseOrderDto>();
            return;
        }

        var query = AllOrders.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(StatusFilter))
        {
            if (Enum.TryParse<POStatus>(StatusFilter, out var status))
                query = query.Where(o => o.Status == status);
        }

        if (!string.IsNullOrWhiteSpace(SupplierFilter) && int.TryParse(SupplierFilter, out var supId))
            query = query.Where(o => o.SupplierId == supId);

        if (DateFrom.HasValue)
        {
            var from = DateFrom.Value.Date;
            query = query.Where(o => o.OrderDate >= from);
        }

        if (DateTo.HasValue)
        {
            var to = DateTo.Value.Date.AddDays(1);
            query = query.Where(o => o.OrderDate < to);
        }

        FilteredOrders = query.OrderByDescending(o => o.OrderDate).ToList();
    }

    private async Task ApplyFilters()
    {
        ApplyFiltersToList();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        StatusFilter = string.Empty;
        SupplierFilter = string.Empty;
        DateFrom = null;
        DateTo = null;
        ApplyFiltersToList();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task ReloadOrders() => await LoadData();

    private async Task OpenCreateWizard()
    {
        if (WizardRef != null)
            await WizardRef.Open();
    }

    private async Task OpenDetail(PurchaseOrderDto po)
    {
        if (DetailModalRef != null)
            await DetailModalRef.Open(po.Id);
    }

    private async Task MarkAsSent(PurchaseOrderDto po)
    {
        // No API for "Mark as Sent" â€” placeholder: show toast
        ShowToast("info", "Mark as Sent would be implemented here.");
        await Task.CompletedTask;
    }

    private async Task MarkAsReceived(PurchaseOrderDto po)
    {
        if (DetailModalRef != null)
            await DetailModalRef.Open(po.Id);
    }

    private void PromptCancel(PurchaseOrderDto po) => CancelTarget = po;
    private void CancelCancel() => CancelTarget = null;

    private async Task ConfirmCancel()
    {
        if (CancelTarget == null) return;

        IsSaving = true;
        StateHasChanged();

        try
        {
            var response = await PurchaseOrderService.Cancel(CancelTarget.Id);
            if (response.Success)
            {
                CancelTarget = null;
                ShowToast("success", "Purchase order cancelled.");
                await ReloadOrders();
            }
            else
            {
                ShowToast("error", response.Message);
            }
        }
        catch
        {
            ShowToast("error", "Failed to cancel purchase order.");
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private MarkupString GetStatusBadge(POStatus status)
    {
        var (text, color, bg) = status switch
        {
            POStatus.Draft => ("Draft", "#6c757d", "rgba(108, 117, 125, 0.15)"),
            POStatus.Sent => ("Sent", "#0d6efd", "rgba(13, 110, 253, 0.15)"),
            POStatus.Received => ("Received", "#198754", "rgba(25, 135, 84, 0.15)"),
            POStatus.Cancelled => ("Cancelled", "#dc3545", "rgba(220, 53, 69, 0.15)"),
            _ => ("Unknown", "#6c757d", "rgba(108, 117, 125, 0.15)")
        };
        return (MarkupString)$"<span class=\"badge px-2 py-1.5 rounded-pill\" style=\"background-color: {bg}; color: {color}; border: 1px solid {color}33;\">â— {text}</span>";
    }

    private void DismissToast() => ToastMessage = string.Empty;
    private void ShowToast(string type, string msg) { ToastType = type; ToastMessage = msg; StateHasChanged(); }
}
