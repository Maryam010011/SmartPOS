@page "/admin/customers"
@using SmartPOS.Shared.DTOs.Customers
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.Common
@inject ICustomerService CustomerService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <!-- Toast -->
    @if (!string.IsNullOrEmpty(ToastMessage))
    {
        <div class="toast-container-pos">
            <div class="toast-pos toast-@ToastType">
                <span class="toast-icon">
                    @switch (ToastType)
                    {
                        case "success": <text>✅</text>; break;
                        case "error": <text>❌</text>; break;
                        default: <text>ℹ️</text>; break;
                    }
                </span>
                <span class="toast-body">@ToastMessage</span>
                <button class="toast-close" @onclick="DismissToast">&times;</button>
            </div>
        </div>
    }

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Customer Management</h2>
            <p class="text-muted m-0">View, add, edit, and manage bakery customer accounts and loyalty points.</p>
        </div>
        <button type="button" class="btn btn-burnt-orange d-flex align-items-center gap-2" @onclick="OpenAddModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
            </svg>
            <span>Add Customer</span>
        </button>
    </div>

    <!-- Filters -->
    <div class="card card-pos mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-start">
                <div class="col-md-3">
                    <label class="form-label text-secondary small fw-semibold">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 ps-0" placeholder="Name, email or phone..."
                               @bind-value="SearchTerm" @bind-value:event="oninput" @onkeyup="HandleSearch" />
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Registered From</label>
                    <input type="date" class="form-control" @bind="DateFrom" @bind:after="ReloadCustomers" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Registered To</label>
                    <input type="date" class="form-control" @bind="DateTo" @bind:after="ReloadCustomers" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Min Spend (Rs)</label>
                    <input type="number" class="form-control" placeholder="0" @bind="MinSpend" @bind:after="ReloadCustomers" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Max Spend (Rs)</label>
                    <input type="number" class="form-control" placeholder="999999" @bind="MaxSpend" @bind:after="ReloadCustomers" />
                </div>
                <div class="col-md-1 d-flex flex-column gap-1">
                    <label class="form-label text-secondary small fw-semibold">Status</label>
                    <select class="form-select" @bind="StatusFilter" @bind:after="ReloadCustomers">
                        <option value="">All</option>
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12 d-flex justify-content-end">
                    <button class="btn btn-outline-secondary btn-sm fw-semibold" @onclick="ResetFilters">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card card-pos">
        <div class="card-body p-0">
            @if (IsLoading)
            {
                <div class="d-flex justify-content-center align-items-center py-5 my-5 flex-column gap-3">
                    <div class="spinner-border" style="width: 3rem; height: 3rem; color: var(--color-button-primary) !important;" role="status"></div>
                    <span class="fw-semibold text-secondary">Loading customers...</span>
                </div>
            }
            else if (Customers == null || !Customers.Any())
            {
                <div class="text-center py-5 my-5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-secondary mb-3" viewBox="0 0 16 16">
                        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.274-.1-3.41-4.793-3.41C.851 9.586 0 11.2 0 12.996C0 13.996 1 14 1 14zM11 3.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0M4.5 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/>
                    </svg>
                    <h5 class="fw-bold text-dark">No Customers Found</h5>
                    <p class="text-muted small">No customers match the current filter criteria.</p>
                    <button class="btn btn-burnt-orange btn-sm mt-2 px-4" @onclick="ResetFilters">Reset Filters</button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-pos align-middle m-0 table-hover">
                        <thead class="table-light">
                            <tr>
                                <th style="padding-left: 20px;">Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th style="width: 100px;" class="text-center">Orders</th>
                                <th style="width: 130px;" class="text-end">Total Spent</th>
                                <th style="width: 110px;" class="text-center">Loyalty Pts</th>
                                <th style="width: 90px;">Status</th>
                                <th class="text-end" style="padding-right: 20px; width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Customers)
                            {
                                <tr class="@(c.IsActive ? "" : "opacity-50")">
                                    <td style="padding-left: 20px;">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-circle-sm" style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--color-button-primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; flex-shrink: 0;">
                                                @GetInitials(c.Name)
                                            </div>
                                            <span class="fw-bold text-dark">@c.Name</span>
                                        </div>
                                    </td>
                                    <td>@c.Email</td>
                                    <td class="small">@c.Phone</td>
                                    <td class="text-center fw-semibold">@c.TotalOrders</td>
                                    <td class="text-end fw-semibold">Rs @c.TotalSpent.ToString("N0")</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill @(c.LoyaltyPoints > 0 ? "bg-dark" : "bg-secondary") px-3 py-2 fw-bold">
                                            @c.LoyaltyPoints
                                        </span>
                                    </td>
                                    <td>
                                        @if (c.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 rounded-pill">● Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1.5 rounded-pill">● Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end" style="padding-right: 20px;">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm border dropdown-toggle fw-semibold" type="button" data-bs-toggle="dropdown">
                                                Manage
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => ViewProfile(c.Id)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0"/><path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8m8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/></svg>
                                                        <span>View Profile</span>
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => OpenEditModal(c)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.5-.5V9h-.5a.5.5 0 0 1-.5-.5v-.5a.5.5 0 0 1 .146-.354l6-6a.5.5 0 0 1 .708 0l3.75 3.75a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.354.146z"/></svg>
                                                        <span>Edit Customer</span>
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => OpenLoyaltyModal(c)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1m3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4z"/></svg>
                                                        <span>Adjust Loyalty Points</span>
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    @if (c.IsActive)
                                                    {
                                                        <button class="dropdown-item text-warning d-flex align-items-center gap-2" @onclick="() => PromptDeactivate(c)">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1.093 3.093c-.496 1.46-.707 2.71-.728 3.74-.022 1.01.125 1.91.432 2.658A13 13 0 0 0 2.52 11.53c1.678 2.195 3.061 5.513 2.465 9.99a1.54 1.54 0 0 0 1.044 1.263 62 62 0 0 0 2.887.87c.307.085.6.14.887.165.289-.026.58-.08.887-.165a62 62 0 0 0 2.887-.87 1.54 1.54 0 0 0 1.044-1.263c.277-2.073-.105-3.83-.715-5.32l-1.39-1.39c.64 1.47 1.002 3.1 1.002 4.965 0 .87-.12 1.493-.306 1.95a12.8 12.8 0 1 1-2.517 2.453c-.28.132-.581.24-.829.24s-.548-.108-.829-.24A12.8 12.8 0 0 1 4.5 12.996c0-1.865.362-3.495 1.002-4.965z"/><path d="M14.907 13.5a8 8 0 1 0-8 8 8 8 0 0 0 8-8m-8 6.5a6.5 6.5 0 1 1 6.5-6.5 6.5 6.5 0 1 1-6.5 6.5"/></svg>
                                                            <span>Deactivate</span>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="dropdown-item text-success d-flex align-items-center gap-2" @onclick="() => ReactivateCustomer(c)">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1 8a7 7 0 1 0 14 0A7 7 0 0 0 1 8zm15 0A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-6.646-2.646a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L11.293 9H3.5a.5.5 0 0 1 0-1h7.793l-1.939-1.939a.5.5 0 0 1 0-.708z"/></svg>
                                                            <span>Reactivate</span>
                                                        </button>
                                                    }
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Pagination -->
    @if (!IsLoading && Customers != null && Customers.Any())
    {
        <div class="d-flex justify-content-between align-items-center mt-4">
            <span class="text-secondary small fw-semibold">Page @CurrentPage</span>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link border rounded fw-bold text-dark px-3" @onclick="PreviousPage">Previous</button>
                    </li>
                    <li class="page-item active">
                        <span class="page-link rounded px-3 fw-bold" style="background-color: var(--color-button-primary); border-color: var(--color-button-primary);">@CurrentPage</span>
                    </li>
                    <li class="page-item @(Customers.Count < PageSize ? "disabled" : "")">
                        <button class="page-link border rounded fw-bold text-dark px-3" @onclick="NextPage">Next</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modals -->
<CustomerFormModal @ref="FormModal" OnSave="ReloadCustomers" />
<LoyaltyModal @ref="LoyaltyModalRef" OnSave="ReloadCustomers" />

<!-- Deactivate Confirmation Modal -->
@if (DeactivateTarget != null)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content card-pos border border-warning-subtle">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-warning">Deactivate Customer</h5>
                    <button type="button" class="btn-close" @onclick="CancelDeactivate"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="m-0 text-dark">
                        Are you sure you want to deactivate <strong>@DeactivateTarget.Name</strong>?
                    </p>
                    <p class="text-muted small mt-2 m-0 border-start border-3 ps-2 border-warning-subtle">
                        They will be hidden from customer lists and unable to earn or redeem loyalty points.
                    </p>
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                    <button class="btn btn-outline-secondary" @onclick="CancelDeactivate">Cancel</button>
                    <button class="btn btn-warning px-4 fw-bold text-white" @onclick="ConfirmDeactivate" disabled="@IsSaving">
                        @if (IsSaving) { <span class="spinner-border spinner-border-sm"></span> }
                        else { <span>Deactivate</span> }
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show modal-backdrop-pos"></div>
}

@code {
    private List<CustomerRowDto>? Customers { get; set; }
    private bool IsLoading = true;
    private bool IsSaving;
    private int CurrentPage = 1;
    private const int PageSize = 10;

    // Filters
    private string SearchTerm = string.Empty;
    private DateTime? DateFrom;
    private DateTime? DateTo;
    private decimal? MinSpend;
    private decimal? MaxSpend;
    private string? StatusFilter = "";

    // Toast
    private string ToastMessage = string.Empty;
    private string ToastType = "success";

    // Modal refs
    private CustomerFormModal? FormModal;
    private LoyaltyModal? LoyaltyModalRef;

    // Deactivate
    private CustomerRowDto? DeactivateTarget;

    protected override async Task OnInitializedAsync() => await LoadCustomers();

    private async Task LoadCustomers()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var filter = new CustomerFilterDto
            {
                SearchTerm = SearchTerm,
                RegistrationDateFrom = DateFrom,
                RegistrationDateTo = DateTo,
                MinSpend = MinSpend,
                MaxSpend = MaxSpend,
                IsActive = StatusFilter switch { "true" => true, "false" => false, _ => null },
                Page = CurrentPage,
                PageSize = PageSize
            };

            var response = await CustomerService.GetAllCustomers(filter);
            if (response.Success && response.Data != null)
            {
                Customers = response.Data.Select(c => new CustomerRowDto
                {
                    Id = c.Id,
                    Name = c.Name,
                    Email = c.Email,
                    Phone = c.Phone,
                    LoyaltyPoints = c.LoyaltyPoints,
                    TotalSpent = c.TotalSpent,
                    IsActive = c.IsActive,
                    CreatedAt = c.CreatedAt,
                    TotalOrders = 0
                }).ToList();
            }
            else
            {
                Customers = new List<CustomerRowDto>();
            }
        }
        catch
        {
            Customers = new List<CustomerRowDto>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadCustomers()
    {
        CurrentPage = 1;
        await LoadCustomers();
    }

    private async Task HandleSearch()
    {
        CurrentPage = 1;
        await LoadCustomers();
    }

    private async Task ResetFilters()
    {
        SearchTerm = string.Empty;
        DateFrom = null;
        DateTo = null;
        MinSpend = null;
        MaxSpend = null;
        StatusFilter = "";
        CurrentPage = 1;
        await LoadCustomers();
    }

    // Pagination
    private async Task PreviousPage()
    {
        if (CurrentPage > 1) { CurrentPage--; await LoadCustomers(); }
    }

    private async Task NextPage()
    {
        if (Customers != null && Customers.Count == PageSize) { CurrentPage++; await LoadCustomers(); }
    }

    // Actions
    private void OpenAddModal() => FormModal?.OpenAdd();

    private void OpenEditModal(CustomerRowDto c) => FormModal?.OpenEdit(new CustomerDto { Id = c.Id, Name = c.Name, Email = c.Email, Phone = c.Phone, LoyaltyPoints = c.LoyaltyPoints, TotalSpent = c.TotalSpent, IsActive = c.IsActive, CreatedAt = c.CreatedAt });

    private void OpenLoyaltyModal(CustomerRowDto c) => LoyaltyModalRef?.Open(c.Id, c.Name, c.LoyaltyPoints);

    private void ViewProfile(int id) => Navigation.NavigateTo($"/admin/customers/profile/{id}");

    // Deactivate
    private void PromptDeactivate(CustomerRowDto c) => DeactivateTarget = c;
    private void CancelDeactivate() => DeactivateTarget = null;

    private async Task ConfirmDeactivate()
    {
        if (DeactivateTarget == null) return;
        IsSaving = true;
        StateHasChanged();

        try
        {
            var response = await CustomerService.DeleteCustomer(DeactivateTarget.Id);
            if (response.Success)
            {
                DeactivateTarget = null;
                ShowToast("success", "Customer deactivated.");
                await LoadCustomers();
            }
            else
            {
                ShowToast("error", response.Message);
            }
        }
         catch { ShowToast("error", "Failed to deactivate customer."); }
         finally { IsSaving = false; StateHasChanged(); }
     }

     private async Task ReactivateCustomer(CustomerRowDto c)
     {
         IsSaving = true;
         StateHasChanged();

         try
         {
             var response = await CustomerService.ActivateCustomer(c.Id);
             if (response.Success)
             {
                 ShowToast("success", "Customer reactivated.");
                 await LoadCustomers();
             }
             else
             {
                 ShowToast("error", response.Message);
             }
         }
         catch { ShowToast("error", "Failed to reactivate customer."); }
         finally { IsSaving = false; StateHasChanged(); }
     }

     // Toast
    private void ShowToast(string type, string msg) { ToastType = type; ToastMessage = msg; StateHasChanged(); }
    private void DismissToast() => ToastMessage = string.Empty;

    // Helpers
    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    private class CustomerRowDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public int LoyaltyPoints { get; set; }
        public decimal TotalSpent { get; set; }
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
        public int TotalOrders { get; set; }
    }
}
