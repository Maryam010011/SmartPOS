@page "/admin/suppliers"
@layout AdminLayout
@using SmartPOS.Shared.DTOs.Suppliers
@using SmartPOS.Shared.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using SmartPOS.Components.Layout
@inject ISupplierService SupplierService
@rendermode InteractiveServer

<PageTitle>Suppliers</PageTitle>

<div class="suppliers-page">
    <header class="page-header">
        <div class="page-title">
            <h1>Suppliers</h1>
            <p>Manage supplier records, contacts, and status.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-primary" type="button" @onclick="ShowCreateForm">Add Supplier</button>
            <button class="btn btn-secondary" type="button" @onclick="LoadSuppliers" disabled="@isLoadingList">Refresh</button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @(statusIsSuccess ? "alert-success" : "alert-error")">
            <span>@statusMessage</span>
        </div>
    }

    <section class="panel">
        <div class="panel-header">
            <h2>Find Supplier</h2>
        </div>
        <EditForm Model="lookupRequest" OnValidSubmit="LookupSupplier">
            <div class="form-grid">
                <div class="form-field">
                    <label for="lookupId">Supplier ID</label>
                    <InputNumber id="lookupId" class="input" @bind-Value="lookupRequest.Id" />
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" disabled="@isLoadingLookup">Find</button>
                    @if (isLoadingLookup)
                    {
                        <span class="spinner" aria-label="Loading"></span>
                    }
                </div>
            </div>
        </EditForm>

        @if (lookupResult != null)
        {
            <div class="result-card">
                <div class="result-header">
                    <h3>@lookupResult.Name</h3>
                    <span class="badge @(lookupResult.IsActive ? "badge-active" : "badge-inactive")">
                        @(lookupResult.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="result-details">
                    <div><strong>Contact:</strong> @lookupResult.ContactPerson</div>
                    <div><strong>Phone:</strong> @lookupResult.ContactNo</div>
                    <div><strong>Email:</strong> @lookupResult.Email</div>
                    <div><strong>Address:</strong> @lookupResult.Address</div>
                </div>
            </div>
        }
    </section>

    @if (showCreateForm)
    {
        <section class="panel">
            <div class="panel-header">
                <h2>Create Supplier</h2>
            </div>
            <EditForm Model="createModel" OnValidSubmit="CreateSupplier">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="createName">Name</label>
                        <InputText id="createName" class="input" @bind-Value="createModel.Name" />
                    </div>
                    <div class="form-field">
                        <label for="createContact">Contact Person</label>
                        <InputText id="createContact" class="input" @bind-Value="createModel.ContactPerson" />
                    </div>
                    <div class="form-field">
                        <label for="createPhone">Contact No</label>
                        <InputText id="createPhone" class="input" @bind-Value="createModel.ContactNo" />
                    </div>
                    <div class="form-field">
                        <label for="createEmail">Email</label>
                        <InputText id="createEmail" class="input" @bind-Value="createModel.Email" />
                    </div>
                    <div class="form-field full-width">
                        <label for="createAddress">Address</label>
                        <InputTextArea id="createAddress" class="input" @bind-Value="createModel.Address" />
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" disabled="@isLoadingCreate">Create</button>
                    <button class="btn btn-secondary" type="button" @onclick="HideCreateForm">Cancel</button>
                    @if (isLoadingCreate)
                    {
                        <span class="spinner" aria-label="Loading"></span>
                    }
                </div>
            </EditForm>
        </section>
    }

    @if (editModel != null)
    {
        <section class="panel">
            <div class="panel-header">
                <h2>Edit Supplier</h2>
            </div>
            <EditForm Model="editModel" OnValidSubmit="UpdateSupplier">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="editName">Name</label>
                        <InputText id="editName" class="input" @bind-Value="editModel.Name" />
                    </div>
                    <div class="form-field">
                        <label for="editContact">Contact Person</label>
                        <InputText id="editContact" class="input" @bind-Value="editModel.ContactPerson" />
                    </div>
                    <div class="form-field">
                        <label for="editPhone">Contact No</label>
                        <InputText id="editPhone" class="input" @bind-Value="editModel.ContactNo" />
                    </div>
                    <div class="form-field">
                        <label for="editEmail">Email</label>
                        <InputText id="editEmail" class="input" @bind-Value="editModel.Email" />
                    </div>
                    <div class="form-field full-width">
                        <label for="editAddress">Address</label>
                        <InputTextArea id="editAddress" class="input" @bind-Value="editModel.Address" />
                    </div>
                    <div class="form-field">
                        <label class="checkbox-label">
                            <InputCheckbox class="checkbox" @bind-Value="editModel.IsActive" />
                            Active
                        </label>
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" disabled="@isLoadingUpdate">Save Changes</button>
                    <button class="btn btn-secondary" type="button" @onclick="CancelEdit">Cancel</button>
                    @if (isLoadingUpdate)
                    {
                        <span class="spinner" aria-label="Loading"></span>
                    }
                </div>
            </EditForm>
        </section>
    }

    @if (pendingDelete != null)
    {
        <section class="panel warning-panel">
            <div class="panel-header">
                <h2>Confirm Delete</h2>
            </div>
            <p>Delete supplier <strong>@pendingDelete.Name</strong>? This action cannot be undone.</p>
            <div class="form-actions">
                <button class="btn btn-danger" type="button" @onclick="DeleteSupplier" disabled="@isLoadingDelete">Confirm Delete</button>
                <button class="btn btn-secondary" type="button" @onclick="CancelDelete">Cancel</button>
                @if (isLoadingDelete)
                {
                    <span class="spinner" aria-label="Loading"></span>
                }
            </div>
        </section>
    }

    <section class="panel">
        <div class="panel-header">
            <h2>All Suppliers</h2>
        </div>

        @if (isLoadingList)
        {
            <div class="loading-state">
                <span class="spinner" aria-label="Loading"></span>
                <span>Loading suppliers...</span>
            </div>
        }
        else if (suppliers.Count == 0)
        {
            <div class="empty-state">
                <p>No suppliers available. Create a supplier to get started.</p>
            </div>
        }
        else
        {
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Address</th>
                            <th>Status</th>
                            <th class="actions-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var supplier in suppliers)
                        {
                            <tr>
                                <td>@supplier.Name</td>
                                <td>@supplier.ContactPerson</td>
                                <td>@supplier.ContactNo</td>
                                <td>@supplier.Email</td>
                                <td>@supplier.Address</td>
                                <td>
                                    <span class="badge @(supplier.IsActive ? "badge-active" : "badge-inactive")">
                                        @(supplier.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="actions-column">
                                    <button class="btn btn-secondary" type="button" @onclick="() => StartEdit(supplier)" disabled="@isLoadingUpdate">Edit</button>
                                    <button class="btn btn-danger" type="button" @onclick="() => ConfirmDelete(supplier)" disabled="@isLoadingDelete">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

<style>
    .suppliers-page {
        padding: 2rem;
        background: var(--color-page-bg);
        color: var(--color-primary-text);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .page-title h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--color-heading-text);
        margin: 0;
    }

    .page-title p {
        margin: 0.35rem 0 0;
        font-size: 1rem;
        color: var(--color-primary-text);
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .panel {
        background: var(--color-card-bg);
        border: 1px solid var(--color-border-accent);
        border-radius: 0.75rem;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .panel-header {
        margin-bottom: 1rem;
    }

    .panel-header h2 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--color-heading-text);
        margin: 0;
    }

    .form-grid {
        display: grid;
        gap: 1rem 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        align-items: end;
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .form-field label {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-primary-text);
    }

    .form-field.full-width {
        grid-column: 1 / -1;
    }

    .input {
        border: 1px solid var(--color-border-accent);
        border-radius: 0.5rem;
        padding: 0.6rem 0.75rem;
        font-size: 0.95rem;
        color: var(--color-primary-text);
        background: var(--color-page-bg);
    }

    .input:focus {
        outline: none;
        border-color: var(--color-accent);
    }

    .form-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 1rem;
        flex-wrap: wrap;
    }

    .btn {
        border-radius: 0.5rem;
        padding: 0.55rem 1rem;
        font-size: 0.95rem;
        font-weight: 600;
        border: 1px solid transparent;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease, border 0.2s ease;
    }

    .btn-primary {
        background: var(--color-button-primary);
        color: var(--color-page-bg);
        border-color: var(--color-button-primary);
    }

    .btn-primary:hover {
        background: var(--color-button-hover);
        border-color: var(--color-button-hover);
    }

    .btn-secondary {
        background: transparent;
        color: var(--color-primary-text);
        border-color: var(--color-border-accent);
    }

    .btn-secondary:hover {
        background: var(--color-table-row-alt);
    }

    .btn-danger {
        background: var(--color-navbar-bg);
        color: var(--color-page-bg);
        border-color: var(--color-navbar-bg);
    }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .alert {
        border-radius: 0.6rem;
        padding: 0.85rem 1rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .alert-success {
        background: var(--color-accent);
        color: var(--color-page-bg);
        border: 1px solid var(--color-border-accent);
    }

    .alert-error {
        background: var(--color-navbar-bg);
        color: var(--color-page-bg);
        border: 1px solid var(--color-navbar-bg);
    }

    .table-container {
        overflow-x: auto;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

    .table th,
    .table td {
        padding: 0.75rem 0.9rem;
        text-align: left;
        border-bottom: 1px solid var(--color-border-accent);
    }

    .table th {
        background: var(--color-navbar-bg);
        color: var(--color-page-bg);
        font-weight: 600;
    }

    .table tbody tr:nth-child(even) {
        background: var(--color-table-row-alt);
    }

    .actions-column {
        white-space: nowrap;
        display: flex;
        gap: 0.5rem;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-active {
        background: var(--color-badge);
        color: var(--color-page-bg);
    }

    .badge-inactive {
        background: var(--color-navbar-bg);
        color: var(--color-page-bg);
    }

    .result-card {
        border-top: 1px solid var(--color-border-accent);
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        display: grid;
        gap: 0.75rem;
    }

    .result-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .result-header h3 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-heading-text);
        margin: 0;
    }

    .result-details {
        display: grid;
        gap: 0.35rem;
        font-size: 0.95rem;
        color: var(--color-primary-text);
    }

    .loading-state {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 600;
        color: var(--color-primary-text);
    }

    .empty-state {
        padding: 1.5rem;
        border: 1px dashed var(--color-border-accent);
        border-radius: 0.6rem;
        color: var(--color-primary-text);
        font-weight: 600;
    }

    .spinner {
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        border: 2px solid var(--color-border-accent);
        border-top-color: var(--color-navbar-bg);
        animation: spin 0.8s linear infinite;
    }

    .warning-panel {
        border-color: var(--color-navbar-bg);
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
    }

    .checkbox {
        width: 1rem;
        height: 1rem;
        accent-color: var(--color-accent);
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private readonly List<SupplierDto> suppliers = new();
    private CreateSupplierDto createModel = new();
    private SupplierDto? editModel;
    private SupplierDto? lookupResult;
    private SupplierDto? pendingDelete;
    private readonly LookupRequest lookupRequest = new();

    private bool showCreateForm;
    private bool isLoadingList;
    private bool isLoadingCreate;
    private bool isLoadingUpdate;
    private bool isLoadingDelete;
    private bool isLoadingLookup;

    private string statusMessage = string.Empty;
    private bool statusIsSuccess = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        isLoadingList = true;
        ClearStatus();

        var response = await SupplierService.GetAll();
        if (response.Success && response.Data != null)
        {
            suppliers.Clear();
            suppliers.AddRange(response.Data);
            SetStatus(true, response.Message);
        }
        else
        {
            SetStatus(false, response.Message);
        }

        isLoadingList = false;
    }

    private async Task LookupSupplier()
    {
        if (lookupRequest.Id <= 0)
        {
            SetStatus(false, "Please provide a valid supplier ID.");
            lookupResult = null;
            return;
        }

        isLoadingLookup = true;
        ClearStatus();

        var response = await SupplierService.GetById(lookupRequest.Id);
        if (response.Success && response.Data != null)
        {
            lookupResult = response.Data;
            SetStatus(true, response.Message);
        }
        else
        {
            lookupResult = null;
            SetStatus(false, response.Message);
        }

        isLoadingLookup = false;
    }

    private void ShowCreateForm()
    {
        createModel = new CreateSupplierDto();
        showCreateForm = true;
    }

    private void HideCreateForm()
    {
        showCreateForm = false;
    }

    private async Task CreateSupplier()
    {
        isLoadingCreate = true;
        ClearStatus();

        var response = await SupplierService.Create(createModel);
        if (response.Success && response.Data != null)
        {
            suppliers.Add(response.Data);
            createModel = new CreateSupplierDto();
            showCreateForm = false;
            SetStatus(true, response.Message);
        }
        else
        {
            SetStatus(false, response.Message);
        }

        isLoadingCreate = false;
    }

    private void StartEdit(SupplierDto supplier)
    {
        editModel = new SupplierDto
        {
            Id = supplier.Id,
            Name = supplier.Name,
            ContactPerson = supplier.ContactPerson,
            ContactNo = supplier.ContactNo,
            Email = supplier.Email,
            Address = supplier.Address,
            IsActive = supplier.IsActive
        };
    }

    private void CancelEdit()
    {
        editModel = null;
    }

    private async Task UpdateSupplier()
    {
        if (editModel == null)
        {
            return;
        }

        isLoadingUpdate = true;
        ClearStatus();

        var response = await SupplierService.Update(editModel);
        if (response.Success && response.Data != null)
        {
            var index = suppliers.FindIndex(s => s.Id == response.Data.Id);
            if (index >= 0)
            {
                suppliers[index] = response.Data;
            }

            if (lookupResult?.Id == response.Data.Id)
            {
                lookupResult = response.Data;
            }

            editModel = null;
            SetStatus(true, response.Message);
        }
        else
        {
            SetStatus(false, response.Message);
        }

        isLoadingUpdate = false;
    }

    private void ConfirmDelete(SupplierDto supplier)
    {
        pendingDelete = supplier;
    }

    private void CancelDelete()
    {
        pendingDelete = null;
    }

    private async Task DeleteSupplier()
    {
        if (pendingDelete == null)
        {
            return;
        }

        isLoadingDelete = true;
        ClearStatus();

        var response = await SupplierService.Delete(pendingDelete.Id);
        if (response.Success)
        {
            suppliers.RemoveAll(s => s.Id == pendingDelete.Id);
            if (lookupResult?.Id == pendingDelete.Id)
            {
                lookupResult = null;
            }
            SetStatus(true, response.Message);
            pendingDelete = null;
        }
        else
        {
            SetStatus(false, response.Message);
        }

        isLoadingDelete = false;
    }

    private void SetStatus(bool success, string message)
    {
        statusIsSuccess = success;
        statusMessage = message;
    }

    private void ClearStatus()
    {
        statusMessage = string.Empty;
    }

    private sealed class LookupRequest
    {
        public int Id { get; set; }
    }
}
