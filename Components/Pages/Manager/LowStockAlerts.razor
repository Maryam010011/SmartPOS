@* ─────────────────────────────────────────────────────────────────── *@
@code {
    // ── Data ─────────────────────────────────────────────────────────
    /// <summary>
    /// Null until the first load completes — drives the loading skeleton state.
    /// </summary>
    private List<InventoryDto>? lowStockItems;

    private List<ProductDto> Products { get; set; } = new();
    private Dictionary<int, ProductDto> ProductLookup { get; set; } = new();

    // ── UI State ─────────────────────────────────────────────────────
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    // ── Search & Sort ─────────────────────────────────────────────────
    private string _searchText = string.Empty;
    private string SearchText
    {
        get => _searchText;
        set
        {
            if (_searchText == value) return;
            _searchText = value;
            CurrentPage = 1;
        }
    }

    private bool SortByUrgency { get; set; } = true;

    // ── Pagination ────────────────────────────────────────────────────
    private int CurrentPage { get; set; } = 1;
    private const int PageSize = 12;

    // ── Computed lists ────────────────────────────────────────────────
    /// <summary>
    /// Items filtered by search text and sorted by the current sort mode.
    /// </summary>
    private IReadOnlyList<InventoryDto> DisplayedItems
    {
        get
        {
            if (lowStockItems == null) return Array.Empty<InventoryDto>();

            IEnumerable<InventoryDto> query = lowStockItems;

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var term = SearchText.Trim();
                query = query.Where(item =>
                    item.ProductName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    item.ProductId.ToString().Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    GetSku(item.ProductId).Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    GetSupplier(item.ProductId).Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            if (SortByUrgency)
            {
                // Sort: out-of-stock first, then by deficit descending
                query = query
                    .OrderByDescending(item => item.Quantity == 0)
                    .ThenByDescending(item => item.ReorderLevel - item.Quantity);
            }
            else
            {
                query = query.OrderBy(item => item.ProductName);
            }

            return query.ToList();
        }
    }

    private IReadOnlyList<InventoryDto> PagedItems =>
        DisplayedItems
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(DisplayedItems.Count / (double)PageSize));
    private bool IsFirstPage => CurrentPage <= 1;
    private bool IsLastPage  => CurrentPage >= TotalPages;

    // ── KPI Metrics ───────────────────────────────────────────────────
    private int TotalAlerts    => lowStockItems?.Count ?? 0;
    private int CriticalCount  => lowStockItems?.Count(i => i.Quantity == 0) ?? 0;
    private int AtLevelCount   => lowStockItems?.Count(i => i.Quantity > 0 && i.Quantity <= i.ReorderLevel) ?? 0;

    // ── Lifecycle ─────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // lowStockItems stays null during this await — skeleton renders
        await LoadDataAsync();
    }

    // ── Data loading ──────────────────────────────────────────────────
    private async Task LoadDataAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var lowStockTask  = InventoryService.GetLowStock();
            var productsTask  = ProductService.GetAll();

            await Task.WhenAll(lowStockTask, productsTask);

            var lowStockResponse = await lowStockTask;
            var productsResponse = await productsTask;

            if (!lowStockResponse.Success)
            {
                ErrorMessage   = lowStockResponse.Message;
                lowStockItems  = new();
            }
            else
            {
                lowStockItems = lowStockResponse.Data ?? new();
            }

            if (productsResponse.Success && productsResponse.Data is not null)
            {
                Products      = productsResponse.Data;
                ProductLookup = Products.ToDictionary(p => p.Id);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage  = $"Unexpected error loading alerts: {ex.Message}";
            lowStockItems = new();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshAsync()
    {
        if (IsLoading) return;

        // Trigger skeleton by resetting to null momentarily
        lowStockItems = null;
        CurrentPage   = 1;
        StateHasChanged();

        await LoadDataAsync();
    }

    // ── Navigation ────────────────────────────────────────────────────
    /// <summary>
    /// Navigates to the Purchase Orders page with the productId pre-selected
    /// via query parameter, allowing the PO form to auto-populate the product.
    /// </summary>
    private void NavigateToPurchaseOrders(InventoryDto item)
    {
        Navigation.NavigateTo($"/manager/purchase-orders?productId={item.ProductId}&productName={Uri.EscapeDataString(item.ProductName)}");
    }

    // ── Search & Sort handlers ────────────────────────────────────────
    private void OnSearchInput(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString() ?? string.Empty;
    }

    private void ClearSearch()
    {
        SearchText  = string.Empty;
        CurrentPage = 1;
    }

    private void ToggleSortByUrgency()
    {
        SortByUrgency = !SortByUrgency;
        CurrentPage   = 1;
    }

    // ── Pagination ────────────────────────────────────────────────────
    private void NextPage()     { if (!IsLastPage)  CurrentPage++; }
    private void PreviousPage() { if (!IsFirstPage) CurrentPage--; }
    private void GoToPage(int page) => CurrentPage = page;

    // ── Lookup helpers ────────────────────────────────────────────────
    private string GetSku(int productId)
        => ProductLookup.TryGetValue(productId, out var p) ? p.SKU : "N/A";

    private string GetSupplier(int productId)
        => ProductLookup.TryGetValue(productId, out var p) && !string.IsNullOrWhiteSpace(p.SupplierName)
            ? p.SupplierName
            : "No Supplier";

    // ── Urgency classification helpers ────────────────────────────────
    private static string GetUrgencyRowClass(InventoryDto item)
    {
        if (item.Quantity == 0)            return "ls-row-out-of-stock";
        var deficit = item.ReorderLevel - item.Quantity;
        if (deficit >= item.ReorderLevel / 2 && item.ReorderLevel > 0)
            return "ls-row-critical";
        return string.Empty;
    }

    private static string GetUrgencyBadgeClass(InventoryDto item)
    {
        if (item.Quantity == 0) return "ls-badge-out-of-stock";
        var deficit = item.ReorderLevel - item.Quantity;
        if (deficit >= item.ReorderLevel / 2 && item.ReorderLevel > 0)
            return "ls-badge-critical";
        return "ls-badge-warning";
    }

    private static string GetUrgencyLabel(InventoryDto item)
    {
        if (item.Quantity == 0) return "Out of Stock";
        var deficit = item.ReorderLevel - item.Quantity;
        if (deficit >= item.ReorderLevel / 2 && item.ReorderLevel > 0)
            return "Critical";
        return "Low Stock";
    }
}
