@inherits LayoutComponentBase
@inject SmartPOS.Services.MaryamJ.AuthStateService AuthState
@inject NavigationManager Navigation

<NavBar />

@if (AuthState.IsAuthenticated && (AuthState.UserRole == "Cashier" || AuthState.UserRole == "Manager" || AuthState.UserRole == "Admin"))
{
    <div class="layout-wrapper">
        <aside class="sidebar">
            <nav class="sidebar-nav">
                <NavLink class="nav-item" href="/cashier/pos" Match="NavLinkMatch.Prefix">
                    🖥 <span>POS Terminal</span>
                </NavLink>
                <NavLink class="nav-item" href="/cashier/sales-history" Match="NavLinkMatch.Prefix">
                    📜 <span>Sales History</span>
                </NavLink>
                <NavLink class="nav-item" href="/cashier/customer-lookup" Match="NavLinkMatch.Prefix">
                    👤 <span>Customer Lookup</span>
                </NavLink>
            </nav>
        </aside>
        <main class="main-content">
            @Body
        </main>
    </div>
    <Footer />
}
else
{
    <div class="container py-5 text-center">
        <h2 class="text-danger">Access Denied</h2>
        <p>You need Cashier or higher privileges to view this page.</p>
        <a href="/login" class="btn btn-burnt-orange">Sign In</a>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        if (!AuthState.IsAuthenticated || 
            (AuthState.UserRole != "Cashier" && AuthState.UserRole != "Manager" && AuthState.UserRole != "Admin"))
        {
            Navigation.NavigateTo("/login");
        }
    }
}
