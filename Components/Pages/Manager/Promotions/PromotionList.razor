@page "/manager/promotions"
@using SmartPOS.Shared.DTOs.Promotions
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.Common
@using SmartPOS.Shared.Enums
@inject IPromotionService PromotionService
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <!-- Toast -->
    @if (!string.IsNullOrEmpty(ToastMessage))
    {
        <div class="toast-container-pos">
            <div class="toast-pos toast-@ToastType">
                <span class="toast-icon">
                    @switch (ToastType)
                    {
                        case "success": <text>✅</text>; break;
                        case "error": <text>❌</text>; break;
                        default: <text>ℹ️</text>; break;
                    }
                </span>
                <span class="toast-body">@ToastMessage</span>
                <button class="toast-close" @onclick="DismissToast">&times;</button>
            </div>
        </div>
    }

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Promotion Management</h2>
            <p class="text-muted m-0">Create, edit, and manage promotional codes and discounts.</p>
        </div>
        <button type="button" class="btn btn-burnt-orange d-flex align-items-center gap-2" @onclick="OpenCreateModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
            </svg>
            <span>Create Promotion</span>
        </button>
    </div>

    <!-- Filters -->
    <div class="card card-pos mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-start">
                <div class="col-md-3">
                    <label class="form-label text-secondary small fw-semibold">Search by Code</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 ps-0" placeholder="Enter promo code..."
                               @bind-value="SearchTerm" @bind-value:event="oninput" />
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Status</label>
                    <select class="form-select" @bind="StatusFilter">
                        <option value="">All</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small fw-semibold">Type</label>
                    <select class="form-select" @bind="TypeFilter">
                        <option value="">All</option>
                        <option value="Percentage">Percentage</option>
                        <option value="Flat">Flat Amount</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary btn-sm fw-semibold" @onclick="ApplyFilters">
                        Apply Filters
                    </button>
                </div>
                <div class="col-md-2 d-flex align-items-end justify-content-end">
                    <button class="btn btn-link btn-sm fw-semibold text-muted" @onclick="ClearFilters">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Promotions Table -->
    <div class="card card-pos">
        <div class="card-body p-0">
            @if (IsLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border" style="color: var(--color-button-primary);" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted mt-2">Loading promotions...</p>
                </div>
            }
            else if (FilteredPromotions == null || !FilteredPromotions.Any())
            {
                <div class="text-center py-5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="text-muted mb-3" viewBox="0 0 16 16">
                        <path d="M3 5v6h5L5.854l-2.147-2.146A.5.5 0 0 1 12 3.5v9H3zm-1 8.5V5A1.5 1.5 0 0 1 3.5 3.5h8.793a1.5 1.5 0 0 1 1.06.44l2.147 2.146A1.5 1.5 0 0 1 16 6.5v3A1.5 1.5 0 0 1 14.5 11H3.5A1.5 1.5 0 0 1 2 9.5z"/>
                    </svg>
                    <p class="text-muted fw-semibold mb-1">No promotions found</p>
                    <p class="text-muted small m-0">Click "Create Promotion" to add your first promotion.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-pos align-middle m-0 table-hover">
                        <thead class="table-light">
                            <tr>
                                <th style="padding-left: 20px;">Code</th>
                                <th>Type</th>
                                <th>Value</th>
                                <th>Min Order</th>
                                <th>Used/Limit</th>
                                <th>Valid From</th>
                                <th>Valid To</th>
                                <th>Status</th>
                                <th class="text-end" style="padding-right: 20px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in FilteredPromotions)
                            {
                                <tr class="@(GetRowStatus(p) == "Inactive" ? "opacity-50" : "")">
                                    <td style="padding-left: 20px;">
                                        <span class="fw-bold text-dark">@p.Code</span>
                                        @if (!string.IsNullOrEmpty(p.Description))
                                        {
                                            <div class="text-muted small" style="font-size: 0.75rem;">@p.Description</div>
                                        }
                                    </td>
                                    <td>
                                        @if (p.DiscountType == DiscountType.Percentage)
                                        {
                                            <span class="badge rounded-pill bg-info-subtle text-info px-2 py-1.5">Percentage</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-primary-subtle text-primary px-2 py-1.5">Flat</span>
                                        }
                                    </td>
                                    <td class="fw-semibold">
                                        @if (p.DiscountType == DiscountType.Percentage)
                                        {
                                            <span>@p.Value%</span>
                                        }
                                        else
                                        {
                                            <span>Rs @p.Value.ToString("N0")</span>
                                        }
                                    </td>
                                    <td>Rs @p.MinOrderValue.ToString("N0")</td>
                                    <td>
                                        <span class="@(p.UsageCount >= p.MaxUsageLimit ? "text-danger" : "text-dark")">
                                            @p.UsageCount
                                        </span>
                                        <span class="text-muted">/</span>
                                        <span class="text-muted">@p.MaxUsageLimit</span>
                                    </td>
                                    <td class="text-muted small">@p.ValidFrom.ToString("dd MMM yyyy")</td>
                                    <td class="text-muted small">@p.ValidTo.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @GetStatusBadge(p)
                                    </td>
                                    <td class="text-end" style="padding-right: 20px;">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm border dropdown-toggle fw-semibold" type="button" data-bs-toggle="dropdown">
                                                Manage
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => OpenEditModal(p)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.854.146a.5.5 0 0 0-.708 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.5-.5V9h-.5a.5.5 0 0 1 .146-.354l6-6a.5.5 0 0 1 .708 0l3.75 3.75a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.354.146z"/></svg>
                                                        <span>Edit</span>
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => ToggleActive(p)">
                                                        @if (p.IsActive)
                                                        {
                                                            <span class="text-warning">Deactivate</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-success">Activate</span>
                                                        }
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => OpenAnalyticsModal(p)">
                                                        <span>View Analytics</span>
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <button class="dropdown-item text-danger d-flex align-items-center gap-2" @onclick="() => PromptDelete(p)">
                                                        <span>Delete</span>
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Modals -->
    <PromotionFormModal @ref="FormModalRef" OnSave="ReloadPromotions" />
    <PromotionAnalyticsModal @ref="AnalyticsModalRef" />

    <!-- Delete Confirmation Modal -->
    @if (DeleteTarget != null)
    {
        <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content card-pos border border-danger-subtle">
                    <div class="modal-header border-bottom-0 pb-0">
                        <h5 class="modal-title fw-bold text-danger">Delete Promotion</h5>
                        <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                    </div>
                    <div class="modal-body py-3">
                        <p class="m-0 text-dark">
                            Are you sure you want to delete promotion <strong>@DeleteTarget.Code</strong>?
                        </p>
                        <p class="text-muted small mt-2 m-0 border-start border-3 ps-2 border-danger-subtle">
                            This action cannot be undone.
                        </p>
                    </div>
                    <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                        <button class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger px-4 fw-bold text-white" @onclick="ConfirmDelete" disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <span>Delete</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show modal-backdrop-pos"></div>
    }

</div>

@code {
    private List<PromotionDto>? AllPromotions;
    private List<PromotionDto>? FilteredPromotions;
    private bool IsLoading = true;
    private bool IsSaving;

    private string SearchTerm = string.Empty;
    private string StatusFilter = string.Empty;
    private string TypeFilter = string.Empty;

    private string ToastMessage = string.Empty;
    private string ToastType = "success";

    private PromotionFormModal? FormModalRef;
    private PromotionAnalyticsModal? AnalyticsModalRef;

    private PromotionDto? DeleteTarget;

    protected override async Task OnInitializedAsync() => await LoadPromotions();

    private async Task LoadPromotions()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var result = await PromotionService.GetAllPromotions();
            if (result.Success && result.Data != null)
            {
                AllPromotions = result.Data;
                ApplyFiltersToList();
            }
            else
            {
                AllPromotions = new List<PromotionDto>();
            }
        }
        catch
        {
            AllPromotions = new List<PromotionDto>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFiltersToList()
    {
        if (AllPromotions == null)
        {
            FilteredPromotions = new List<PromotionDto>();
            return;
        }

        var query = AllPromotions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            var term = SearchTerm.Trim().ToLower();
            query = query.Where(p => p.Code.ToLower().Contains(term));
        }

        if (!string.IsNullOrWhiteSpace(StatusFilter))
        {
            query = query.Where(p => GetRowStatus(p) == StatusFilter);
        }

        if (!string.IsNullOrWhiteSpace(TypeFilter))
        {
            if (Enum.TryParse<DiscountType>(TypeFilter, out var type))
            {
                query = query.Where(p => p.DiscountType == type);
            }
        }

        FilteredPromotions = query.OrderByDescending(p => p.CreatedAt).ToList();
    }

    private async Task ApplyFilters()
    {
        ApplyFiltersToList();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        SearchTerm = string.Empty;
        StatusFilter = string.Empty;
        TypeFilter = string.Empty;
        ApplyFiltersToList();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task ReloadPromotions() => await LoadPromotions();

    private void OpenCreateModal() => FormModalRef?.OpenCreate();

    private void OpenEditModal(PromotionDto p) => FormModalRef?.OpenEdit(p);

    private void OpenAnalyticsModal(PromotionDto p) => AnalyticsModalRef?.Open(p.Id, p.Code);

    private async Task ToggleActive(PromotionDto p)
    {
        IsSaving = true;
        StateHasChanged();

        try
        {
            var response = await PromotionService.ToggleActive(p.Id);
            if (response.Success)
            {
                ShowToast("success", response.Message);
                await ReloadPromotions();
            }
            else
            {
                ShowToast("error", response.Message);
            }
        }
        catch
        {
            ShowToast("error", "Failed to toggle promotion status.");
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void PromptDelete(PromotionDto p) => DeleteTarget = p;
    private void CancelDelete() => DeleteTarget = null;

    private async Task ConfirmDelete()
    {
        if (DeleteTarget == null) return;

        IsSaving = true;
        StateHasChanged();

        try
        {
            var response = await PromotionService.DeletePromotion(DeleteTarget.Id);
            if (response.Success)
            {
                DeleteTarget = null;
                ShowToast("success", "Promotion deleted.");
                await ReloadPromotions();
            }
            else
            {
                ShowToast("error", response.Message);
            }
        }
        catch
        {
            ShowToast("error", "Failed to delete promotion.");
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void DismissToast() => ToastMessage = string.Empty;
    private void ShowToast(string type, string msg) { ToastType = type; ToastMessage = msg; StateHasChanged(); }

    private string GetRowStatus(PromotionDto p)
    {
        var now = DateTime.UtcNow;
        if (!p.IsActive)
            return "Inactive";
        else if (now > p.ValidTo)
            return "Expired";
        else
            return "Active";
    }

    private MarkupString GetStatusBadge(PromotionDto p)
    {
        var status = GetRowStatus(p);
        if (status == "Active")
            return (MarkupString)"<span class=\"badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 rounded-pill\">● Active</span>";
        else if (status == "Expired")
            return (MarkupString)"<span class=\"badge px-2 py-1.5 rounded-pill\" style=\"background-color: rgba(204, 85, 0, 0.15); color: #CC5500; border: 1px solid rgba(204, 85, 0, 0.3);\">● Expired</span>";
        else
            return (MarkupString)"<span class=\"badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1.5 rounded-pill\">● Inactive</span>";
    }
}
