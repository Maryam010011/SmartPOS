@namespace SmartPOS.Components.Layout

<!-- Drawer Panel -->
<aside class="profile-drawer">

    <!-- Header -->
    <div class="drawer-header">
        <div class="drawer-avatar">
            <span class="avatar-initials">@GetInitials()</span>
        </div>
        <div class="drawer-user-info">
            <span class="drawer-display-name">@DisplayName</span>
            <span class="drawer-role-badge" style="--role-color: @RoleColor">@RoleName</span>
        </div>
        <button class="drawer-close-btn" onclick="closeSidebar()" aria-label="Close profile drawer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <!-- Body -->
    <div class="drawer-body">

        <!-- Profile Info Card -->
        <div class="drawer-info-card">
            <div class="info-row">
                <span class="info-label">Role</span>
                <span class="info-value">@RoleName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Session</span>
                <span class="info-value">Active</span>
            </div>
            <div class="info-row">
                <span class="info-label">Store</span>
                <span class="info-value">SmartPOS+ Bakery</span>
            </div>
        </div>

        <button class="drawer-nav-item danger-item" onclick="signOut()">
            <span class="nav-item-icon"></span>
            <span>Sign Out</span>
        </button>
    </div>

    <!-- Footer -->
    <div class="drawer-footer">
        <span class="drawer-app-name"> SmartPOS<span class="drawer-plus">+</span></span>
        <span class="drawer-version">v1.0</span>
    </div>

</aside>

<!-- Overlay (always rendered, hidden by CSS, shown via JS) -->
<div class="drawer-overlay" onclick="closeSidebar()"></div>

@code {
    [Parameter] public string DisplayName   { get; set; } = "User";
    [Parameter] public string RoleName      { get; set; } = "Staff";
    [Parameter] public string RoleColor     { get; set; } = "#C4848A";

    private string GetInitials()
    {
        var parts = DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : DisplayName.Length >= 2
                ? DisplayName[..2].ToUpper()
                : DisplayName.ToUpper();
    }

}

<style>
    /* ── Overlay ────────────────────────────────────────────── */
    .drawer-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--drawer-overlay, rgba(61,28,2,0.35));
        z-index: 1000;
        backdrop-filter: blur(2px);
        animation: overlay-in 0.22s ease;
    }

    .profile-drawer.drawer-open + .drawer-overlay {
        display: block;
    }

    @@keyframes overlay-in {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    /* ── Drawer Panel ────────────────────────────────────────── */
    .profile-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: var(--drawer-width, 320px);
        height: 100vh;
        background: var(--drawer-bg, #FFF8DC);
        border-left: 1px solid var(--drawer-border, rgba(61,28,2,0.12));
        box-shadow: var(--drawer-shadow, -6px 0 40px rgba(61,28,2,0.18));
        z-index: 1001;
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform var(--transition-slow, 0.4s cubic-bezier(0.25,0.46,0.45,0.94));
    }

    .profile-drawer.drawer-open {
        transform: translateX(0);
    }

    /* ── Drawer Header ───────────────────────────────────────── */
    .drawer-header {
        background: var(--drawer-header-bg, #3D1C02);
        color: var(--drawer-header-text, #FFF8DC);
        padding: 1.5rem 1.25rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        flex-shrink: 0;
    }

    .drawer-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--drawer-avatar-bg, rgba(196,132,138,0.25));
        border: 2px solid rgba(196, 132, 138, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .avatar-initials {
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 1rem;
        font-weight: 700;
        color: #FFF8DC;
        letter-spacing: 0.03em;
    }

    .drawer-user-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        min-width: 0;
    }

    .drawer-display-name {
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.9rem;
        font-weight: 600;
        color: #FFF8DC;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .drawer-role-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(255,255,255,0.10);
        border: 1px solid var(--role-color, #C4848A);
        color: var(--role-color, #C4848A);
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        border-radius: 9999px;
        align-self: flex-start;
    }

    .drawer-close-btn {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,248,220,0.70);
        border-radius: 0.4rem;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background var(--transition-fast, 0.15s ease), color var(--transition-fast, 0.15s ease);
    }

    .drawer-close-btn:hover {
        background: rgba(196, 132, 138, 0.22);
        color: #FFF8DC;
    }

    /* ── Drawer Body ─────────────────────────────────────────── */
    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* Info Card */
    .drawer-info-card {
        background: rgba(61,28,2,0.04);
        border: 1px solid rgba(61,28,2,0.08);
        border-radius: var(--radius-md, 0.625rem);
        padding: 0.9rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.82rem;
    }

    .info-label {
        color: var(--text-muted, rgba(61,28,2,0.38));
        font-weight: 500;
    }

    .info-value {
        color: var(--text-primary, #3D1C02);
        font-weight: 600;
    }

    /* Section Label */
    .drawer-section-label {
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text-muted, rgba(61,28,2,0.38));
        padding: 0 0.25rem;
    }

    /* Nav items */
    .drawer-nav {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .drawer-nav-item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.7rem 0.85rem;
        border-radius: var(--radius-md, 0.625rem);
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-primary, #3D1C02);
        text-decoration: none;
        background: transparent;
        border: none;
        cursor: pointer;
        text-align: left;
        width: 100%;
        transition: background var(--transition-fast, 0.15s ease);
    }

    .drawer-nav-item:hover {
        background: var(--drawer-item-hover, rgba(196,132,138,0.10));
    }

    .nav-item-icon {
        font-size: 1rem;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
    }

    .danger-item {
        color: var(--color-danger, #c44a4a);
        margin-top: 0.25rem;
    }

    .danger-item:hover {
        background: rgba(196, 74, 74, 0.08);
    }

    /* ── Drawer Footer ───────────────────────────────────────── */
    .drawer-footer {
        padding: 0.85rem 1.25rem;
        border-top: 1px solid var(--surface-border, rgba(61,28,2,0.09));
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    .drawer-app-name {
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-secondary, rgba(61,28,2,0.60));
    }

    .drawer-plus {
        color: var(--color-rose, #C4848A);
    }

    .drawer-version {
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        font-size: 0.68rem;
        color: var(--text-muted, rgba(61,28,2,0.38));
    }
</style>
