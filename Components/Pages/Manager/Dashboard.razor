@page "/manager/dashboard"
@layout ManagerLayout
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.DTOs.Inventory
@using SmartPOS.Shared.DTOs.PurchaseOrders
@using SmartPOS.Shared.Enums
@using SmartPOS.Shared.Common
@inject IInventoryService InventoryService
@inject IPurchaseOrderService PurchaseOrderService
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Manager Dashboard</h2>
            <p class="text-muted m-0">Inventory overview, stock alerts, and purchase order tracking.</p>
        </div>
        <a href="/manager/inventory" class="btn btn-burnt-orange d-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/></svg>
            <span>Manage Inventory</span>
        </a>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--color-button-primary);" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2">Loading dashboard data...</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(204, 85, 0, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#CC5500" viewBox="0 0 16 16"><path d="M2 1a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h5v2H4.5a.5.5 0 0 0-.5.5v.5h-.5a.5.5 0 0 0-.5.5v.5H2.5a.5.5 0 0 0-.5.5v.5H1.5a.5.5 0 0 0 0 1h13a.5.5 0 0 0 0-1h-.5V13a.5.5 0 0 0-.5-.5h-2.5a.5.5 0 0 0-.5.5v.5H9v-2h5V7a1 1 0 0 0-1-1H9V5h2.5a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3A.5.5 0 0 0 8 1.5V2H6V1.5A.5.5 0 0 0 5.5 1z"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Total SKUs</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: var(--color-button-primary);">@TotalSKUs</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(204, 85, 0, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#CC5500" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">In Stock</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: #198754;">@InStockCount</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100" style="border-left: 4px solid #CC5500 !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(204, 85, 0, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#CC5500" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Low Stock</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: #CC5500;">@LowStockCount</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100" style="border-left: 4px solid #dc3545 !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(220, 53, 69, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#dc3545" viewBox="0 0 16 16"><path d="M2.5 0a.5.5 0 0 0-.5.5v2.5H.5a.5.5 0 0 0 0 1h1.5v2.5a.5.5 0 0 0 1 0V4h1.5a.5.5 0 0 0 0-1H3V.5a.5.5 0 0 0-.5-.5M12.5 7a.5.5 0 0 0-.5.5V9h-2a.5.5 0 0 0 0 1h2.5a.5.5 0 0 0 .5-.5V7a.5.5 0 0 0-.5-.5M8 9.5a.5.5 0 0 0-.5.5v2.5H5.5a.5.5 0 0 0 0 1h2.5a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5m-3.5 2a.5.5 0 0 0-.5.5v2.5H2a.5.5 0 0 0 0 1h2.5a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Out of Stock</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: #dc3545;">@OutOfStockCount</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card card-pos h-100">
                    <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Low Stock Alerts</h6>
                        <a href="/manager/inventory/low-stock" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="card-body p-0">
                        @if (LowStockItems == null || !LowStockItems.Any())
                        {
                            <div class="text-center py-4 text-muted small">All items are well-stocked. ✅</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-pos align-middle m-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="padding-left: 20px;">Product</th>
                                            <th>Current Qty</th>
                                            <th>Reorder Level</th>
                                            <th class="text-end" style="padding-right: 20px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in LowStockItems.Take(5))
                                        {
                                            <tr>
                                                <td style="padding-left: 20px;"><span class="fw-bold text-dark">@item.ProductName</span></td>
                                                <td class="fw-semibold">@item.Quantity</td>
                                                <td class="text-muted">@item.ReorderLevel</td>
                                                <td class="text-end" style="padding-right: 20px;">
                                                    @if (item.Quantity == 0)
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1.5 rounded-pill">● Out of Stock</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge px-2 py-1.5 rounded-pill" style="background-color: rgba(204, 85, 0, 0.15); color: #CC5500; border: 1px solid rgba(204, 85, 0, 0.3);">● Low Stock</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card card-pos h-100">
                    <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Recent Purchase Orders</h6>
                        <a href="/manager/purchase-orders" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="card-body p-0">
                        @if (RecentPOs == null || !RecentPOs.Any())
                        {
                            <div class="text-center py-4 text-muted small">No purchase orders yet.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-pos align-middle m-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="padding-left: 20px;">PO #</th>
                                            <th>Supplier</th>
                                            <th>Items</th>
                                            <th>Total</th>
                                            <th class="text-end" style="padding-right: 20px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var po in RecentPOs)
                                        {
                                            <tr>
                                                <td style="padding-left: 20px;"><span class="fw-bold text-dark">#@po.Id</span></td>
                                                <td class="text-muted small">@po.SupplierName</td>
                                                <td>@po.LineItems.Count</td>
                                                <td class="fw-semibold">$@po.TotalCost.ToString("N2")</td>
                                                <td class="text-end" style="padding-right: 20px;">
                                                    <span class="badge @GetStatusBadgeClass(po.Status) px-2 py-1.5 rounded-pill">@po.Status</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-12">
                <div class="card card-pos">
                    <div class="card-header bg-transparent border-bottom-0 pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Quick Actions</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <a href="/manager/inventory" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-3">
                                    <span style="font-size: 1.5rem;">📦</span>
                                    <div>
                                        <div class="fw-bold small">Inventory Dashboard</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Monitor stock levels</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/manager/inventory/low-stock" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-3">
                                    <span style="font-size: 1.5rem;">⚠️</span>
                                    <div>
                                        <div class="fw-bold small">Low Stock Alerts</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">@LowStockCount items need attention</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/manager/purchase-orders" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-3">
                                    <span style="font-size: 1.5rem;">🛒</span>
                                    <div>
                                        <div class="fw-bold small">Purchase Orders</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Create & track POs</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/manager/promotions" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-3">
                                    <span style="font-size: 1.5rem;">🏷️</span>
                                    <div>
                                        <div class="fw-bold small">Promotions</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Manage discounts</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool IsLoading = true;

    private int TotalSKUs;
    private int LowStockCount;
    private int OutOfStockCount;
    private int InStockCount;

    private List<InventoryDto>? LowStockItems;
    private List<PurchaseOrderDto>? RecentPOs;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var invTask = InventoryService.GetAll();
            var lowTask = InventoryService.GetLowStock();
            var poTask = PurchaseOrderService.GetAll();

            await Task.WhenAll(invTask, lowTask, poTask);

            var invResult = await invTask;
            if (invResult.Success && invResult.Data != null)
            {
                TotalSKUs = invResult.Data.Count;
                InStockCount = invResult.Data.Count(i => i.Quantity > i.ReorderLevel);
                LowStockCount = invResult.Data.Count(i => i.Quantity > 0 && i.IsLowStock);
                OutOfStockCount = invResult.Data.Count(i => i.Quantity == 0);
            }

            var lowResult = await lowTask;
            if (lowResult.Success && lowResult.Data != null)
                LowStockItems = lowResult.Data;

            var poResult = await poTask;
            if (poResult.Success && poResult.Data != null)
                RecentPOs = poResult.Data.OrderByDescending(p => p.OrderDate).Take(5).ToList();
        }
        catch
        {
            LowStockItems ??= new();
            RecentPOs ??= new();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private string GetStatusBadgeClass(POStatus status) => status switch
    {
        POStatus.Draft => "bg-secondary",
        POStatus.Sent => "bg-warning text-dark",
        POStatus.Received => "bg-success",
        POStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
