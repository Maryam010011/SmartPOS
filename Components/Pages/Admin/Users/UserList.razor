@page "/admin/users"
@layout AdminLayout
@using SmartPOS.Shared.DTOs.Users
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.Common
@using SmartPOS.Shared.Enums
@inject IUserService UserService
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">User Management</h2>
            <p class="text-muted m-0">Admin portal for viewing, adding, editing, and modifying POS staff credentials.</p>
        </div>
        <button type="button" class="btn btn-burnt-orange d-flex align-items-center gap-2" @onclick="OpenAddModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-person-plus-fill" viewBox="0 0 16 16">
                <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5"/>
            </svg>
            <span>Add User</span>
        </button>
    </div>

    <!-- Filters and Top Search Bar -->
    <div class="card card-pos mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-center">
                <!-- Search -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search text-muted" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 ps-0" placeholder="Search by name or email..." 
                               @bind-value="SearchTerm" @bind-value:event="oninput" @onkeyup="HandleSearch" />
                    </div>
                </div>

                <!-- Role Filter -->
                <div class="col-md-3 col-sm-6">
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label text-secondary small fw-semibold m-0">Role:</label>
                        <select class="form-select" @bind="SelectedRoleId" @bind:after="ReloadUsers">
                            <option value="-1">All Roles</option>
                            @foreach (var role in Enum.GetValues<UserRole>())
                            {
                                <option value="@((int)role)">@role.ToString()</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Status Filter -->
                <div class="col-md-3 col-sm-6">
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label text-secondary small fw-semibold m-0">Status:</label>
                        <select class="form-select" @bind="SelectedStatusString" @bind:after="ReloadUsers">
                            <option value="All">All Statuses</option>
                            <option value="Active">Active Only</option>
                            <option value="Inactive">Inactive Only</option>
                        </select>
                    </div>
                </div>

                <!-- Reset Button -->
                <div class="col-md-2 d-flex justify-content-md-end justify-content-start">
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bulk Actions Panel (Displays when items are selected) -->
    @if (SelectedUserIds.Any())
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center mb-4 p-3 border border-warning-subtle shadow-sm rounded-3">
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold">@SelectedUserIds.Count Selected</span>
                <span class="text-dark fw-semibold small">Perform bulk actions on highlighted accounts:</span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-success btn-sm fw-bold px-3 d-flex align-items-center gap-1" @onclick="HandleBulkActivate" disabled="@IsLoading">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-shield-fill-check" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m2.146 5.146a.5.5 0 0 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793z"/>
                    </svg>
                    <span>Bulk Activate</span>
                </button>
                <button class="btn btn-secondary btn-sm fw-bold px-3 d-flex align-items-center gap-1" @onclick="HandleBulkDeactivate" disabled="@IsLoading">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-shield-fill-x" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0M6.854 5.146 8 6.293l1.146-1.147a.5.5 0 1 1 .708.708L8.707 7l1.147 1.146a.5.5 0 0 1-.708.708L8 7.707l-1.146 1.147a.5.5 0 0 1-.708-.708L7.293 7 6.146 5.854a.5.5 0 1 1 .708-.708"/>
                    </svg>
                    <span>Bulk Deactivate</span>
                </button>
                <button class="btn btn-outline-dark btn-sm fw-semibold" @onclick="ClearSelection">Cancel Selection</button>
            </div>
        </div>
    }

    <!-- Main Data Table Card -->
    <div class="card card-pos">
        <div class="card-body p-0">
            @if (IsLoading)
            {
                <div class="d-flex justify-content-center align-items-center py-5 my-5 flex-column gap-3">
                    <div class="spinner-border text-burnt-orange" style="width: 3rem; height: 3rem; color: var(--color-button-primary) !important;" role="status"></div>
                    <span class="fw-semibold text-secondary">Loading system user list...</span>
                </div>
            }
            else if (UsersList == null || !UsersList.Any())
            {
                <div class="text-center py-5 my-5 flex-column">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-people text-secondary mb-3" viewBox="0 0 16 16">
                        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.274-.1-3.41-4.793-3.41C.851 9.586 0 11.2 0 12.996C0 13.996 1 14 1 14zM11 3.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0M4.5 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/>
                    </svg>
                    <h5 class="fw-bold text-dark">No Users Found</h5>
                    <p class="text-muted small">No accounts match the current filter or search criteria.</p>
                    <button class="btn btn-burnt-orange btn-sm mt-2 px-4" @onclick="ResetFilters">Reset Filter</button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-pos align-middle m-0 table-hover">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 40px; padding-left: 20px;">
                                    <input class="form-check-input" type="checkbox" checked="@IsAllSelected" @onchange="ToggleSelectAll" />
                                </th>
                                <th>Name</th>
                                <th>Email Address</th>
                                <th>Assigned Role</th>
                                <th>Account Status</th>
                                <th>Created Date</th>
                                <th class="text-end" style="padding-right: 20px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in UsersList)
                            {
                                <tr>
                                    <td style="padding-left: 20px;">
                                        <input class="form-check-input" type="checkbox" checked="@SelectedUserIds.Contains(user.Id)" 
                                               @onchange="(e) => ToggleSelectItem(user.Id, e.Value)" />
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-circle-sm" style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--color-button-primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700;">
                                                @GetInitials(user.Name)
                                            </div>
                                            <span class="fw-bold text-dark">@user.Name</span>
                                        </div>
                                    </td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="badge badge-role badge-role-@user.RoleName.ToLower()">
                                            @user.RoleName
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 rounded-pill">
                                                â -  Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1.5 rounded-pill">
                                                â -  Inactive
                                            </span>
                                        }
                                    </td>
                                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end" style="padding-right: 20px;">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm border dropdown-toggle fw-semibold" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                Manage
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => ViewProfile(user.Id)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-eye-fill" viewBox="0 0 16 16">
                                                            <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0"/>
                                                            <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8m8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/>
                                                        </svg>
                                                        <span>View Profile</span>
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item d-flex align-items-center gap-2" @onclick="() => OpenEditModal(user)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-pencil-fill" viewBox="0 0 16 16">
                                                            <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.5-.5V9h-.5a.5.5 0 0 1-.5-.5v-.5a.5.5 0 0 1 .146-.354l6-6a.5.5 0 0 1 .708 0l3.75 3.75a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.354.146z"/>
                                                        </svg>
                                                        <span>Edit Account</span>
                                                    </button>
                                                </li>
                                                <li>
                                                    @if (user.IsActive)
                                                    {
                                                        <button class="dropdown-item text-warning d-flex align-items-center gap-2" @onclick="() => HandleToggleStatus(user)">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-shield-slash-fill" viewBox="0 0 16 16">
                                                                <path fill-rule="evenodd" d="M1.093 3.093c-.496 1.46-.707 2.71-.728 3.74-.022 1.01.125 1.91.432 2.658A13 13 0 0 0 2.52 11.53c1.678 2.195 3.061 5.513 2.465 9.99a1.54 1.54 0 0 0 1.044 1.263 62 62 0 0 0 2.887.87c.307.085.6.14.887.165.289-.026.58-.08.887-.165a62 62 0 0 0 2.887-.87 1.54 1.54 0 0 0 1.044-1.263c.277-2.073-.105-3.83-.715-5.32l-1.39-1.39c.64 1.47 1.002 3.1 1.002 4.965 0 .87-.12 1.493-.306 1.95a12.8 12.8 0 0 1-2.517 2.453c-.28.132-.581.24-.829.24s-.548-.108-.829-.24A12.8 12.8 0 0 1 4.5 12.996c0-1.865.362-3.495 1.002-4.965z"/>
                                                                <path d="M14.907 13.5a8 8 0 1 0-8 8 8 8 0 0 0 8-8m-8 6.5a6.5 6.5 0 1 1 6.5-6.5 6.5 6.5 0 0 1-6.5 6.5"/>
                                                            </svg>
                                                            <span>Deactivate</span>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="dropdown-item text-success d-flex align-items-center gap-2" @onclick="() => HandleToggleStatus(user)">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-shield-check" viewBox="0 0 16 16">
                                                                <path d="M5.338 1.59a61 61 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.033.294-.117c.24-.114.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.656-.213-1.6-.496-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.457z"/>
                                                            </svg>
                                                            <span>Activate</span>
                                                        </button>
                                                    }
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <button class="dropdown-item text-danger d-flex align-items-center gap-2" @onclick="() => PromptDelete(user)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                                            <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.18a.5.5 0 0 0-.548.436l-.5 8.5a.5.5 0 1 0 .996.06l.5-8.5a.5.5 0 0 0-.436-.548M6.165 5.25a.5.5 0 0 0-.93.244l.15 8.5a.5.5 0 1 0 .99-.017l-.15-8.5z"/>
                                                        </svg>
                                                        <span>Delete Account</span>
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Pagination Footer -->
    @if (!IsLoading && UsersList != null && UsersList.Any())
    {
        <div class="d-flex justify-content-between align-items-center mt-4">
            <span class="text-secondary small fw-semibold">Page @CurrentPage</span>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm m-0 gap-1">
                    <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link border rounded fw-bold text-dark px-3 py-1.5" @onclick="PreviousPage">Previous</button>
                    </li>
                    <li class="page-item active">
                        <span class="page-link rounded px-3 py-1.5 fw-bold" style="background-color: var(--color-button-primary); border-color: var(--color-button-primary);">@CurrentPage</span>
                    </li>
                    <li class="page-item @(UsersList.Count < PageSize ? "disabled" : "")">
                        <button class="page-link border rounded fw-bold text-dark px-3 py-1.5" @onclick="NextPage">Next</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal Components Reference -->
<UserFormModal @ref="FormModal" OnSave="ReloadUsers" />
<UserProfileModal @ref="ProfileModal" OnEditRequested="OpenEditFromProfile" OnStatusChanged="ReloadUsers" />

<!-- Standard CSS Delete Confirmation Modal -->
@if (DeletePromptVisible && DeleteUserTarget != null)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content card-pos border border-danger-subtle">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger">Confirm Soft Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="m-0 text-dark">
                        Are you sure you want to delete user <strong>@DeleteUserTarget.Name</strong>?
                    </p>
                    <p class="text-muted small mt-2 m-0 border-start border-3 ps-2 border-danger-subtle">
                        * Note: This is a <strong>soft delete</strong>. The user's account will be deactivated and hidden from regular POS functions, but their historical transaction data will remain saved.
                    </p>
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger px-4 fw-bold" @onclick="ConfirmDelete" disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <span>Soft Delete</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show modal-backdrop-pos"></div>
}

@code {
    private List<UserDto>? UsersList { get; set; }
    private List<int> SelectedUserIds { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    // Filter values
    private string SearchTerm { get; set; } = string.Empty;
    private int SelectedRoleId { get; set; } = -1;
    private string SelectedStatusString { get; set; } = "All";
    private int CurrentPage { get; set; } = 1;
    private const int PageSize = 10;

    // Modals Ref
    private UserFormModal? FormModal { get; set; }
    private UserProfileModal? ProfileModal { get; set; }

    // Delete Prompt State
    private bool DeletePromptVisible { get; set; }
    private UserDto? DeleteUserTarget { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            bool? isActiveFilter = null;
            if (SelectedStatusString == "Active") isActiveFilter = true;
            if (SelectedStatusString == "Inactive") isActiveFilter = false;

            var filter = new UserFilterDto
            {
                RoleId = SelectedRoleId == -1 ? null : SelectedRoleId,
                IsActive = isActiveFilter,
                SearchTerm = SearchTerm,
                Page = CurrentPage,
                PageSize = PageSize
            };

            var response = await UserService.GetAllUsers(filter);
            if (response.Success)
            {
                UsersList = response.Data;
            }
            else
            {
                UsersList = new List<UserDto>();
            }
        }
        catch (Exception)
        {
            UsersList = new List<UserDto>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadUsers()
    {
        SelectedUserIds.Clear();
        await LoadUsers();
    }

    private async Task ResetFilters()
    {
        SearchTerm = string.Empty;
        SelectedRoleId = -1;
        SelectedStatusString = "All";
        CurrentPage = 1;
        await ReloadUsers();
    }

    private async Task HandleSearch()
    {
        CurrentPage = 1;
        await ReloadUsers();
    }

    // Modal Triggers
    private void OpenAddModal()
    {
        FormModal?.OpenAdd();
    }

    private void OpenEditModal(UserDto user)
    {
        FormModal?.OpenEdit(user);
    }

    private void OpenEditFromProfile(UserDto user)
    {
        FormModal?.OpenEdit(user);
    }

    private async Task ViewProfile(int userId)
    {
        if (ProfileModal != null)
        {
            await ProfileModal.Open(userId);
        }
    }

    // Table Select Operations
    private bool IsAllSelected => UsersList != null && UsersList.Any() && UsersList.All(u => SelectedUserIds.Contains(u.Id));

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (UsersList == null) return;
        var checkedState = (bool)(e.Value ?? false);

        if (checkedState)
        {
            foreach (var user in UsersList)
            {
                if (!SelectedUserIds.Contains(user.Id))
                {
                    SelectedUserIds.Add(user.Id);
                }
            }
        }
        else
        {
            foreach (var user in UsersList)
            {
                SelectedUserIds.Remove(user.Id);
            }
        }
    }

    private void ToggleSelectItem(int userId, object? value)
    {
        var checkedState = (bool)(value ?? false);
        if (checkedState)
        {
            if (!SelectedUserIds.Contains(userId))
            {
                SelectedUserIds.Add(userId);
            }
        }
        else
        {
            SelectedUserIds.Remove(userId);
        }
    }

    private void ClearSelection()
    {
        SelectedUserIds.Clear();
    }

    // Status Modifiers
    private async Task HandleToggleStatus(UserDto user)
    {
        IsLoading = true;
        StateHasChanged();
        try
        {
            ApiResponse response;
            if (user.IsActive)
            {
                response = await UserService.DeactivateUser(user.Id);
            }
            else
            {
                response = await UserService.ActivateUser(user.Id);
            }

            if (response.Success)
            {
                await ReloadUsers();
            }
        }
        catch (Exception)
        {
            // Fail silently or handle
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    // Bulk Activations
    private async Task HandleBulkActivate()
    {
        if (!SelectedUserIds.Any()) return;
        IsLoading = true;
        StateHasChanged();

        try
        {
            var response = await UserService.BulkActivate(SelectedUserIds);
            if (response.Success)
            {
                await ReloadUsers();
            }
        }
        catch (Exception) { }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

