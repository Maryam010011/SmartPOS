@page "/admin/dashboard"
@layout AdminLayout
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.DTOs.Users
@using SmartPOS.Shared.DTOs.Customers
@using SmartPOS.Shared.DTOs.Inventory
@using SmartPOS.Shared.DTOs.PurchaseOrders
@using SmartPOS.Shared.DTOs.Weather
@using SmartPOS.Shared.Common
@using SmartPOS.Shared.Enums
@inject IUserService UserService
@inject ICustomerService CustomerService
@inject IInventoryService InventoryService
@inject IPurchaseOrderService PurchaseOrderService
@inject IWeatherService WeatherService
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Admin Dashboard</h2>
            <p class="text-muted m-0">System overview and key business metrics at a glance.</p>
        </div>
        <div class="text-end">
            @if (Weather != null)
            {
                <div class="d-flex align-items-center gap-2 text-muted small">
                    <span>ðŸŒ¤ @Weather.City</span>
                    <span class="fw-bold">@Weather.Temperature°C</span>
                    <span>@Weather.Condition</span>
                </div>
            }
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--color-button-primary);" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2">Loading dashboard data...</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(204, 85, 0, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#CC5500" viewBox="0 0 16 16"><path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.274-.1-3.41-4.793-3.41C.851 9.586 0 11.2 0 12.996C0 13.996 1 14 1 14zM11 3.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0M4.5 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Total Users</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: var(--color-button-primary);">@TotalUsers</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(204, 85, 0, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#CC5500" viewBox="0 0 16 16"><path d="M2 1a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h5v2H4.5a.5.5 0 0 0-.5.5v.5h-.5a.5.5 0 0 0-.5.5v.5H2.5a.5.5 0 0 0-.5.5v.5H1.5a.5.5 0 0 0 0 1h13a.5.5 0 0 0 0-1h-.5V13a.5.5 0 0 0-.5-.5h-2.5a.5.5 0 0 0-.5.5v.5H9v-2h5V7a1 1 0 0 0-1-1H9V5h2.5a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3A.5.5 0 0 0 8 1.5V2H6V1.5A.5.5 0 0 0 5.5 1z"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Total Products (Stock)</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: var(--color-button-primary);">@TotalStockItems</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100" style="border-left: 4px solid #dc3545 !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(220, 53, 69, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#dc3545" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Low Stock Items</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: #dc3545;">@LowStockCount</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card card-pos border-0 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(204, 85, 0, 0.1); flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#CC5500" viewBox="0 0 16 16"><path d="M0 2.5A1.5 1.5 0 0 1 1.5 1h11A1.5 1.5 0 0 1 14 2.5v10.528c0 .3-.05.654-.238.972h.738a.5.5 0 0 1 .5.5a.5.5 0 0 1-.5.5H1.497a.5.5 0 0 1-.5-.5a.5.5 0 0 1 .5-.5h.738c-.188-.318-.238-.673-.238-.972V2.5Zm3.5 4.5a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1h-6Zm0-2a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1h-6Zm0 4a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1h-6Z"/></svg>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Pending POs</div>
                            <div class="fw-bold" style="font-size: 1.75rem; color: var(--color-button-primary);">@PendingPOCount</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card card-pos h-100">
                    <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Recent Users</h6>
                        <a href="/admin/users" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="card-body p-0">
                        @if (RecentUsers == null || !RecentUsers.Any())
                        {
                            <div class="text-center py-4 text-muted small">No users found.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-pos align-middle m-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="padding-left: 20px;">Name</th>
                                            <th>Email</th>
                                            <th>Role</th>
                                            <th class="text-end" style="padding-right: 20px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in RecentUsers)
                                        {
                                            <tr>
                                                <td style="padding-left: 20px;"><span class="fw-bold text-dark">@user.Name</span></td>
                                                <td class="text-muted small">@user.Email</td>
                                                <td><span class="badge badge-role badge-role-@user.RoleName.ToLower()">@user.RoleName</span></td>
                                                <td class="text-end" style="padding-right: 20px;">
                                                    @if (user.IsActive)
                                                    {
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 rounded-pill">â— Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1.5 rounded-pill">â— Inactive</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card card-pos h-100">
                    <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Inventory Status</h6>
                        <a href="/admin/products" class="btn btn-sm btn-outline-secondary">Manage</a>
                    </div>
                    <div class="card-body p-0">
                        @if (LowStockItems == null || !LowStockItems.Any())
                        {
                            <div class="text-center py-4 text-muted small">All items are well-stocked.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-pos align-middle m-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="padding-left: 20px;">Product</th>
                                            <th>Qty</th>
                                            <th>Reorder Level</th>
                                            <th class="text-end" style="padding-right: 20px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in LowStockItems.Take(5))
                                        {
                                            <tr>
                                                <td style="padding-left: 20px;"><span class="fw-bold text-dark">@item.ProductName</span></td>
                                                <td class="fw-semibold">@item.Quantity</td>
                                                <td class="text-muted">@item.ReorderLevel</td>
                                                <td class="text-end" style="padding-right: 20px;">
                                                    @if (item.Quantity == 0)
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1.5 rounded-pill">â— Out of Stock</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge px-2 py-1.5 rounded-pill" style="background-color: rgba(204, 85, 0, 0.15); color: #CC5500; border: 1px solid rgba(204, 85, 0, 0.3);">â— Low Stock</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-md-6">
                <div class="card card-pos h-100">
                    <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Recent Purchase Orders</h6>
                        <a href="/manager/purchase-orders" class="btn btn-sm btn-outline-secondary">View All</a>
                    </div>
                    <div class="card-body p-0">
                        @if (RecentPOs == null || !RecentPOs.Any())
                        {
                            <div class="text-center py-4 text-muted small">No purchase orders yet.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-pos align-middle m-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="padding-left: 20px;">PO #</th>
                                            <th>Supplier</th>
                                            <th>Total</th>
                                            <th class="text-end" style="padding-right: 20px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var po in RecentPOs)
                                        {
                                            <tr>
                                                <td style="padding-left: 20px;"><span class="fw-bold text-dark">#@po.Id</span></td>
                                                <td class="text-muted small">@po.SupplierName</td>
                                                <td class="fw-semibold">$@po.TotalCost.ToString("N2")</td>
                                                <td class="text-end" style="padding-right: 20px;">
                                                    <span class="badge @(po.Status == POStatus.Received ? "bg-success" : po.Status == POStatus.Cancelled ? "bg-danger" : po.Status == POStatus.Draft ? "bg-secondary" : "bg-warning text-dark") px-2 py-1.5 rounded-pill">@po.Status</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card card-pos h-100">
                    <div class="card-header bg-transparent border-bottom-0 pt-3 px-4">
                        <h6 class="fw-bold m-0" style="color: var(--color-button-primary);">Quick Links</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-6">
                                <a href="/admin/users" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-2">
                                    <span>ðŸ‘¥</span> <span>User Management</span>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/admin/roles" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-2">
                                    <span>ðŸ›¡</span> <span>Roles & Permissions</span>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/admin/customers" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-2">
                                    <span>ðŸ‘¤</span> <span>Customers</span>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/admin/products" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-2">
                                    <span>ðŸ“¦</span> <span>Products</span>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/manager/inventory" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-2">
                                    <span>ðŸ“Š</span> <span>Inventory</span>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/admin/promotions" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 py-2">
                                    <span>ðŸ·</span> <span>Promotions</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool IsLoading = true;

    private int TotalUsers;
    private int TotalStockItems;
    private int LowStockCount;
    private int PendingPOCount;

    private List<UserDto>? RecentUsers;
    private List<InventoryDto>? LowStockItems;
    private List<PurchaseOrderDto>? RecentPOs;
    private WeatherDto? Weather;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var userTask = UserService.GetAllUsers(new UserFilterDto { Page = 1, PageSize = 10 });
            var invTask = InventoryService.GetAll();
            var lowStockTask = InventoryService.GetLowStock();
            var poTask = PurchaseOrderService.GetAll();
            var weatherTask = WeatherService.GetCurrentWeather("Lahore");

            await Task.WhenAll(userTask, invTask, lowStockTask, poTask, weatherTask);

            var userResult = await userTask;
            if (userResult.Success && userResult.Data != null)
            {
                RecentUsers = userResult.Data.Take(5).ToList();
                TotalUsers = userResult.Data.Count;
            }

            var invResult = await invTask;
            if (invResult.Success && invResult.Data != null)
            {
                TotalStockItems = invResult.Data.Count;
            }

            var lowResult = await lowStockTask;
            if (lowResult.Success && lowResult.Data != null)
            {
                LowStockItems = lowResult.Data;
                LowStockCount = lowResult.Data.Count;
            }

            var poResult = await poTask;
            if (poResult.Success && poResult.Data != null)
            {
                RecentPOs = poResult.Data.OrderByDescending(p => p.OrderDate).Take(5).ToList();
                PendingPOCount = poResult.Data.Count(p => p.Status == POStatus.Draft || p.Status == POStatus.Sent);
            }

            var wResult = await weatherTask;
            if (wResult.Success && wResult.Data != null)
                Weather = wResult.Data;
        }
        catch
        {
            RecentUsers ??= new();
            LowStockItems ??= new();
            RecentPOs ??= new();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
