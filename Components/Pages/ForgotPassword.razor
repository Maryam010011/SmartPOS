@page "/forgot-password"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IAuthService AuthService
@using SmartPOS.Shared.Interfaces

<div class="recovery-page">
    <div class="recovery-card">
        <div class="recovery-header">
            <div class="recovery-logo">🔑</div>
            <h2>Password Recovery</h2>
            <p class="text-muted">Recover your sweet account credentials</p>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger py-2 small">@Error</div>
        }

        @if (!string.IsNullOrEmpty(Info))
        {
            <div class="alert alert-info py-2 small">@Info</div>
        }

        @if (Step == 1)
        {
            <EditForm Model="@RequestModel" OnValidSubmit="HandleRequestCode" FormName="requestCodeForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Email Address</label>
                    <InputText @bind-Value="RequestModel.Email" class="form-control" placeholder="you@smartpos.pk" required />
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <a href="/login" class="text-burnt-orange small fw-semibold text-decoration-none"> Back to Login</a>
                </div>

                <button type="submit" class="btn btn-burnt-orange w-100 py-2 fw-semibold" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Send Recovery Code
                </button>
            </EditForm>
        }
        else if (Step == 2)
        {
            @if (!string.IsNullOrEmpty(SimulatedCode))
            {
                <div class="alert alert-warning py-2 mb-3 small" style="border: 1px dashed var(--color-button-primary);">
                     <strong>Simulated Code (Copy this):</strong> <code style="font-size: 1.1rem; color: #CC5500;">@SimulatedCode</code>
                </div>
            }

            <EditForm Model="@ResetModel" OnValidSubmit="HandleResetPassword" FormName="resetPasswordForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">6-Digit Verification Code</label>
                    <InputText @bind-Value="ResetModel.Code" class="form-control text-center fw-bold" placeholder="123456" maxlength="6" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">New Password</label>
                    <InputText @bind-Value="ResetModel.NewPassword" type="password" class="form-control" placeholder="" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Confirm New Password</label>
                    <InputText @bind-Value="ResetModel.ConfirmPassword" type="password" class="form-control" placeholder="" required />
                </div>

                <button type="submit" class="btn btn-burnt-orange w-100 py-2 fw-semibold" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Reset Password
                </button>
            </EditForm>
        }
        else if (Step == 3)
        {
            <div class="text-center py-3">
                <span style="font-size: 3rem;">ðŸŽ‰</span>
                <h4 class="mt-2 fw-bold text-success">Password Updated!</h4>
                <p class="text-muted small">Your password has been successfully reset. You can now log in using your new credentials.</p>
                <a href="/login" class="btn btn-burnt-orange px-4 py-2 mt-2 fw-semibold">Sign In</a>
            </div>
        }
    </div>
</div>

<style>
    .recovery-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%); padding: 1rem; font-family: 'Inter', sans-serif; }
    .recovery-card { background: white; border-radius: 20px; box-shadow: 0 10px 45px rgba(0,0,0,0.08); padding: 2.5rem; width: 100%; max-width: 440px; border: 1px solid rgba(204, 85, 0, 0.1); }
    .recovery-header { text-align: center; margin-bottom: 2rem; }
    .recovery-logo { display: inline-flex; align-items: center; justify-content: center; width: 72px; height: 72px; border-radius: 50%; background: #FFE8D6; font-size: 2.5rem; margin-bottom: 1rem; box-shadow: 0 4px 15px rgba(204, 85, 0, 0.15); }
    .recovery-header h2 { font-weight: 800; color: #4A2C2A; margin: 0; font-size: 1.8rem; }
    .recovery-header p { font-size: 0.9rem; margin-top: 0.5rem; }
    .form-control:focus { border-color: #CC5500; box-shadow: 0 0 0 0.25rem rgba(204, 85, 0, 0.25); }
    .btn-burnt-orange { background-color: #CC5500; color: white; border: none; transition: background-color 0.2s; }
    .btn-burnt-orange:hover { background-color: #A34400; color: white; }
    .text-burnt-orange { color: #CC5500; }
    .text-burnt-orange:hover { color: #A34400; }
</style>

@code {
    private int Step = 1;
    private bool IsLoading;
    private string? Error;
    private string? Info;
    private string? SimulatedCode;

    private RequestCodeModel RequestModel = new();
    private ResetPasswordModel ResetModel = new();

    private class RequestCodeModel
    {
        public string Email { get; set; } = string.Empty;
    }

    private class ResetPasswordModel
    {
        public string Code { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private async Task HandleRequestCode()
    {
        IsLoading = true;
        Error = null;
        Info = null;
        StateHasChanged();

        try
        {
            var response = await AuthService.ForgotPassword(RequestModel.Email);
            if (response.Success)
            {
                // The forgot password service returns the code directly in the Message property
                SimulatedCode = response.Message;
                Info = "We found your email and generated a recovery verification code.";
                Step = 2;
            }
            else
            {
                Error = response.Message ?? "Email not found.";
            }
        }
        catch (Exception ex)
        {
            Error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleResetPassword()
    {
        if (ResetModel.NewPassword != ResetModel.ConfirmPassword)
        {
            Error = "Passwords do not match.";
            return;
        }

        if (ResetModel.NewPassword.Length < 6)
        {
            Error = "Password must be at least 6 characters long.";
            return;
        }

        IsLoading = true;
        Error = null;
        Info = null;
        StateHasChanged();

        try
        {
            var response = await AuthService.ResetPassword(RequestModel.Email, ResetModel.Code, ResetModel.NewPassword);
            if (response.Success)
            {
                Step = 3;
            }
            else
            {
                Error = response.Message ?? "Invalid verification code.";
            }
        }
        catch (Exception ex)
        {
            Error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
