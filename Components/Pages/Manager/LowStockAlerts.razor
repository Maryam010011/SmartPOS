@page "/manager/low-stock"
@layout ManagerLayout
@rendermode InteractiveServer

@inject IInventoryService InventoryService
@inject IProductService ProductService
@inject NavigationManager Navigation

<PageTitle>Low Stock &amp; Reorder Alerts</PageTitle>

<div class="ls-page p-4">

    @* ── Page Header & KPI Summary ───────────────────────────────── *@
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-start gap-4 mb-5">
        <div>
            <div class="ls-page-eyebrow mb-1">Inventory Intelligence</div>
            <h1 class="ls-page-title mb-1">Low Stock &amp; Reorder Alerts</h1>
            <p class="ls-page-subtitle mb-0">
                Monitor products approaching their reorder thresholds and take immediate action.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-3 flex-shrink-0">
            <div class="ls-kpi-card ls-kpi-critical">
                <div class="ls-kpi-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                    </svg>
                </div>
                <div>
                    <div class="ls-kpi-label">Critical Items</div>
                    <div class="ls-kpi-value">@CriticalCount</div>
                </div>
            </div>
            <div class="ls-kpi-card ls-kpi-warning">
                <div class="ls-kpi-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41m-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5 5 0 0 0 8 3M3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9z"/>
                    </svg>
                </div>
                <div>
                    <div class="ls-kpi-label">At Reorder Level</div>
                    <div class="ls-kpi-value">@AtLevelCount</div>
                </div>
            </div>
            <div class="ls-kpi-card ls-kpi-total">
                <div class="ls-kpi-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5M3.14 5l1.25 5h8.22l1.25-5zM5 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0m9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0"/>
                    </svg>
                </div>
                <div>
                    <div class="ls-kpi-label">Total Alerts</div>
                    <div class="ls-kpi-value">@TotalAlerts</div>
                </div>
            </div>
        </div>
    </div>

    @* ── Status Messages ─────────────────────────────────────────── *@
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="ls-alert ls-alert-error mb-4" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
            </svg>
            <div><strong>Failed to load.</strong> @ErrorMessage</div>
        </div>
    }

    @* ── Search, Filter & Refresh Controls ──────────────────────── *@
    <div class="ls-controls-bar mb-4">
        <div class="ls-search-wrap">
            <svg class="ls-search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/>
            </svg>
            <input id="ls-search-input"
                   class="ls-search-input"
                   type="text"
                   placeholder="Search by product name, SKU, or ID…"
                   value="@SearchText"
                   @oninput="OnSearchInput" />
            @if (!string.IsNullOrWhiteSpace(SearchText))
            {
                <button class="ls-search-clear" type="button" @onclick="ClearSearch" aria-label="Clear search">&times;</button>
            }
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <button id="ls-sort-toggle"
                    class="btn ls-filter-btn @(SortByUrgency ? "ls-filter-btn-active" : "")"
                    type="button"
                    @onclick="ToggleSortByUrgency">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                    <path d="M3.5 2.5a.5.5 0 0 0-1 0v8.793l-1.146-1.147a.5.5 0 0 0-.708.708l2 1.999.007.007a.497.497 0 0 0 .7-.006l2-2a.5.5 0 0 0-.707-.708L3.5 11.293zm3.5 1a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5M7.5 6a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zm0 3a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1zm0 3a.5.5 0 0 0 0 1h1a.5.5 0 0 0 0-1z"/>
                </svg>
                @(SortByUrgency ? "Most Urgent First" : "Sort: Default")
            </button>
            <button id="ls-refresh-btn"
                    class="btn ls-refresh-btn"
                    type="button"
                    @onclick="RefreshAsync"
                    disabled="@IsLoading"
                    title="Refresh alerts">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="@(IsLoading ? "ls-spin" : "")">
                    <path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41m-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5 5 0 0 0 8 3M3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9z"/>
                </svg>
                <span class="ms-1 d-none d-sm-inline">@(IsLoading ? "Refreshing…" : "Refresh")</span>
            </button>
        </div>
    </div>

    @* ── Main Content: Loading / Empty / Table ────────────────────── *@
    @if (lowStockItems == null)
    {
        @* Loading skeleton state *@
        <div class="ls-card">
            <div class="ls-skeleton-header p-3 ls-border-bottom">
                <div class="ls-skeleton ls-skeleton-text" style="width: 180px; height: 16px;"></div>
                <div class="ls-skeleton ls-skeleton-text" style="width: 80px; height: 24px; border-radius: 20px;"></div>
            </div>
            <div class="table-responsive">
                <table class="table ls-table mb-0">
                    <thead class="ls-table-head">
                        <tr>
                            <th>Product</th>
                            <th>SKU / ID</th>
                            <th>Current Stock</th>
                            <th>Reorder Level</th>
                            <th>Deficit</th>
                            <th>Last Updated</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var s = 0; s < 5; s++)
                        {
                            <tr>
                                <td><div class="ls-skeleton ls-skeleton-text" style="width: 130px; height: 14px;"></div></td>
                                <td><div class="ls-skeleton ls-skeleton-text" style="width: 80px; height: 14px;"></div></td>
                                <td><div class="ls-skeleton ls-skeleton-text" style="width: 60px; height: 14px;"></div></td>
                                <td><div class="ls-skeleton ls-skeleton-text" style="width: 60px; height: 14px;"></div></td>
                                <td><div class="ls-skeleton ls-skeleton-text" style="width: 50px; height: 14px;"></div></td>
                                <td><div class="ls-skeleton ls-skeleton-text" style="width: 100px; height: 14px;"></div></td>
                                <td class="text-end"><div class="ls-skeleton ls-skeleton-text" style="width: 110px; height: 32px; border-radius: 6px; margin-left: auto;"></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <section class="ls-card">
            @* Table header strip *@
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 ls-border-bottom">
                <div>
                    <h2 class="ls-section-title mb-0">Alert Register</h2>
                    <p class="ls-section-subtitle mb-0">Products at or below their reorder threshold require immediate procurement action.</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (!string.IsNullOrWhiteSpace(SearchText))
                    {
                        <span class="ls-filter-tag">
                            &ldquo;@SearchText&rdquo;
                            <button class="ls-filter-tag-close" type="button" @onclick="ClearSearch">&times;</button>
                        </span>
                    }
                    <span class="ls-count-badge">@DisplayedItems.Count alert(s)</span>
                </div>
            </div>

            @* Data table *@
            <div class="table-responsive">
                <table class="table ls-table mb-0" id="ls-alert-table">
                    <thead class="ls-table-head">
                        <tr>
                            <th scope="col">Product</th>
                            <th scope="col">SKU / ID</th>
                            <th scope="col">Current Stock</th>
                            <th scope="col">Reorder Level</th>
                            <th scope="col">Deficit</th>
                            <th scope="col">Last Updated</th>
                            <th scope="col" class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (DisplayedItems.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="p-5 text-center">
                                    <div class="ls-empty-state">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                            <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05"/>
                                        </svg>
                                        <div class="ls-empty-title">
                                            @(string.IsNullOrWhiteSpace(SearchText)
                                                ? "All Clear — No Low Stock Items"
                                                : "No Results Found")
                                        </div>
                                        <div class="ls-empty-subtitle">
                                            @(string.IsNullOrWhiteSpace(SearchText)
                                                ? "All inventory levels are currently above their reorder thresholds."
                                                : $"No alerts match \"{SearchText}\". Try a different search term.")
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(SearchText))
                                        {
                                            <button class="btn ls-btn-outline mt-3" type="button" @onclick="ClearSearch">Clear Search</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in PagedItems)
                            {
                                var deficit = item.ReorderLevel - item.Quantity;
                                var isCritical = item.Quantity == 0;
                                var urgencyClass = GetUrgencyRowClass(item);

                                <tr class="ls-table-row @urgencyClass" id="ls-row-@item.Id">
                                    @* Product Name + Supplier *@
                                    <td class="p-3">
                                        <div class="ls-product-name">@item.ProductName</div>
                                        <div class="ls-product-supplier">@GetSupplier(item.ProductId)</div>
                                    </td>
                                    @* SKU / Product ID *@
                                    <td class="p-3">
                                        <div class="ls-sku-pill">@GetSku(item.ProductId)</div>
                                        <div class="ls-product-id">ID: @item.ProductId</div>
                                    </td>
                                    @* Current Stock with urgency badge *@
                                    <td class="p-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="ls-stock-value @(isCritical ? "ls-stock-zero" : "ls-stock-low")">@item.Quantity</span>
                                            <span class="ls-urgency-badge @GetUrgencyBadgeClass(item)">
                                                @GetUrgencyLabel(item)
                                            </span>
                                        </div>
                                    </td>
                                    @* Reorder Level *@
                                    <td class="p-3">
                                        <span class="ls-reorder-level">@item.ReorderLevel</span>
                                    </td>
                                    @* Deficit *@
                                    <td class="p-3">
                                        <span class="ls-deficit @(deficit > 0 ? "ls-deficit-positive" : "ls-deficit-met")">
                                            @(deficit > 0 ? $"+{deficit}" : "—")
                                        </span>
                                    </td>
                                    @* Last Updated *@
                                    <td class="p-3">
                                        <span class="ls-date">@item.LastUpdated.ToLocalTime().ToString("dd MMM yyyy")</span>
                                        <div class="ls-time">@item.LastUpdated.ToLocalTime().ToString("HH:mm")</div>
                                    </td>
                                    @* Quick Reorder Button *@
                                    <td class="p-3 text-end">
                                        <button id="ls-reorder-@item.Id"
                                                class="btn ls-btn-reorder"
                                                type="button"
                                                @onclick="() => NavigateToPurchaseOrders(item)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                                                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                                            </svg>
                                            Quick Reorder
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination Footer *@
            @if (TotalPages > 1)
            {
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 p-3 ls-border-top">
                    <p class="mb-0 ls-page-info">
                        Showing <strong>@PagedItems.Count</strong> of <strong>@DisplayedItems.Count</strong> alerts
                    </p>
                    <div class="btn-group" role="group" aria-label="Alert list pagination">
                        <button class="btn ls-btn-outline btn-sm" type="button" @onclick="PreviousPage" disabled="@IsFirstPage">&lsaquo;</button>
                        @foreach (var page in Enumerable.Range(1, TotalPages))
                        {
                            <button class="btn @(page == CurrentPage ? "ls-btn-primary" : "ls-btn-outline") btn-sm ls-page-btn"
                                    type="button"
                                    @onclick="() => GoToPage(page)">
                                @(page)
                            </button>
                        }
                        <button class="btn ls-btn-outline btn-sm" type="button" @onclick="NextPage" disabled="@IsLastPage">&rsaquo;</button>
                    </div>
                </div>
            }
            else if (DisplayedItems.Count > 0)
            {
                <div class="p-3 ls-border-top">
                    <p class="mb-0 ls-page-info">Showing all <strong>@DisplayedItems.Count</strong> alert(s)</p>
                </div>
            }
        </section>
    }

    @* ── Quick Navigation Links ──────────────────────────────────── *@
    <div class="d-flex flex-wrap gap-3 mt-4">
        <button class="btn ls-nav-link-btn" type="button" @onclick='() => Navigation.NavigateTo("/manager/inventory")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5m0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
                <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2m0 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1z"/>
            </svg>
            View Full Inventory
        </button>
        <button class="btn ls-nav-link-btn" type="button" @onclick='() => Navigation.NavigateTo("/manager/purchase-orders")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                <path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5M3.14 5l1.25 5h8.22l1.25-5zM5 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0m9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0"/>
            </svg>
            All Purchase Orders
        </button>
    </div>
</div>

@* ─────────────────────────────────────────────────────────────────── *@
@*  STYLES                                                             *@
@* ─────────────────────────────────────────────────────────────────── *@
<style>
    /* ── Page container ─────────────────────────────────────────── */
    .ls-page {
        background-color: var(--color-page-bg);
        color: var(--color-primary-text);
        min-height: 100%;
    }

    /* ── Page header typography ─────────────────────────────────── */
    .ls-page-eyebrow {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
    }

    .ls-page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--color-heading-text);
        line-height: 1.2;
    }

    .ls-page-subtitle {
        font-size: 0.9rem;
        color: color-mix(in srgb, var(--color-primary-text) 65%, transparent);
        max-width: 480px;
    }

    /* ── KPI Cards ──────────────────────────────────────────────── */
    .ls-kpi-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 22px;
        border-radius: 12px;
        background-color: var(--color-card-bg);
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 25%, transparent);
        min-width: 160px;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .ls-kpi-card:hover {
        box-shadow: 0 6px 20px color-mix(in srgb, var(--color-border-accent) 18%, transparent);
        transform: translateY(-2px);
    }

    .ls-kpi-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 10px;
        flex-shrink: 0;
    }

    .ls-kpi-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: color-mix(in srgb, var(--color-primary-text) 55%, transparent);
        margin-bottom: 3px;
    }

    .ls-kpi-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-heading-text);
        line-height: 1;
    }

    /* Critical = Dusty Rose accent (zero stock items) */
    .ls-kpi-critical .ls-kpi-icon {
        background-color: color-mix(in srgb, var(--color-accent) 15%, var(--color-card-bg));
        color: var(--color-accent);
        border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    }

    .ls-kpi-critical { border-left: 3px solid var(--color-accent); }

    /* Warning = muted border (at-level items) */
    .ls-kpi-warning .ls-kpi-icon {
        background-color: color-mix(in srgb, var(--color-border-accent) 12%, var(--color-card-bg));
        color: color-mix(in srgb, var(--color-heading-text) 80%, var(--color-accent));
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 25%, transparent);
    }

    .ls-kpi-warning { border-left: 3px solid var(--color-border-accent); }

    /* Total = neutral */
    .ls-kpi-total .ls-kpi-icon {
        background-color: color-mix(in srgb, var(--color-navbar-bg) 8%, var(--color-card-bg));
        color: color-mix(in srgb, var(--color-heading-text) 75%, transparent);
        border: 1px solid color-mix(in srgb, var(--color-navbar-bg) 15%, transparent);
    }

    .ls-kpi-total { border-left: 3px solid color-mix(in srgb, var(--color-navbar-bg) 30%, transparent); }

    /* ── Alert messages ─────────────────────────────────────────── */
    .ls-alert {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 8px;
        font-size: 0.9rem;
        border: 1px solid;
    }

    .ls-alert-error {
        background-color: color-mix(in srgb, var(--color-border-accent) 8%, var(--color-page-bg));
        border-color: color-mix(in srgb, var(--color-border-accent) 40%, transparent);
        color: var(--color-heading-text);
    }

    /* ── Controls bar ───────────────────────────────────────────── */
    .ls-controls-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
    }

    /* ── Search ─────────────────────────────────────────────────── */
    .ls-search-wrap {
        position: relative;
        display: flex;
        align-items: center;
        flex: 1;
        min-width: 240px;
    }

    .ls-search-icon {
        position: absolute;
        left: 12px;
        color: color-mix(in srgb, var(--color-primary-text) 45%, transparent);
        pointer-events: none;
    }

    .ls-search-input {
        width: 100%;
        padding: 9px 36px 9px 36px;
        background-color: var(--color-card-bg);
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 35%, transparent);
        border-radius: 8px;
        color: var(--color-primary-text);
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .ls-search-input::placeholder {
        color: color-mix(in srgb, var(--color-primary-text) 40%, transparent);
    }

    .ls-search-input:focus {
        border-color: var(--color-border-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
    }

    .ls-search-clear {
        position: absolute;
        right: 10px;
        background: none;
        border: none;
        color: color-mix(in srgb, var(--color-primary-text) 45%, transparent);
        cursor: pointer;
        font-size: 1.1rem;
        line-height: 1;
        padding: 2px 4px;
        transition: color 0.15s ease;
    }

    .ls-search-clear:hover { color: var(--color-primary-text); }

    /* ── Filter / Refresh buttons ───────────────────────────────── */
    .ls-filter-btn {
        background-color: var(--color-card-bg);
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 35%, transparent);
        color: var(--color-primary-text);
        padding: 8px 14px;
        font-size: 0.8rem;
        font-weight: 500;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        transition: all 0.15s ease;
        white-space: nowrap;
    }

    .ls-filter-btn:hover {
        background-color: color-mix(in srgb, var(--color-border-accent) 10%, var(--color-card-bg));
        border-color: var(--color-border-accent);
    }

    .ls-filter-btn-active {
        background-color: color-mix(in srgb, var(--color-accent) 12%, var(--color-card-bg));
        border-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
        color: var(--color-heading-text);
    }

    .ls-refresh-btn {
        background-color: var(--color-card-bg);
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 35%, transparent);
        color: var(--color-primary-text);
        padding: 8px 14px;
        font-size: 0.8rem;
        font-weight: 500;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        transition: all 0.15s ease;
    }

    .ls-refresh-btn:hover:not(:disabled) {
        background-color: color-mix(in srgb, var(--color-border-accent) 10%, var(--color-card-bg));
        border-color: var(--color-border-accent);
    }

    .ls-refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    @@keyframes ls-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .ls-spin { animation: ls-spin 0.8s linear infinite; }

    /* ── Card ───────────────────────────────────────────────────── */
    .ls-card {
        background-color: var(--color-card-bg);
        border: 1px solid color-mix(in srgb, var(--color-border-accent) 25%, transparent);
        border-radius: 12px;
        overflow: hidden;
    }

    .ls-border-bottom { border-bottom: 1px solid color-mix(in srgb, var(--color-border-accent) 20%, transparent); }
    .ls-border-top    { border-top:    1px solid color-mix(in srgb, var(--color-border-accent) 20%, transparent); }

    /* ── Section header ─────────────────────────────────────────── */
    .ls-section-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-heading-text);
    }

    .ls-section-subtitle {
        font-size: 0.78rem;
        color: color-mix(in srgb, var(--color-primary-text) 55%, transparent);
        margin-top: 2px;
    }

    .ls-count-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        background-color: var(--color-badge);
        color: var(--color-page-bg);
        white-space: nowrap;
