@page "/customer/orders"
@rendermode InteractiveServer
@layout CustomerLayout

@inject ISaleService SaleService
@inject NavigationManager NavigationManager

<PageTitle>My Orders â€” SmartPOS+ Bakery</PageTitle>

<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     ORDER HISTORY ROOT
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
<div class="oh-root">

    <!-- â”€â”€ PAGE HEADER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <header class="oh-page-header">
        <div class="oh-header-left">
            <span class="oh-header-icon">ðŸ§¾</span>
            <div>
                <h1 class="oh-title">My Orders</h1>
                <p class="oh-subtitle">Browse and track your complete purchase history</p>
            </div>
        </div>

        <!-- Summary chips -->
        <div class="oh-summary-chips">
            <div class="oh-chip">
                <span class="oh-chip-value">@_orders.Count</span>
                <span class="oh-chip-label">Total Orders</span>
            </div>
            <div class="oh-chip oh-chip--accent">
                <span class="oh-chip-value">Rs. @_orders.Sum(o => o.TotalAmount).ToString("N0")</span>
                <span class="oh-chip-label">Total Spent</span>
            </div>
            <div class="oh-chip">
                <span class="oh-chip-value">@_orders.Count(o => o.Status == SaleStatus.Completed)</span>
                <span class="oh-chip-label">Completed</span>
            </div>
        </div>
    </header>

    <!-- â”€â”€ FILTER BAR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <section class="oh-filter-bar">

        <!-- Date From -->
        <div class="oh-filter-group">
            <label class="oh-filter-label" for="filter-from">From</label>
            <input id="filter-from"
                   type="date"
                   class="oh-filter-input"
                   value="@(_filter.From?.ToString("yyyy-MM-dd") ?? "")"
                   @onchange="@(e => OnFromDateChange(e.Value?.ToString()))" />
        </div>

        <!-- Date To -->
        <div class="oh-filter-group">
            <label class="oh-filter-label" for="filter-to">To</label>
            <input id="filter-to"
                   type="date"
                   class="oh-filter-input"
                   value="@(_filter.To?.ToString("yyyy-MM-dd") ?? "")"
                   @onchange="@(e => OnToDateChange(e.Value?.ToString()))" />
        </div>

        <!-- Status Filter -->
        <div class="oh-filter-group">
            <label class="oh-filter-label" for="filter-status">Status</label>
            <select id="filter-status" class="oh-filter-select"
                    @onchange="@(e => OnStatusChange(e.Value?.ToString()))">
                <option value="">All Statuses</option>
                <option value="Completed">Completed</option>
                <option value="Voided">Voided</option>
                <option value="Refunded">Refunded</option>
            </select>
        </div>

        <!-- Sale Type Filter -->
        <div class="oh-filter-group">
            <label class="oh-filter-label" for="filter-type">Order Type</label>
            <select id="filter-type" class="oh-filter-select"
                    @onchange="@(e => OnSaleTypeChange(e.Value?.ToString()))">
                <option value="">All Types</option>
                <option value="Online">Online</option>
                <option value="Onsite">Onsite</option>
            </select>
        </div>

        <!-- Action Buttons -->
        <div class="oh-filter-actions">
            <button id="btn-apply-filters" class="oh-btn-apply" @onclick="ApplyFilters">
                <span>ðŸ”</span> Apply
            </button>
            <button id="btn-reset-filters" class="oh-btn-reset" @onclick="ResetFilters">
                â†º Reset
            </button>
        </div>
    </section>

    <!-- â”€â”€ ERROR BANNER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="oh-error-banner" role="alert">
            <span>âš ï¸ @_errorMessage</span>
            <button class="oh-error-dismiss" @onclick="@(() => _errorMessage = null)">âœ•</button>
        </div>
    }

    <!-- â”€â”€ TABLE PANEL â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <section class="oh-table-panel">

        <!-- Loading Skeleton -->
        @if (_isLoading)
        {
            <div class="oh-skeleton-wrapper">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="oh-skeleton-row">
                        <div class="oh-skel oh-skel-sm"></div>
                        <div class="oh-skel oh-skel-md"></div>
                        <div class="oh-skel oh-skel-sm"></div>
                        <div class="oh-skel oh-skel-sm"></div>
                        <div class="oh-skel oh-skel-sm"></div>
                        <div class="oh-skel oh-skel-xs"></div>
                    </div>
                }
            </div>
        }

        <!-- Empty State -->
        else if (_orders.Count == 0)
        {
            <div class="oh-empty-state">
                <div class="oh-empty-icon">ðŸ“‹</div>
                <h2 class="oh-empty-title">No orders found</h2>
                <p class="oh-empty-sub">Try adjusting your filters, or place your first order from the shop.</p>
                <button class="oh-btn-apply" @onclick="@(() => NavigationManager.NavigateTo("/customer/shop"))">
                    ðŸ›ï¸ Go to Shop
                </button>
            </div>
        }

        <!-- Data Table -->
        else
        {
            <!-- Table Column Headers -->
            <div class="oh-table-header oh-table-grid">
                <span class="oh-th">Receipt #</span>
                <span class="oh-th">Date &amp; Time</span>
                <span class="oh-th oh-th-center">Items</span>
                <span class="oh-th oh-th-right">Total</span>
                <span class="oh-th oh-th-center">Status</span>
                <span class="oh-th oh-th-center">Action</span>
            </div>

            <!-- Table Rows -->
            <div class="oh-table-body">
                @foreach (var order in _pagedOrders)
                {
                    <div class="oh-table-row oh-table-grid" id="order-row-@order.SaleId"
                         @onclick="@(() => OpenOrderModal(order))">

                        <!-- Receipt Number -->
                        <div class="oh-td">
                            <span class="oh-receipt-num">@order.ReceiptNumber</span>
                        </div>

                        <!-- Date & Time -->
                        <div class="oh-td">
                            <span class="oh-date-main">@order.SaleDate.ToString("dd MMM yyyy")</span>
                            <span class="oh-date-sub">@order.SaleDate.ToString("hh:mm tt")</span>
                        </div>

                        <!-- Items Count -->
                        <div class="oh-td oh-td-center">
                            <span class="oh-items-pill">@order.Items.Count item@(order.Items.Count != 1 ? "s" : "")</span>
                        </div>

                        <!-- Total -->
                        <div class="oh-td oh-td-right">
                            <span class="oh-total-amount">Rs. @order.TotalAmount.ToString("N0")</span>
                        </div>

                        <!-- Status Badge -->
                        <div class="oh-td oh-td-center">
                            <span class="oh-status-badge oh-status-@order.Status.ToString().ToLower()">
                                @GetStatusIcon(order.Status) @order.Status
                            </span>
                        </div>

                        <!-- Action -->
                        <div class="oh-td oh-td-center" @onclick:stopPropagation="true">
                            <button id="view-btn-@order.SaleId"
                                    class="oh-view-btn"
                                    @onclick="@(() => OpenOrderModal(order))">
                                View Details
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- â”€â”€ PAGINATION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            @if (_totalPages > 1)
            {
                <div class="oh-pagination">
                    <button class="oh-page-btn"
                            disabled="@(_currentPage <= 1)"
                            @onclick="@(() => GoToPage(_currentPage - 1))">
                        â€¹ Prev
                    </button>

                    @for (int p = 1; p <= _totalPages; p++)
                    {
                        int pg = p;
                        <button class="oh-page-btn @(pg == _currentPage ? "oh-page-btn--active" : "")"
                                @onclick="@(() => GoToPage(pg))">
                            @pg
                        </button>
                    }

                    <button class="oh-page-btn"
                            disabled="@(_currentPage >= _totalPages)"
                            @onclick="@(() => GoToPage(_currentPage + 1))">
                        Next â€º
                    </button>
                </div>
            }

            <!-- Row count info -->
            <p class="oh-row-count">
                Showing @_pagedOrders.Count of @_orders.Count order@(_orders.Count != 1 ? "s" : "")
            </p>
        }
    </section>
</div>

<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     ORDER DETAIL MODAL
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
@if (_showModal && _selectedOrder is not null)
{
    <div class="oh-modal-backdrop" @onclick="CloseModal"></div>

    <div class="oh-modal" role="dialog" aria-modal="true" aria-labelledby="modal-receipt-title">

        <!-- Modal Header -->
        <div class="oh-modal-header">
            <div>
                <h2 id="modal-receipt-title" class="oh-modal-title">Order Details</h2>
                <p class="oh-modal-receipt">@_selectedOrder.ReceiptNumber</p>
            </div>
            <button id="modal-close-btn" class="oh-modal-close" @onclick="CloseModal">âœ•</button>
        </div>

        <!-- Order Meta Strip -->
        <div class="oh-modal-meta-strip">
            <div class="oh-modal-meta-item">
                <span class="oh-modal-meta-label">ðŸ“… Date</span>
                <span class="oh-modal-meta-value">@_selectedOrder.SaleDate.ToString("dd MMM yyyy, hh:mm tt")</span>
            </div>
            <div class="oh-modal-meta-item">
                <span class="oh-modal-meta-label">ðŸ“¦ Status</span>
                <span class="oh-status-badge oh-status-@_selectedOrder.Status.ToString().ToLower()">
                    @GetStatusIcon(_selectedOrder.Status) @_selectedOrder.Status
                </span>
            </div>
            <div class="oh-modal-meta-item">
                <span class="oh-modal-meta-label">ðŸ›’ Items</span>
                <span class="oh-modal-meta-value">@_selectedOrder.Items.Count item@(_selectedOrder.Items.Count != 1 ? "s" : "")</span>
            </div>
        </div>

        <!-- Items Table -->
        <div class="oh-modal-items-header oh-modal-items-grid">
            <span class="oh-mth">Product</span>
            <span class="oh-mth oh-mth-center">Qty</span>
            <span class="oh-mth oh-mth-right">Unit Price</span>
            <span class="oh-mth oh-mth-right">Line Total</span>
        </div>

        <div class="oh-modal-items-body">
            @foreach (var item in _selectedOrder.Items)
            {
                <div class="oh-modal-item-row oh-modal-items-grid">
                    <span class="oh-item-name" title="@item.ProductName">@item.ProductName</span>
                    <span class="oh-item-qty oh-td-center">Ã— @item.Quantity</span>
                    <span class="oh-item-price oh-td-right">Rs. @item.UnitPrice.ToString("N0")</span>
                    <span class="oh-item-total oh-td-right">Rs. @item.LineTotal.ToString("N0")</span>
                </div>
            }
        </div>

        <!-- Totals Breakdown -->
        <div class="oh-modal-totals">
            <div class="oh-totals-row">
                <span>Subtotal</span>
                <span>Rs. @_selectedOrder.SubTotal.ToString("N0")</span>
            </div>
            @if (_selectedOrder.DiscountAmount > 0)
            {
                <div class="oh-totals-row oh-totals-discount">
                    <span>Discount</span>
                    <span>âˆ’ Rs. @_selectedOrder.DiscountAmount.ToString("N0")</span>
                </div>
            }
            <div class="oh-totals-row">
                <span>Tax (17% GST)</span>
                <span>Rs. @_selectedOrder.TaxAmount.ToString("N0")</span>
            </div>
            <div class="oh-totals-row oh-totals-grand">
                <span>Total Paid</span>
                <span>Rs. @_selectedOrder.TotalAmount.ToString("N0")</span>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="oh-modal-footer">
            <button class="oh-btn-reset" @onclick="CloseModal">Close</button>
        </div>
    </div>
}


<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     SCOPED STYLES  â€” ALL COLORS FROM colors.css VARIABLES
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@@300;400;500;600;700;800&display=swap');

    /* â”€â”€ Scope Reset â”€â”€ */
    .oh-root *,
    .oh-modal *,
    .oh-modal-backdrop {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       ROOT WRAPPER
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .oh-root {
        min-height: 100vh;
        background: var(--color-page-bg);
        color: var(--color-primary-text);
        padding: 2rem 2.5rem 4rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       PAGE HEADER
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .oh-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid rgba(61,28,2,.1);
    }

    .oh-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .oh-header-icon {
        font-size: 2.4rem;
        line-height: 1;
        flex-shrink: 0;
    }

    .oh-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--color-heading-text);
        margin: 0 0 .2rem;
        letter-spacing: -.4px;
    }

    .oh-subtitle {
        font-size: .875rem;
        color: var(--color-primary-text);
        opacity: .55;
        margin: 0;
        font-weight: 400;
    }

    /* Summary Chips */
    .oh-summary-chips {
        display: flex;
        gap: .85rem;
        flex-wrap: wrap;
    }

    .oh-chip {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: var(--color-card-bg);
        border: 1.5px solid rgba(61,28,2,.12);
        border-radius: 12px;
        padding: .6rem 1.25rem;
        min-width: 90px;
        box-shadow: 0 2px 8px rgba(61,28,2,.07);
        transition: transform .16s, box-shadow .16s;
    }

    .oh-chip:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(61,28,2,.12);
    }

    .oh-chip--accent {
        background: var(--color-navbar-bg);
        border-color: var(--color-navbar-bg);
    }

    .oh-chip--accent .oh-chip-value,
    .oh-chip--accent .oh-chip-label {
        color: var(--color-page-bg);
    }

    .oh-chip-value {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--color-heading-text);
        line-height: 1.2;
    }

    .oh-chip-label {
        font-size: .65rem;
        font-weight: 600;
        letter-spacing: .6px;
        text-transform: uppercase;
        color: var(--color-primary-text);
        opacity: .55;
        margin-top: .15rem;
    }

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       FILTER BAR
       â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .oh-filter-bar {
        display: flex;
        align-items: flex-end;
        gap: 1rem;
        flex-wrap: wrap;
        background: var(--color-card-bg);
        border: 1.5px solid rgba(61,28,2,.1);
        border-radius: 16px;
        padding: 1.1rem 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 10px rgba(61,28,2,.06);
    }

    .oh-filter-group {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        flex: 1;
        min-width: 140px;
    }

    .oh-filter-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .7px;
        text-transform: uppercase;
        color: var(--color-heading-text);
        opacity: .65;
    }

    .oh-filter-input,
    .oh-filter-select {
        height: 40px;
        padding: 0 .85rem;
        border: 1.5px solid rgba(61,28,2,.18);
        border-radius: 10px;
        background: var(--color-page-bg);
        color: var(--color-primary-text);
        font-size: .875rem;
        font-weight: 500;
        outline: none;
        cursor: pointer;
        transition: border-color .18s, box-shadow .18s;
        width: 100%;
    }

    .oh-filter-input:focus,
    .oh-filter-select:focus {
        border-color: var(--color-border-accent);
        box-shadow: 0 0 0 3px rgba(196,132,138,.2);
    }

    .oh-filter-select { appearance: auto; }

    .oh-filter-actions {
        display: flex;
        gap: .6rem;
        align-items: flex-end;
        flex-shrink: 0;
    }

    .oh-btn-apply {
        display: flex;
        align-items: center;
        gap: .4rem;
        background: var(--color-button-primary);
        color: #fff;
        border: none;
        border-radius: 10px;
        height: 40px;
        padding: 0 1.2rem;
        font-size: .875rem;
