@page "/register"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using SmartPOS.Data
@using SmartPOS.Models
@using SmartPOS.Shared.Enums
@inject AppDbContext DbContext
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Register> Logger

<PageTitle>Create New Account - SmartPOS+</PageTitle>

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Create New Account</h1>
        @if (!string.IsNullOrEmpty(_currentUserRole))
        {
            <p class="auth-subtitle">@_currentUserRole context</p>
        }
        else
        {
            <p class="auth-subtitle">Create your account to get started</p>
        }

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="validation-message-box">
                    @errorMessage
                </div>
            }

            @if (isSuccess)
            {
                <div class="validation-message-box" style="background-color: #f0fdf4; border-color: #86efac; color: #166534;">
                    Account created successfully. Redirecting...
                </div>
            }

            <div class="auth-form-group">
                <label class="auth-label">Full Name</label>
                <div class="input-container">
                    <InputText @bind-Value="registerModel.Name" class="auth-input" placeholder="Full name" />
                </div>
                <ValidationMessage For="@(() => registerModel.Name)" class="text-danger" />
            </div>

            <div class="auth-form-group">
                <label class="auth-label">Email Address</label>
                <div class="input-container">
                    <InputText @bind-Value="registerModel.Email" class="auth-input" placeholder="e.g. name@smartpos.com" />
                </div>
                <ValidationMessage For="@(() => registerModel.Email)" class="text-danger" />
            </div>

            <div class="auth-form-group">
                <label class="auth-label">Password</label>
                <div class="input-container">
                    <InputText @bind-Value="registerModel.Password" type="password" class="auth-input" placeholder="Minimum 6 characters" />
                </div>
                <ValidationMessage For="@(() => registerModel.Password)" class="text-danger" />
            </div>

            <div class="auth-form-group">
                <label class="auth-label">Confirm Password</label>
                <div class="input-container">
                    <InputText @bind-Value="registerModel.ConfirmPassword" type="password" class="auth-input" placeholder="Re-enter your password" />
                </div>
                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="text-danger" />
            </div>

            <button type="submit" class="auth-btn" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Create Account</span>
                }
            </button>

            @if (!string.IsNullOrEmpty(_currentUserRole))
            {
                <div class="auth-links" style="justify-content: center;">
                    <a href="/@_currentUserRole.ToLower()/dashboard">Back to Dashboard</a>
                </div>
            }
            else
            {
                <div class="auth-links" style="justify-content: center;">
                    <a href="/login">Back to Sign In</a>
                </div>
            }
        </EditForm>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private bool isLoading;
    private bool isSuccess;
    private string _currentUserRole = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var roleClaim = user.FindFirst(c => c.Type == ClaimTypes.Role)?.Value;
            _currentUserRole = roleClaim ?? "";
        }
    }

    private async Task HandleRegister()
    {
        if (isLoading) return;
        isLoading = true;
        errorMessage = null;
        isSuccess = false;

        try
        {
            var existingUser = await DbContext.Users
                .FirstOrDefaultAsync(u => u.Email == registerModel.Email);
            if (existingUser != null)
            {
                errorMessage = "Email is already registered.";
                return;
            }

            var newRoleName = _currentUserRole switch
            {
                "Admin" => "Manager",
                "Manager" => "Cashier",
                "Cashier" => "Customer",
                _ => "Customer"
            };

            var newRole = await DbContext.Roles
                .FirstOrDefaultAsync(r => r.Name == newRoleName);
            if (newRole == null)
            {
                errorMessage = "Unable to determine account role.";
                return;
            }

            var newUser = new User
            {
                Name = registerModel.Name,
                Email = registerModel.Email,
                PasswordHash = BCrypt.Net.BCrypt.HashPassword(registerModel.Password),
                RoleId = newRole.Id,
                IsActive = true,
                CreatedAt = DateTime.UtcNow
            };

            DbContext.Users.Add(newUser);
            await DbContext.SaveChangesAsync();

            if (newRoleName == "Customer")
            {
                var customerProfile = new Customer
                {
                    UserId = newUser.Id
                };
                DbContext.Customers.Add(customerProfile);
                await DbContext.SaveChangesAsync();
            }

            isSuccess = true;
            registerModel = new();
            await Task.Delay(2000);
            if (!string.IsNullOrEmpty(_currentUserRole))
                NavigationManager.NavigateTo($"/{_currentUserRole.ToLower()}/dashboard");
            else
                NavigationManager.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Account creation failed for email {Email}", registerModel.Email);
            errorMessage = "An error occurred during account creation. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required.")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Confirm Password is required.")]
        [System.ComponentModel.DataAnnotations.Compare("Password", ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
