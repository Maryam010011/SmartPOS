    // Delete Operations
    private void PromptDelete(UserDto user)
    {
        DeleteUserTarget = user;
        DeletePromptVisible = true;
    }

    private void CancelDelete()
    {
        DeleteUserTarget = null;
        DeletePromptVisible = false;
    }

    private async Task ConfirmDelete()
    {
        if (DeleteUserTarget == null) return;
        IsLoading = true;
        StateHasChanged();

        try
        {
            var response = await UserService.DeleteUser(DeleteUserTarget.Id);
            if (response.Success)
            {
                CancelDelete();
                await ReloadUsers();
            }
        }
        catch (Exception) { }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    // Pagination Methods
    private async Task PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            await ReloadUsers();
        }
    }

    private async Task NextPage()
    {
        if (UsersList != null && UsersList.Count == PageSize)
        {
            CurrentPage++;
            await ReloadUsers();
        }
    }

    // Initials & Helpers
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }
