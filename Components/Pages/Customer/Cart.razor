@code {
    // в”Ђв”Ђ Promo Code State в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private string               _promoCode      = string.Empty;
    private bool                 _isApplyingPromo = false;
    private ApplyPromoResultDto? _appliedPromo    = null;
    private string?              _promoError      = null;

    // в”Ђв”Ђ Checkout Modal State в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private bool          _showCheckoutModal = false;
    private int           _checkoutStep      = 1;
    private PaymentMethod _selectedPayment   = PaymentMethod.Cash;
    private bool          _isPlacingOrder    = false;
    private string?       _checkoutError     = null;

    // в”Ђв”Ђ Post-Order State в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private SaleResultDto? _saleResult  = null;
    private bool           _orderPlaced = false;

    // в”Ђв”Ђ Computed Totals в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    /// <summary>
    /// Discount from applied promo. Defaults to 0 until MaryamJ's promo service
    /// is wired and a valid promo is applied.
    /// </summary>
    private decimal DiscountAmount => _appliedPromo?.DiscountAmount ?? 0m;

    /// <summary>
    /// Client-side GST estimate at 5%. The final authoritative tax is
    /// computed server-side by ISaleService.ProcessSale ГўвЂ ' IFBRService.CalculateTax.
    /// </summary>
    private decimal EstimatedTax => Math.Round((CartState.SubTotal - DiscountAmount) * 0.05m, 0);

    private decimal GrandTotal => CartState.SubTotal - DiscountAmount + EstimatedTax;

    // в”Ђв”Ђ Lifecycle в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    protected override void OnInitialized()
    {
        // Subscribe to cart changes so this page re-renders when
        // Shop.razor mutates the shared CartStateService (e.g. user
        // navigates back and modifies an item in the sidebar).
        CartState.OnCartChanged += HandleCartChanged;
    }

    private void HandleCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CartState.OnCartChanged -= HandleCartChanged;
    }

    // в”Ђв”Ђ Cart Mutations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private void Increment(int productId) => CartState.UpdateQuantity(productId, +1);
    private void Decrement(int productId) => CartState.UpdateQuantity(productId, -1);
    private void Remove(int productId)    => CartState.RemoveItem(productId);
    private void ClearAll()              => CartState.Clear();

    // в”Ђв”Ђ Promo Code в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    /// <summary>
    /// Promo code validation UI shell.
    ///
    /// Гў*"Гў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*Вђв•—
    /// в•‘  TODO  -  WIRE-UP PENDING (MaryamJ branch merge)          в•‘
    /// в•‘                                                          в•‘
    /// в•‘  Once MaryamJ's IPromotionService is merged, replace     в•‘
    /// в•‘  the stub below with:                                    в•‘
    /// в•‘                                                          в•‘
    /// в•‘    1. Add @inject IPromotionService PromotionService     в•‘
    /// в•‘       to the top of this file.                          в•‘
    /// в•‘                                                          в•‘
    /// в•‘    2. Replace the Task.Delay stub with:                  в•‘
    /// в•‘         var r = await PromotionService                   в•‘
    /// в•‘                   .ValidateAndApply(                     в•‘
    /// в•‘                       _promoCode.Trim(),                 в•‘
    /// в•‘                       CartState.SubTotal);               в•‘
    /// в•‘         if (r.Success && r.Data?.IsValid == true)        в•‘
    /// в•‘             _appliedPromo = r.Data;                      в•‘
    /// в•‘         else                                             в•‘
    /// в•‘             _promoError = r.Data?.Message ?? r.Message;  в•‘
    /// Гў*ЕЎГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*ВђГў*Вќ
    /// </summary>
    private async Task ApplyPromoCode()
    {
        if (string.IsNullOrWhiteSpace(_promoCode)) return;

        _isApplyingPromo = true;
        _promoError      = null;
        _appliedPromo    = null;
        StateHasChanged();

        // в”Ђв”Ђ STUB: Simulates a network call while MaryamJ's service is in development в”Ђв”Ђ
        await Task.Delay(700);
        _promoError = $"Code \"{_promoCode.Trim().ToUpperInvariant()}\"  -  promo validation service is pending (MaryamJ branch).";
        // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

        _isApplyingPromo = false;
    }

    private void RemovePromo()
    {
        _appliedPromo = null;
        _promoCode    = string.Empty;
        _promoError   = null;
    }

    // в”Ђв”Ђ Checkout Modal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private void OpenCheckoutModal()
    {
        _checkoutStep      = 1;
        _checkoutError     = null;
        _selectedPayment   = PaymentMethod.Cash;
        _showCheckoutModal = true;
    }

    private void CloseCheckoutModal()
    {
        _showCheckoutModal = false;
        _checkoutError     = null;
    }

    // в”Ђв”Ђ Place Order в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    /// <summary>
    /// Assembles CreateSaleDto from current cart state and calls
    /// ISaleService.ProcessSale (Shahzain's implementation in SaleService.cs).
    ///
    /// Notes:
    ///   UserId  = 1 as guest/fallback until ClaimsPrincipal auth is integrated.
    ///   CustomerId = null for anonymous guest checkout.
    ///   On success: cart is cleared, receipt shown in modal step 3.
    ///   On failure: error displayed inline in step 2.
    /// </summary>
    private async Task PlaceOrder()
    {
        _isPlacingOrder = true;
        _checkoutError  = null;
        StateHasChanged();

        var dto = new CreateSaleDto
        {
            CustomerId    = null,     // TODO: resolve from auth context once login is wired
            UserId        = 1,        // TODO: replace with authenticated user ID
            PromoCode     = _appliedPromo is not null ? _promoCode.Trim() : null,
            SaleType      = SaleType.Online,
            PaymentMethod = _selectedPayment,
            Items         = CartState.Items
                .Select(i => new SaleItemDto
                {
                    ProductId   = i.Product.Id,
                    ProductName = i.Product.Name,
                    Quantity    = i.Quantity,
                    UnitPrice   = i.Product.Price,
                    LineTotal   = i.Product.Price * i.Quantity
                })
                .ToList()
        };

        var result = await SaleService.ProcessSale(dto);

        _isPlacingOrder = false;

        if (result.Success && result.Data is not null)
        {
            _saleResult   = result.Data;
            _checkoutStep = 3;          // advance to receipt step
            CartState.Clear();          // clear cart  -  order is placed
        }
        else
        {
            _checkoutError = result.Message.Length > 0
                ? result.Message
                : "An unexpected error occurred. Please try again.";
        }
    }

    /// <summary>
    /// Called when user clicks "Done" on the receipt step.
    /// Closes modal and shows the full-page receipt (cart page empty state).
    /// </summary>
    private void FinishOrder()
    {
        _showCheckoutModal = false;
        _orderPlaced       = true;
        // _saleResult stays set  -  used by the full-page receipt section
    }

    // в”Ђв”Ђ Navigation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    private void GoToShop() => Navigation.NavigateTo("/customer/shop");
}
