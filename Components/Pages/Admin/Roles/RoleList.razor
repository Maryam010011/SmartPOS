@page "/admin/roles"
@layout AdminLayout
@using SmartPOS.Shared.DTOs.Roles
@using SmartPOS.Shared.Interfaces
@using SmartPOS.Shared.Common
@inject IRoleService RoleService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background-color: var(--color-page-bg); min-height: 100vh;">
    <!-- Toast Container -->
    @if (!string.IsNullOrEmpty(ToastMessage))
    {
        <div class="toast-container-pos">
            <div class="toast-pos toast-@ToastType">
                <span class="toast-icon">
                    @switch (ToastType)
                    {
                        case "success": <text>âœ…</text>; break;
                        case "error": <text>âŒ</text>; break;
                        case "warning": <text>âš ï¸</text>; break;
                        default: <text>â„¹ï¸</text>; break;
                    }
                </span>
                <span class="toast-body">@ToastMessage</span>
                <button class="toast-close" @onclick="DismissToast">&times;</button>
            </div>
        </div>
    }

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-button-primary);">Role Management</h2>
            <p class="text-muted m-0">Define system roles and configure granular permissions for the POS workflow.</p>
        </div>
        <button type="button" class="btn btn-burnt-orange d-flex align-items-center gap-2" @onclick="OpenAddModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
            </svg>
            <span>Add Role</span>
        </button>
    </div>

    <!-- Main Table Card -->
    <div class="card card-pos">
        <div class="card-body p-0">
            @if (IsLoading)
            {
                <div class="d-flex justify-content-center align-items-center py-5 my-5 flex-column gap-3">
                    <div class="spinner-border" style="width: 3rem; height: 3rem; color: var(--color-button-primary) !important;" role="status"></div>
                    <span class="fw-semibold text-secondary">Loading roles...</span>
                </div>
            }
            else if (RolesList == null || !RolesList.Any())
            {
                <div class="text-center py-5 my-5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-secondary mb-3" viewBox="0 0 16 16">
                        <path d="M4.5 11.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-3a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-3a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5"/>
                        <path d="M3 0a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V1a1 1 0 0 0-1-1zm0 1h10v14H3z"/>
                    </svg>
                    <h5 class="fw-bold text-dark">No Roles Found</h5>
                    <p class="text-muted small">No roles have been created yet. Add one to get started.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-pos align-middle m-0 table-hover">
                        <thead class="table-light">
                            <tr>
                                <th style="padding-left: 20px;">Role Name</th>
                                <th style="width: 160px;">Users Assigned</th>
                                <th>Permissions Summary</th>
                                <th class="text-end" style="padding-right: 20px; width: 200px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in RolesList)
                            {
                                var permSummary = GetPermissionsSummary(role.Id);
                                <tr>
                                    <td style="padding-left: 20px;">
                                        @if (EditingRoleId == role.Id)
                                        {
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="text" class="input-edit-inline" @bind="EditNameValue"
                                                       @onkeydown="(e) => HandleEditKeydown(e, role.Id)" />
                                                <button class="btn btn-sm btn-burnt-orange" @onclick="() => ConfirmEditName(role.Id)" title="Save">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0"/>
                                                    </svg>
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditName" title="Cancel">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/>
                                                    </svg>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="fw-bold text-dark">@role.RoleName</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @(role.UserCount > 0 ? "bg-dark" : "bg-secondary") px-3 py-2 fw-bold">
                                            @role.UserCount @(role.UserCount == 1 ? "user" : "users")
                                        </span>
                                    </td>
                                    <td>
                                        @if (permSummary != null)
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @if (permSummary.IsFullAccess)
                                                {
                                                    <span class="badge-summary-full badge-perm-summary">Full Access</span>
                                                }
                                                else if (permSummary.IsReadOnly)
                                                {
                                                    <span class="badge-summary-readonly badge-perm-summary">Read Only</span>
                                                }
                                                else
                                                {
                                                    @if (permSummary.FullCount > 0)
                                                    {
                                                        <span class="perm-pill perm-pill-full">@permSummary.FullCount Full</span>
                                                    }
                                                    @if (permSummary.ReadOnlyCount > 0)
                                                    {
                                                        <span class="perm-pill perm-pill-read">@permSummary.ReadOnlyCount Read</span>
                                                    }
                                                    @if (permSummary.CustomCount > 0)
                                                    {
                                                        <span class="perm-pill perm-pill-custom">@permSummary.CustomCount Custom</span>
                                                    }
                                                    @if (permSummary.FullCount == 0 && permSummary.ReadOnlyCount == 0 && permSummary.CustomCount == 0)
                                                    {
                                                        <span class="badge-summary-none badge-perm-summary">No Permissions</span>
                                                    }
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                        }
                                    </td>
                                    <td class="text-end" style="padding-right: 20px;">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-burnt-orange fw-semibold"
                                                    @onclick="() => NavigateToPermissions(role.Id)"
                                                    title="Configure Permissions">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                                    <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                                                </svg>
                                                Permissions
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary fw-semibold"
                                                    @onclick="() => StartEditName(role)"
                                                    title="Edit Name">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.5-.5V9h-.5a.5.5 0 0 1-.5-.5v-.5a.5.5 0 0 1 .146-.354l6-6a.5.5 0 0 1 .708 0l3.75 3.75a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.354.146z"/>
                                                </svg>
                                            </button>
                                            <button class="btn btn-sm @(role.UserCount > 0 ? "btn-outline-danger" : "btn-outline-danger") fw-semibold"
                                                    @onclick="() => PromptDelete(role)"
                                                    disabled="@(role.UserCount > 0)"
                                                    title="@(role.UserCount > 0 ? "Cannot delete â€” users are assigned to this role" : "Delete role")">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.18a.5.5 0 0 0-.548.436l-.5 8.5a.5.5 0 1 0 .996.06l.5-8.5a.5.5 0 0 0-.436-.548M6.165 5.25a.5.5 0 0 0-.93.244l.15 8.5a.5.5 0 1 0 .99-.017l-.15-8.5z"/>
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Role Modal -->
@if (ShowAddModal)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content card-pos">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" style="color: var(--color-button-primary);">Add New Role</h5>
                    <button type="button" class="btn-close" @onclick="CancelAdd"></button>
                </div>
                <div class="modal-body py-3">
                    <label class="form-label fw-semibold text-dark small">Role Name</label>
                    <input type="text" class="form-control" placeholder="e.g. Floor Manager"
                           @bind="NewRoleName" @bind:event="oninput"
                           @onkeydown="HandleAddKeydown" />
                    @if (!string.IsNullOrEmpty(AddError))
                    {
                        <div class="text-danger small mt-2 d-flex align-items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                            </svg>
                            <span>@AddError</span>
                        </div>
                    }
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelAdd">Cancel</button>
                    <button type="button" class="btn btn-burnt-orange px-4 fw-bold" @onclick="ConfirmAdd" disabled="@(string.IsNullOrWhiteSpace(NewRoleName) || IsSaving)">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <span>Create Role</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show modal-backdrop-pos"></div>
}

<!-- Delete Confirmation Modal -->
@if (ShowDeletePrompt && DeleteTarget != null)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content card-pos border border-danger-subtle">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger">Delete Role</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="m-0 text-dark">
                        Are you sure you want to delete <strong>@DeleteTarget.RoleName</strong>?
                    </p>
                    <p class="text-muted small mt-2 m-0 border-start border-3 ps-2 border-danger-subtle">
                        This action cannot be undone. All permissions associated with this role will be removed.
                    </p>
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger px-4 fw-bold" @onclick="ConfirmDelete" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <span>Delete Role</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show modal-backdrop-pos"></div>
}

@code {
    private List<RoleDto>? RolesList { get; set; }
    private Dictionary<int, PermissionsDto?> PermissionsCache { get; set; } = new();
    private Dictionary<int, RoleSummary> SummaryCache { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }

    // Toast
    private string ToastMessage { get; set; } = string.Empty;
    private string ToastType { get; set; } = "success";

    // Add Modal
    private bool ShowAddModal { get; set; }
    private string NewRoleName { get; set; } = string.Empty;
    private string AddError { get; set; } = string.Empty;

    // Inline Edit
    private int? EditingRoleId { get; set; }
    private string EditNameValue { get; set; } = string.Empty;
    private RoleDto? EditingRole { get; set; }

    // Delete
    private bool ShowDeletePrompt { get; set; }
    private RoleDto? DeleteTarget { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
    }

    private async Task LoadRoles()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var response = await RoleService.GetAllRoles();
            if (response.Success)
            {
                RolesList = response.Data;
                PermissionsCache.Clear();
                SummaryCache.Clear();

                // Load permissions sequentially to avoid DbContext concurrency
                foreach (var role in RolesList!)
                {
                    try
                    {
                        var permResponse = await RoleService.GetRolePermissions(role.Id);
                        if (permResponse.Success)
                        {
                            PermissionsCache[role.Id] = permResponse.Data;
                            SummaryCache[role.Id] = ComputeSummary(permResponse.Data);
                        }
                        else
                        {
                            PermissionsCache[role.Id] = null;
                            SummaryCache[role.Id] = new RoleSummary();
                        }
                    }
                    catch
                    {
                        PermissionsCache[role.Id] = null;
                        SummaryCache[role.Id] = new RoleSummary();
                    }
                }
            }
            else
            {
                RolesList = new List<RoleDto>();
            }
        }
        catch
        {
            RolesList = new List<RoleDto>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private RoleSummary? GetPermissionsSummary(int roleId)
    {
        if (SummaryCache.TryGetValue(roleId, out var summary))
            return summary;
        return null;
    }

    private static RoleSummary ComputeSummary(PermissionsDto? perms)
    {
        if (perms?.Modules == null || perms.Modules.Count == 0)
            return new RoleSummary();

        var modules = perms.Modules;
        int total = modules.Count;
        int fullAccess = modules.Count(m => m.Value is { CanCreate: true, CanRead: true, CanUpdate: true, CanDelete: true });
        int readOnly = modules.Count(m => m.Value is { CanCreate: false, CanRead: true, CanUpdate: false, CanDelete: false });
        int custom = total - fullAccess - readOnly;

        return new RoleSummary
        {
            IsFullAccess = fullAccess == total && total > 0,
            IsReadOnly = readOnly == total && total > 0,
            FullCount = fullAccess,
            ReadOnlyCount = readOnly,
            CustomCount = custom
        };
    }

    // â”€â”€ Add Role â”€â”€
    private void OpenAddModal()
    {
        NewRoleName = string.Empty;
        AddError = string.Empty;
        ShowAddModal = true;
    }

    private void CancelAdd()
    {
        ShowAddModal = false;
    }

    private async void HandleAddKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ConfirmAdd();
        else if (e.Key == "Escape")
            CancelAdd();
    }

    private async Task ConfirmAdd()
    {
        if (string.IsNullOrWhiteSpace(NewRoleName)) return;

        IsSaving = true;
        AddError = string.Empty;
        StateHasChanged();

        try
        {
            var dto = new CreateRoleDto { RoleName = NewRoleName.Trim() };
            var response = await RoleService.CreateRole(dto);
            if (response.Success)
            {
                ShowAddModal = false;
                ShowToast("success", $"Role \"{NewRoleName.Trim()}\" created successfully!");
                await LoadRoles();
            }
            else
            {
                AddError = response.Message;
            }
        }
        catch
        {
            AddError = "An unexpected error occurred.";
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    // â”€â”€ Inline Edit Name â”€â”€
    private void StartEditName(RoleDto role)
    {
        EditingRoleId = role.Id;
        EditingRole = role;
        EditNameValue = role.RoleName;
    }

    private void CancelEditName()
    {
        EditingRoleId = null;
        EditingRole = null;
        EditNameValue = string.Empty;
    }

    private async Task HandleEditKeydown(KeyboardEventArgs e, int roleId)
    {
        if (e.Key == "Enter")
            await ConfirmEditName(roleId);
        else if (e.Key == "Escape")
            CancelEditName();
    }

    private async Task ConfirmEditName(int roleId)
    {
        if (EditingRole == null || string.IsNullOrWhiteSpace(EditNameValue)) return;

        var newName = EditNameValue.Trim();
        if (newName == EditingRole.RoleName)
        {
            CancelEditName();
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            var dto = new UpdateRoleDto
            {
                RoleName = newName,
                Permissions = PermissionsCache.TryGetValue(roleId, out var p) && p != null
                    ? p
                    : new PermissionsDto()
            };

            var response = await RoleService.UpdateRole(roleId, dto);
            if (response.Success)
            {
                CancelEditName();
                ShowToast("success", $"Role renamed to \"{newName}\".");
                await LoadRoles();
            }
            else
            {
                ShowToast("error", response.Message);
                CancelEditName();
            }
        }
        catch
        {
            ShowToast("error", "Failed to update role name.");
            CancelEditName();
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    // â”€â”€ Delete â”€â”€
    private void PromptDelete(RoleDto role)
    {
        DeleteTarget = role;
        ShowDeletePrompt = true;
    }

    private void CancelDelete()
    {
        DeleteTarget = null;
        ShowDeletePrompt = false;
    }

    private async Task ConfirmDelete()
    {
        if (DeleteTarget == null) return;

        IsSaving = true;
        StateHasChanged();

        try
        {
            var response = await RoleService.DeleteRole(DeleteTarget.Id);
            if (response.Success)
            {
                ShowDeletePrompt = false;
                ShowToast("success", $"Role \"{DeleteTarget.RoleName}\" deleted.");
                await LoadRoles();
            }
            else
            {
                ShowToast("error", response.Message);
                CancelDelete();
            }
        }
        catch
        {
            ShowToast("error", "Failed to delete role.");
            CancelDelete();
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    // â”€â”€ Navigation â”€â”€
    private void NavigateToPermissions(int roleId)
    {
        Navigation.NavigateTo($"/admin/roles/{roleId}/permissions");
    }

    // â”€â”€ Toast â”€â”€
    private void ShowToast(string type, string message)
    {
        ToastType = type;
        ToastMessage = message;
        StateHasChanged();
    }

    private void DismissToast()
    {
        ToastMessage = string.Empty;
    }

    // â”€â”€ Summary Model â”€â”€
    private class RoleSummary
    {
        public bool IsFullAccess { get; set; }
        public bool IsReadOnly { get; set; }
        public int FullCount { get; set; }
        public int ReadOnlyCount { get; set; }
        public int CustomCount { get; set; }
    }
}
